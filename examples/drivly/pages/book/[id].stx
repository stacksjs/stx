    <div class="step-line flex-1 h-[1.5px] bg-[color:var(--border)] mx-3 min-w-5"></div>
    <div class="step flex items-center gap-2.5 text-[0.8125rem] font-medium text-[color:var(--text-muted)]" data-step="2"><span class="step-num w-7 h-7 rounded-full bg-[color:var(--bg-subtle)] text-[color:var(--text-muted)] inline-flex items-center justify-center font-semibold flex-shrink-0 border border-[color:var(--border)] transition-all">2</span> Protection</div>
    <div class="step-line flex-1 h-[1.5px] bg-[color:var(--border)] mx-3 min-w-5"></div>
    <div class="step flex items-center gap-2.5 text-[0.8125rem] font-medium text-[color:var(--text-muted)]" data-step="3"><span class="step-num w-7 h-7 rounded-full bg-[color:var(--bg-subtle)] text-[color:var(--text-muted)] inline-flex items-center justify-center font-semibold flex-shrink-0 border border-[color:var(--border)] transition-all">3</span> Extras</div>
    <div class="step-line flex-1 h-[1.5px] bg-[color:var(--border)] mx-3 min-w-5"></div>
    <div class="step flex items-center gap-2.5 text-[0.8125rem] font-medium text-[color:var(--text-muted)]" data-step="4"><span class="step-num w-7 h-7 rounded-full bg-[color:var(--bg-subtle)] text-[color:var(--text-muted)] inline-flex items-center justify-center font-semibold flex-shrink-0 border border-[color:var(--border)] transition-all">4</span> Driver</div>
    <div class="step-line flex-1 h-[1.5px] bg-[color:var(--border)] mx-3 min-w-5"></div>
    <div class="step flex items-center gap-2.5 text-[0.8125rem] font-medium text-[color:var(--text-muted)]" data-step="5"><span class="step-num w-7 h-7 rounded-full bg-[color:var(--bg-subtle)] text-[color:var(--text-muted)] inline-flex items-center justify-center font-semibold flex-shrink-0 border border-[color:var(--border)] transition-all">5</span> Pay</div>
