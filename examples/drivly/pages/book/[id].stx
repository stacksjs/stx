<script client>
  if (!window.__bookingPage) {
    window.__bookingPage = true

    const PRICE = {{ car.price }}
    const PLANS = {{ protectionPlans }}
    const EXTRAS = {{ extras }}
    const CAR_NAME = {{ car.make + ' ' + car.model }}

    // Read URL params
    const params = new URLSearchParams(location.search)
    const today = new Date()
    const t3 = new Date(); t3.setDate(today.getDate() + 3)
    const t6 = new Date(); t6.setDate(today.getDate() + 6)
    const fmt = d => d.toISOString().slice(0, 10)

    document.getElementById('from').value = params.get('from') || fmt(t3)
    document.getElementById('to').value = params.get('to') || fmt(t6)
    document.getElementById('ft').value = params.get('ft') || '10:00'
    document.getElementById('tt').value = params.get('tt') || '10:00'

    // ── Reactive booking state ──
    const step = state(1)
    const fromDate = state(document.getElementById('from').value)
    const toDate = state(document.getElementById('to').value)
    const planId = state('premium')
    const extrasSelected = state([])

    document.getElementById('from').addEventListener('change', function () { fromDate.set(this.value) })
    document.getElementById('to').addEventListener('change', function () { toDate.set(this.value) })

    const days = derived(() => {
      const f = new Date(fromDate()); const t = new Date(toDate())
      const ms = Math.max(0, t - f)
      return Math.max(1, Math.ceil(ms / (24 * 3600 * 1000)))
    })

    // ── Step navigation ──
    function goto(n) {
      if (n < 1 || n > 6) return
      step.set(n)
      window.scrollTo({ top: 0, behavior: 'smooth' })
    }

    effect(() => {
      const n = step()
      // Panels
      document.querySelectorAll('.step-panel').forEach(p => {
        p.style.display = Number(p.dataset.panel) === n ? 'block' : 'none'
      })
      // Stepper
      document.querySelectorAll('.step').forEach(s => {
        const num = Number(s.dataset.step)
        s.classList.toggle('active', num === n)
        s.classList.toggle('done', num < n)
      })
    })

    document.querySelectorAll('.next-btn').forEach(b => {
      b.addEventListener('click', function () { goto(Number(this.dataset.goto)) })
    })
    document.querySelectorAll('.back-btn').forEach(b => {
      b.addEventListener('click', function () { goto(Number(this.dataset.goto)) })
    })

    // ── Protection ──
    document.querySelectorAll('.protection-card').forEach(c => {
      c.addEventListener('click', function () {
        document.querySelectorAll('.protection-card').forEach(o => o.classList.remove('selected'))
        this.classList.add('selected')
        planId.set(this.dataset.plan)
      })
    })

    // ── Extras ──
    document.querySelectorAll('[data-extra]').forEach(el => {
      el.addEventListener('click', function (e) {
        if (e.target.tagName !== 'INPUT') {
          const cb = this.querySelector('input')
          cb.checked = !cb.checked
        }
        const checked = this.querySelector('input').checked
        this.classList.toggle('selected', checked)
        const current = extrasSelected()
        if (checked && !current.includes(this.dataset.extra)) extrasSelected.set([...current, this.dataset.extra])
        else if (!checked) extrasSelected.set(current.filter(x => x !== this.dataset.extra))
      })
    })

    // ── Payment method selection ──
    document.querySelectorAll('input[name="payment"]').forEach(r => {
      r.addEventListener('change', function () {
        document.querySelectorAll('.pay-method').forEach(l => {
          if (l.querySelector('input[name="payment"]')) l.classList.toggle('selected', l.querySelector('input').checked)
        })
      })
    })

    // ── Driver form validation ──
    document.getElementById('driverContinue').addEventListener('click', function () {
      const form = document.getElementById('driverForm')
      if (!form.checkValidity()) {
        form.reportValidity()
        return
      }
      goto(5)
    })

    // ── Reserve ──
    document.getElementById('reserveBtn').addEventListener('click', function () {
      const terms = document.getElementById('acceptTerms')
      if (!terms.checked) { window._toast('Please accept the terms to continue', 'error'); return }
      const btn = this
      btn.disabled = true
      btn.innerHTML = '<span style="display:inline-block; width: 16px; height: 16px; border: 2px solid white; border-top-color: transparent; border-radius: 50%; animation: spin 0.7s linear infinite"></span> Processing...'
      setTimeout(() => {
        goto(6)
        document.getElementById('bookingRef').textContent = Math.floor(100000 + Math.random() * 900000)
        window._toast('Trip booked · You\'ll hear from the host soon!', 'success')
      }, 1200)
    })

    // ── Summary totals ──
    effect(() => {
      const d = days()
      const plan = PLANS.find(p => p.id === planId())
      const sub = PRICE * d
      const fee = sub * 0.1
      const prot = PRICE * plan.priceMultiplier * d
      const extrasTotal = extrasSelected().reduce((sum, id) => {
        const e = EXTRAS.find(x => x.id === id)
        return sum + (e ? e.price * d : 0)
      }, 0)
      const total = sub + fee + prot + extrasTotal

      document.getElementById('sDays').textContent = d
      document.getElementById('sSub').textContent = '$' + sub.toFixed(2)
      document.getElementById('sFee').textContent = '$' + fee.toFixed(2)
      document.getElementById('sProt').textContent = '$' + prot.toFixed(2)
      document.getElementById('sPlan').textContent = plan.name
      document.getElementById('sExtras').textContent = '$' + extrasTotal.toFixed(2)
      document.getElementById('sExtrasRow').style.display = extrasTotal > 0 ? 'flex' : 'none'
      document.getElementById('sTotal').textContent = '$' + total.toFixed(2)

      // Dates summary
      const f = new Date(fromDate()); const t = new Date(toDate())
      const opt = { month: 'short', day: 'numeric' }
      document.getElementById('sumDates').textContent = f.toLocaleDateString(undefined, opt) + ' — ' + t.toLocaleDateString(undefined, opt) + ' (' + d + ' ' + (d === 1 ? 'day' : 'days') + ')'
    })

    // Spinner keyframes
    const styleTag = document.createElement('style')
    styleTag.textContent = '@keyframes spin { to { transform: rotate(360deg); } }'
    document.head.appendChild(styleTag)
  }
</script>

@endsection
