<script server>
import { cars, getCar } from '../../data/cars'

const id = params?.id || 'tesla-model-3-2024'
const car = getCar(id) || cars[0]
const pageTitle = 'Book your ' + car.make + ' ' + car.model + ' · Drivly'
const activePage = 'search'

const protectionPlans = [
  { id: 'premium',  name: 'Premium',  priceMultiplier: 0.35, deductible: 0, desc: 'Zero-deductible. Roadside included. Full peace of mind.', recommended: true },
  { id: 'standard', name: 'Standard', priceMultiplier: 0.25, deductible: 500, desc: '$500 deductible. Roadside included.' },
  { id: 'minimum',  name: 'Minimum',  priceMultiplier: 0.15, deductible: 3000, desc: '$3,000 deductible. Meets state minimums only.' },
]

const extras = [
  { id: 'childseat', label: 'Child seat', desc: 'Infant or toddler seat', price: 12 },
  { id: 'toll',      label: 'Toll pass',  desc: 'Unlimited toll pass',    price: 18 },
  { id: 'charger',   label: 'EV charger', desc: 'Portable Level 2 charger', price: 15 },
  { id: 'prepaid',   label: 'Prepaid refuel', desc: 'Return with any level', price: 45 },
]

const bookTimes = ['08:00', '09:00', '10:00', '11:00', '12:00', '14:00', '16:00', '18:00']
const usStates = ['CA','NY','TX','FL','WA','IL','CO','AZ','TN']
</script>

@extends('layouts/app.stx')

@push('styles')
  .checkout-layout { display: grid; grid-template-columns: 1fr 420px; gap: 3rem; margin-top: 2rem; align-items: start; }
  @media (max-width: 980px) { .checkout-layout { grid-template-columns: 1fr; } }
  .stepper { display: flex; align-items: center; gap: 0; margin-bottom: 2.5rem; }
  .step { display: flex; align-items: center; gap: 0.625rem; font-size: 0.8125rem; font-weight: 500; color: var(--text-muted); }
  .step-num { width: 28px; height: 28px; border-radius: 50%; background: var(--bg-subtle); color: var(--text-muted); display: inline-flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0; border: 1.5px solid var(--border); transition: all 180ms; }
  .step.active .step-num { background: var(--brand); color: white; border-color: var(--brand); }
  .step.active { color: var(--text); }
  .step.done .step-num { background: var(--text); color: var(--bg); border-color: var(--text); }
  .step-line { flex: 1; height: 1.5px; background: var(--border); margin: 0 0.75rem; min-width: 20px; }
  .step.done + .step-line { background: var(--text); }
  .pay-method { display: flex; align-items: center; gap: 0.75rem; padding: 1rem; border: 1.5px solid var(--border); border-radius: var(--radius); cursor: pointer; transition: all 120ms; }
  .pay-method.selected { border-color: var(--brand); background: var(--brand-soft); }
  .pay-method input { accent-color: var(--brand); }
  .protection-card { padding: 1.25rem; border: 1.5px solid var(--border); border-radius: var(--radius-lg); cursor: pointer; transition: all 120ms; position: relative; }
  .protection-card.selected { border-color: var(--brand); background: var(--brand-soft); }
  .protection-card .recommended-badge { position: absolute; top: -8px; right: 1rem; background: var(--brand); color: white; padding: 0.1875rem 0.625rem; border-radius: 999px; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
@endpush

