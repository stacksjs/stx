<script server>
import { cars } from '../data/cars'

const pageTitle = 'My trips · Drivly'
const activePage = 'trips'

const upcoming = [
  { id: 'DRV-482913', carId: 'tesla-model-3-2024', guest: 'Maya L.', from: '2026-05-14', to: '2026-05-17', total: 432.50, status: 'Confirmed', pickupTime: '10:00 AM' },
  { id: 'DRV-481802', carId: 'jeep-wrangler-2023',  from: '2026-06-02', to: '2026-06-08', total: 946.00, status: 'Awaiting host', pickupTime: '9:00 AM' },
]

const past = [
  { id: 'DRV-478291', carId: 'porsche-911-carrera-2023', from: '2026-02-14', to: '2026-02-16', total: 1210.00, status: 'Completed', rating: 5 },
  { id: 'DRV-471029', carId: 'mazda-miata-2023',         from: '2025-11-03', to: '2025-11-05', total: 285.00, status: 'Completed', rating: 5 },
  { id: 'DRV-468013', carId: 'honda-civic-2024',         from: '2025-09-18', to: '2025-09-22', total: 342.00, status: 'Completed', rating: 4 },
]

// Pre-resolve car metadata so template doesn't use cars.find() (stx can't eval that in @foreach contexts)
const upcomingWithCar = upcoming.map(t => ({ ...t, car: cars.find(c => c.id === t.carId) }))
const pastWithCar = past.map(t => ({ ...t, car: cars.find(c => c.id === t.carId) }))
</script>

@extends('layouts/app.stx')

@section('content')
<div class="max-w-[1280px] mx-auto px-6 py-8 pb-16">

  <div class="flex justify-between items-end flex-wrap gap-4 mb-8">
    <div>
      <h1 class="serif text-4xl sm:text-5xl m-0 mb-1.5">My trips</h1>
      <p class="text-[color:var(--text-muted)] m-0">Your rentals, past and upcoming.</p>
    </div>
    <StxLink to="/search" class="inline-flex items-center gap-2 py-3.5 px-6 rounded-xl text-[0.9375rem] font-semibold text-white bg-[#FF3E54] hover:bg-[#e63349] transition-all hover:-translate-y-px"
             style="box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2)">Book another trip</StxLink>
