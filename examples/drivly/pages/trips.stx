</div>

<script client>
  document.querySelectorAll('.tab-btn-trip').forEach(btn => {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.tab-btn-trip').forEach(b => {
        b.classList.remove('active')
        b.style.color = 'var(--text-muted)'
        b.style.fontWeight = '500'
        b.style.borderBottomColor = 'transparent'
      })
      this.classList.add('active')
      this.style.color = 'var(--text)'
      this.style.fontWeight = '600'
      this.style.borderBottomColor = 'var(--brand)'
      const tab = this.dataset.tab
      document.querySelectorAll('.trip-panel').forEach(p => {
        p.style.display = p.dataset.panel === tab ? (tab === 'cancelled' ? 'block' : 'block') : 'none'
      })
    })
  })
</script>

@endsection
