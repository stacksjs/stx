<!-- @memo: pure static marketing content — memoize so SPA nav doesn't re-render. -->
@memo([])
<section class="py-16">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="text-center max-w-[640px] mx-auto mb-12">
      <span class="inline-flex items-center gap-1.5 py-1.5 px-2.5 rounded-full text-xs font-medium text-[color:var(--text-secondary)] bg-[color:var(--bg-subtle)] border border-[color:var(--border)]">How it works</span>
      <h2 class="serif text-4xl sm:text-5xl m-0 mt-4 mb-2">The simplest way to rent a car</h2>
      <p class="text-[color:var(--text-muted)] text-lg m-0">It takes under 60 seconds. Really.</p>
    </div>

    <div class="grid md:grid-cols-3 grid-cols-1 gap-5">
      @foreach (steps as step)
        <div class="bg-[color:var(--bg-elevated)] border border-[color:var(--border)] rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-5 right-5 text-xs font-bold text-[color:var(--text-faint)] tracking-wider">{{ step.num }}</div>
          <div class="w-14 h-14 rounded-2xl bg-[rgba(255,62,84,0.1)] flex items-center justify-center text-3xl mb-5">{{ step.icon }}</div>
          <h3 class="serif text-2xl m-0 mb-2">{{ step.title }}</h3>
          <p class="text-[color:var(--text-muted)] m-0 leading-relaxed">{{ step.desc }}</p>
        </div>
      @endforeach
    </div>
  </div>
</section>
@endmemo

