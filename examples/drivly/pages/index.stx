         style="background: radial-gradient(circle, rgba(255, 62, 84, 0.18) 0%, transparent 70%)"></div>
    <div class="absolute bottom-[-100px] left-[-80px] w-[400px] h-[400px] rounded-full blur-3xl"
         style="background: radial-gradient(circle, rgba(147, 51, 234, 0.14) 0%, transparent 70%)"></div>
  </div>

  <div class="max-w-[1280px] mx-auto px-6">
