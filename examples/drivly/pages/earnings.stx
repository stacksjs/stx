          <input type="text" value="{{ defaultCar }}" x-model="carName" class="w-full py-3.5 px-4 border border-[color:var(--border)] rounded-xl bg-[color:var(--input-bg)] text-[color:var(--text)] text-base">
        </label>
        <label>
          <span class="block text-xs font-semibold uppercase tracking-wider text-[color:var(--text-muted)] mb-2">Daily rate: $<span :text="price">89</span></span>
          <input type="range" min="25" max="450" value="89" x-model="price" class="w-full accent-[#FF3E54]">
