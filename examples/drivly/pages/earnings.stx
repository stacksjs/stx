          <div class="flex justify-between">
            <span class="text-[color:var(--text-muted)]">Gross bookings</span>
            <span class="tabular font-semibold" :text="grossLabel">$1,068</span>
          </div>
          <div class="flex justify-between">
            <span class="text-[color:var(--text-muted)]">Drivly service fee</span>
            <span class="tabular font-semibold text-[color:var(--text-muted)]" :text="feeLabel">-$160</span>
          </div>
          <div class="flex justify-between pt-3 border-t border-[color:var(--border)]">
