          <div class="flex gap-3 items-center py-2.5"><svg class="w-5 h-5 text-[color:var(--text-muted)] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg><div><p class="m-0 text-xs text-[color:var(--text-muted)] uppercase tracking-wider">Fuel type</p><p class="m-0 mt-0.5 font-medium">{{ car.fuelType }}</p></div></div>
          <div class="flex gap-3 items-center py-2.5"><svg class="w-5 h-5 text-[color:var(--text-muted)] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M8.5 7a4 4 0 1 0 0 8 4 4 0 0 0 0-8zM20 8v6M17 11h6"/></svg><div><p class="m-0 text-xs text-[color:var(--text-muted)] uppercase tracking-wider">Seats</p><p class="m-0 mt-0.5 font-medium">{{ car.seats }} seats</p></div></div>
          <div class="flex gap-3 items-center py-2.5"><svg class="w-5 h-5 text-[color:var(--text-muted)] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M9 3v18M15 3v18"/></svg><div><p class="m-0 text-xs text-[color:var(--text-muted)] uppercase tracking-wider">Doors</p><p class="m-0 mt-0.5 font-medium">{{ car.doors }} doors</p></div></div>
          <div class="flex gap-3 items-center py-2.5"><svg class="w-5 h-5 text-[color:var(--text-muted)] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M14 4h6l-6 6V4zM16 17v5l6-6h-5l-1 1zM3 3l6 6M3 3v6h6M21 21l-6-6M21 21v-6h-6"/></svg><div><p class="m-0 text-xs text-[color:var(--text-muted)] uppercase tracking-wider">MPG / Range</p><p class="m-0 mt-0.5 font-medium">{{ car.mpg }}{{ car.range ? ' · ' + car.range : '' }}</p></div></div>
          <div class="flex gap-3 items-center py-2.5"><svg class="w-5 h-5 text-[color:var(--text-muted)] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 6v6l4 2"/></svg><div><p class="m-0 text-xs text-[color:var(--text-muted)] uppercase tracking-wider">Category</p><p class="m-0 mt-0.5 font-medium">{{ car.category }}</p></div></div>
