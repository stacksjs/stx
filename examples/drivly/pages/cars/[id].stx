<script server>
import { cars, getCar } from '../../data/cars'

const id = params?.id || 'tesla-model-3-2024'
const car = getCar(id) || cars[0]
const pageTitle = car.year + ' ' + car.make + ' ' + car.model + ' · Drivly'
const pageDescription = car.description.slice(0, 160)
const activePage = 'search'

const similar = cars.filter(c => c.id !== car.id && c.category === car.category).slice(0, 4)
if (similar.length < 4) {
  for (const c of cars) {
    if (similar.length >= 4) break
    if (c.id !== car.id && !similar.find(s => s.id === c.id)) similar.push(c)
  }
}

const ratingPct = {
  cleanliness: 4.9,
  maintenance: 4.95,
  communication: 4.92,
  convenience: 4.88,
  accuracy: 4.94,
}

const defaultFrom = new Date()
defaultFrom.setDate(defaultFrom.getDate() + 3)
const defaultTo = new Date()
defaultTo.setDate(defaultTo.getDate() + 6)
const fmtDate = d => d.toISOString().slice(0, 10)

const tripRules = [
  'No smoking — $250 cleaning fee if violated',
  'Pets welcome with advance notice',
  'Off-road driving requires approval',
  'Return with same fuel/charge level',
  'Max 200 miles/day (extra miles: $0.40/mi)',
  'Valid driver\'s license required',
]

const pickupTimes = ['08:00', '09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00']
const ratingMetricEntries = Object.entries(ratingPct)
const galleryItems = car.gallery.filter((_, i) => i < 5)
</script>

@extends('layouts/app.stx')

@push('styles')
  .gallery-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 0.5rem; aspect-ratio: 16/9; border-radius: var(--radius-xl); overflow: hidden; }
  .gallery-grid > *:nth-child(1) { grid-row: span 2; }
  .gallery-grid .gallery-cell { width: 100%; height: 100%; cursor: pointer; overflow: hidden; }
  .gallery-grid img { width: 100%; height: 100%; object-fit: cover; transition: opacity 180ms, transform 400ms; }
  .gallery-grid .gallery-cell:hover img { opacity: 0.9; transform: scale(1.04); }
  @media (max-width: 720px) { .gallery-grid { grid-template-columns: 1fr; grid-template-rows: auto; aspect-ratio: auto; } .gallery-grid > * { aspect-ratio: 16/10; } .gallery-grid > *:nth-child(1) { grid-row: auto; } .gallery-grid > *:nth-child(n+4) { display: none; } }
  .detail-layout { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; margin-top: 2.5rem; align-items: start; }
  @media (max-width: 980px) { .detail-layout { grid-template-columns: 1fr; } .book-sidebar { position: sticky; bottom: 0; top: auto !important; z-index: 40; } }
  .book-sidebar { position: sticky; top: 96px; }
  .rating-bar { position: relative; height: 6px; background: var(--bg-muted); border-radius: 3px; overflow: hidden; }
  .rating-bar-fill { position: absolute; inset: 0; background: var(--text); border-radius: 3px; }
  .spec-item { display: flex; gap: 0.75rem; align-items: center; padding: 0.625rem 0; }
  .spec-item svg { color: var(--text-muted); flex-shrink: 0; }
  .tab-list { display: flex; border-bottom: 1px solid var(--border); gap: 0.25rem; margin-bottom: 1.75rem; }
  .tab-btn { padding: 0.875rem 1rem; border: none; background: transparent; color: var(--text-muted); font-size: 0.9375rem; font-weight: 500; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; font-family: inherit; }
  .tab-btn.active { color: var(--text); border-bottom-color: var(--brand); font-weight: 600; }
  .lightbox { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.92); display: none; align-items: center; justify-content: center; padding: 2rem; }
  .lightbox.open { display: flex; }
  .lightbox img { max-width: 100%; max-height: 100%; }
  .lightbox-close { position: absolute; top: 1.5rem; right: 1.5rem; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); border: none; color: white; font-size: 1.5rem; cursor: pointer; }
@endpush

