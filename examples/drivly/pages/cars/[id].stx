        </a>

        <p class="muted" style="text-align: center; margin: 0.75rem 0 0; font-size: 0.8125rem">You won't be charged yet</p>
      </div>

      <!-- Trust card -->
      <div class="card" style="padding: 1.25rem; margin-top: 1rem; display: flex; gap: 0.75rem">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.75" style="flex-shrink: 0"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div>
          <p style="margin: 0; font-weight: 600; font-size: 0.9375rem">Every trip is protected</p>
          <p class="muted" style="margin: 0.25rem 0 0; font-size: 0.8125rem; line-height: 1.5">Liability insurance up to $750K. 24/7 customer support. Free cancellation up to 24 hours.</p>
        </div>
      </div>
    </aside>
  </div>

  <!-- Similar cars -->
  <section style="margin-top: 4rem">
    <h2 class="serif" style="font-size: 1.875rem; margin: 0 0 1.5rem">You might also like</h2>
    <div class="grid grid-4">
      @foreach (similar as sc)
        @component('CarCard', { car: sc })
        @endcomponent
      @endforeach
    </div>
  </section>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <button class="lightbox-close" onclick="closeLightbox()">×</button>
  <img id="lightboxImg" src="" alt="">
</div>

<script client>
  if (!window.__carDetailPage) {
    window.__carDetailPage = true

    const PRICE = {{ car.price }}
    const CAR_ID = {{ car.id }}
    const GALLERY = {{ car.gallery }}

    const favorites = useStore('favorites')

    // ── Favorite toggle ──
    const favBtn = document.querySelector('.detail-fav-btn')
    const favIcon = document.querySelector('.fav-icon-detail')
    const favLabel = document.querySelector('.fav-label-detail')
    function syncFav() {
      const on = favorites.has(CAR_ID)
      if (on) { favIcon.setAttribute('fill', '#FF3E54'); favIcon.style.stroke = '#FF3E54'; favLabel.textContent = 'Saved' }
      else { favIcon.setAttribute('fill', 'none'); favIcon.style.stroke = 'currentColor'; favLabel.textContent = 'Save' }
    }
    syncFav()
    favBtn.addEventListener('click', function () {
      favorites.toggle(CAR_ID)
      syncFav()
      window._toast && window._toast(favorites.has(CAR_ID) ? 'Saved to favorites' : 'Removed from favorites', 'success')
    })

    // ── Share ──
    document.getElementById('shareBtn').addEventListener('click', function () {
      const url = location.href
      if (navigator.share) navigator.share({ url, title: document.title }).catch(() => {})
      else { navigator.clipboard && navigator.clipboard.writeText(url); window._toast('Link copied', 'success') }
    })

    // ── Tabs ──
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
        this.classList.add('active')
        const target = this.dataset.tab
        document.querySelectorAll('.tab-panel').forEach(p => {
          p.style.display = p.dataset.panel === target ? 'block' : 'none'
        })
      })
    })

    // ── Price breakdown (reactive) ──
    const fromDate = state(document.getElementById('fromDate').value)
    const toDate = state(document.getElementById('toDate').value)

    document.getElementById('fromDate').addEventListener('change', function () { fromDate.set(this.value) })
    document.getElementById('toDate').addEventListener('change', function () { toDate.set(this.value) })

    const days = derived(() => {
      const f = new Date(fromDate()); const t = new Date(toDate())
      const ms = Math.max(0, t - f)
      return Math.max(1, Math.ceil(ms / (24 * 3600 * 1000)))
    })

    effect(() => {
      const d = days()
      const sub = PRICE * d
      const fee = sub * 0.1
      const protection = sub * 0.15
      const total = sub + fee + protection
      document.getElementById('pbDays').textContent = d
      document.getElementById('pbSubtotal').textContent = '$' + sub.toFixed(2)
      document.getElementById('pbFee').textContent = '$' + fee.toFixed(2)
      document.getElementById('pbProtection').textContent = '$' + protection.toFixed(2)
      document.getElementById('pbTotal').textContent = '$' + total.toFixed(2)
      // Sync to URL-state for booking page
      const btn = document.getElementById('continueBtn')
      btn.setAttribute('href', '/book/' + CAR_ID + '?from=' + fromDate() + '&to=' + toDate() + '&ft=' + document.getElementById('fromTime').value + '&tt=' + document.getElementById('toTime').value)
    })

    document.getElementById('fromTime').addEventListener('change', () => fromDate.set(fromDate()))
    document.getElementById('toTime').addEventListener('change', () => toDate.set(toDate()))

    // ── Lightbox ──
    window.openLightbox = function (idx) {
      document.getElementById('lightboxImg').src = GALLERY[idx]
      document.getElementById('lightbox').classList.add('open')
      document.body.style.overflow = 'hidden'
    }
    window.closeLightbox = function () {
      document.getElementById('lightbox').classList.remove('open')
      document.body.style.overflow = ''
    }
    document.getElementById('lightbox').addEventListener('click', function (e) {
      if (e.target === this) closeLightbox()
    })
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeLightbox()
    })
  }
</script>

@endsection
