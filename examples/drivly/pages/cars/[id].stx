          @if (car.instantBook)
            <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[0.6875rem] font-medium text-[#10B981] bg-[rgba(16,185,129,0.12)] border border-[rgba(16,185,129,0.25)]">⚡ Instant</span>
          @endif
        </div>

        <!-- Dates bind to fromDate/toDate signals via x-model -->
        <div class="grid grid-cols-2 border border-[color:var(--border)] rounded-xl overflow-hidden mb-2">
          <label class="p-3 border-r border-[color:var(--border)] cursor-pointer block">
            <span class="text-[0.6875rem] font-semibold uppercase tracking-wider text-[color:var(--text-muted)] block">Trip start</span>
            <input type="date" x-model="fromDate" class="border-0 bg-transparent outline-0 text-[color:var(--text)] text-sm w-full py-0.5">
          </label>
          <label class="p-3 cursor-pointer block">
            <span class="text-[0.6875rem] font-semibold uppercase tracking-wider text-[color:var(--text-muted)] block">Trip end</span>
            <input type="date" x-model="toDate" class="border-0 bg-transparent outline-0 text-[color:var(--text)] text-sm w-full py-0.5">
