             loading="{{ idx === 0 ? 'eager' : 'lazy' }}" decoding="async"
             fetchpriority="{{ idx === 0 ? 'high' : 'auto' }}">
      </div>
    @endforeach
  </div>

  <div class="grid md:grid-cols-[1fr_380px] grid-cols-1 gap-12 mt-10 items-start">

    <!-- Left column -->
    <div>
      <!-- Host strip -->
      <section class="bg-[color:var(--bg-elevated)] border border-[color:var(--border)] rounded-2xl p-6 flex items-center justify-between gap-4 flex-wrap">
