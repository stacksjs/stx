          </div>
        </div>
        <button class="py-2 px-3.5 rounded-xl text-[0.8125rem] font-semibold bg-[color:var(--bg-subtle)] border border-[color:var(--border)] text-[color:var(--text)] hover:bg-[color:var(--bg-muted)] transition-colors"
