    <!-- Booking sidebar -->
    <aside class="book-sidebar">
      <div class="bg-[color:var(--bg-elevated)] border border-[color:var(--border)] rounded-2xl p-6" style="box-shadow: 0 24px 48px -12px rgba(0,0,0,0.18)">
