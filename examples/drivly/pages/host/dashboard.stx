        <p class="tabular" style="margin: 0.625rem 0 0.25rem; font-size: 1.75rem; font-weight: 700">{{ kpi.value }}</p>
        <span class="chip chip-accent" style="font-size: 0.6875rem">↑ {{ kpi.delta }}</span>
