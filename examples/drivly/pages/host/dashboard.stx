            <stop offset="100%" stop-color="#FF3E54" stop-opacity="0"/>
          </linearGradient>
        </defs>
        @foreach (gridLines as y)
          <line x1="40" y1="{{ y }}" x2="590" y2="{{ y }}" stroke="var(--border)" stroke-dasharray="2 4"/>
        @endforeach
        <polygon points="{{ areaPointsStr }}" fill="url(#earnGrad)"/>
        <polyline points="{{ chartPointsStr }}" fill="none" stroke="#FF3E54" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        @foreach (chartDots as dot)
          <circle cx="{{ dot.cx }}" cy="{{ dot.cy }}" r="3.5" fill="white" stroke="#FF3E54" stroke-width="2"/>
          <text x="{{ dot.cx }}" y="205" text-anchor="middle" font-size="10" fill="var(--text-muted)" font-family="Inter, sans-serif">{{ dot.label }}</text>
        @endforeach
      </svg>
    </div>

    <div class="card" style="padding: 1.5rem">
      <h2 style="font-size: 1.125rem; font-weight: 700; margin: 0 0 1rem">Performance mix</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem">
        @foreach (perfMix as item)
          <div>
            <div style="display: flex; justify-content: space-between; font-size: 0.8125rem; margin-bottom: 0.375rem">
              <span style="color: var(--text-secondary)">{{ item.label }}</span>
              <span class="tabular" style="font-weight: 600">{{ item.pct }}%</span>
            </div>
            <div style="height: 6px; background: var(--bg-muted); border-radius: 3px; overflow: hidden">
              <div style="height: 100%; width: {{ item.pct }}%; background: {{ item.color }}"></div>
