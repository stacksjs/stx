<script server>
import { cars } from '../../data/cars'

const pageTitle = 'Host dashboard · Drivly'
const activePage = 'host-dashboard'

definePageMeta({ middleware: ['auth'] })
useSeoMeta({ title: pageTitle, robots: 'noindex' })

// Pretend the current host owns these cars
const myListings = cars.slice(0, 3)

const kpis = [
  { label: 'Earnings this month',   value: '$4,812',  delta: '+12.4%', trend: 'up' },
  { label: 'Trips completed',       value: '28',      delta: '+6',     trend: 'up' },
  { label: 'Average trip value',    value: '$172',    delta: '+$8',    trend: 'up' },
  { label: 'Avg rating',            value: '4.93 ★',  delta: '+0.02',  trend: 'up' },
]

const upcomingBookings = [
  { id: 'DRV-482913', carId: 'tesla-model-3-2024', guest: 'Maya L.',    from: '2026-05-14', to: '2026-05-17', payout: 389.25, status: 'Confirmed' },
  { id: 'DRV-481810', carId: 'porsche-911-carrera-2023', guest: 'Ethan B.', from: '2026-05-20', to: '2026-05-22', payout: 700.20, status: 'Awaiting approval' },
  { id: 'DRV-479922', carId: 'jeep-wrangler-2023', guest: 'Rachel K.', from: '2026-05-25', to: '2026-05-27', payout: 237.60, status: 'Confirmed' },
].map(b => {
  const c = cars.find(x => x.id === b.carId)
  return { ...b, carImage: c?.image, carLabel: c ? (c.year + ' ' + c.make + ' ' + c.model) : b.carId }
})

const messages = [
  { guest: 'Maya L.',    avatar: 'ML', preview: 'Hi — is the charger still in the trunk for pickup tomorrow?', time: '12m', unread: true },
  { guest: 'Ethan B.',   avatar: 'EB', preview: 'Confirmed for the 20th. Can I get early pickup at 8am?',      time: '2h',  unread: true },
  { guest: 'Rachel K.',  avatar: 'RK', preview: 'Thanks for everything — 5 stars on the way!',                  time: '1d',  unread: false },
  { guest: 'Darren S.',  avatar: 'DS', preview: 'Is the car pet-friendly? Traveling with a golden retriever',   time: '2d',  unread: false },
]

const recentReviews = [
  { car: '2024 Tesla Model 3', guest: 'Maya L.', rating: 5, body: 'Flawless experience. Super clean, delivery was on time.', date: '2026-03-14' },
  { car: '2023 Porsche 911',   guest: 'Ethan B.', rating: 5, body: 'Dream car. Owner was lovely, will rent again.',           date: '2026-03-02' },
]

// Earnings chart — 12 months
const earnings = [2840, 3120, 3480, 3920, 4100, 4280, 4650, 4420, 4810, 5020, 4890, 4812]
const labels = ['Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar']
const maxE = Math.max(...earnings)
const totalE = earnings.reduce((a, b) => a + b, 0)
const gap = (600 - 50) / (earnings.length - 1)
const chartPoints = earnings.map((v, i) => {
  const x = 40 + i * gap
  const y = 180 - (v / maxE) * 160
  return x + ',' + y
})
const chartPointsStr = chartPoints.join(' ')
const areaPointsStr = '40,180 ' + chartPointsStr + ' ' + (40 + (earnings.length - 1) * gap) + ',180'
const chartDots = earnings.map((v, i) => ({
  cx: 40 + i * gap,
  cy: 180 - (v / maxE) * 160,
  label: labels[i],
}))
const gridLines = [0, 25, 50, 75, 100].map(g => 20 + g * 1.6)
const perfMix = [
  { label: 'Model 3',      pct: 48, color: '#FF3E54' },
  { label: '911 Carrera',  pct: 32, color: '#9333ea' },
  { label: 'Wrangler 4xe', pct: 20, color: '#10b981' },
]
</script>

@extends('layouts/app.stx')

@section('content')
