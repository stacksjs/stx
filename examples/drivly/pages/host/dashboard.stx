          </tr>
        </thead>
        <tbody>
          @foreach (upcomingBookings as b)
            <tr class="border-b border-[color:var(--border)]">
              <td class="py-3.5 px-3">
                <div class="flex items-center gap-3">
                  <img src="{{ b.carImage }}" alt="{{ b.carLabel }}" class="w-12 h-8 object-cover rounded-md">
                  <div>
                    <p class="m-0 font-medium">{{ b.carLabel }}</p>
                    <p class="text-[color:var(--text-muted)] m-0 mt-0.5 text-xs">#{{ b.id }}</p>
                  </div>
                </div>
              </td>
              <td class="py-3.5 px-3">{{ b.guest }}</td>
              <td class="py-3.5 px-3 tabular">{{ b.from }} → {{ b.to }}</td>
              <td class="py-3.5 px-3 text-right tabular">${{ b.payout.toFixed(2) }}</td>
              <td class="py-3.5 px-3 text-right">
                @if (b.status === 'Confirmed')
                  <span class="inline-flex items-center py-0.5 px-2 rounded-full text-[0.6875rem] font-medium text-emerald-500 bg-emerald-500/10 border border-emerald-500/25">{{ b.status }}</span>
                @else
                  <span class="inline-flex items-center py-0.5 px-2 rounded-full text-[0.6875rem] font-medium text-amber-500 bg-amber-500/10 border border-amber-500/25">{{ b.status }}</span>
                @endif
