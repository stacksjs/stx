      <div class="bg-[color:var(--bg-elevated)] border border-[color:var(--border)] rounded-2xl p-5">
        <p class="text-[color:var(--text-muted)] m-0 text-xs font-semibold uppercase tracking-wider">{{ kpi.label }}</p>
        <p class="tabular m-0 mt-2.5 mb-1 text-3xl font-bold">{{ kpi.value }}</p>
        <span class="inline-flex items-center gap-1 py-0.5 px-2 rounded-full text-[0.6875rem] font-medium text-emerald-500 bg-emerald-500/10 border border-emerald-500/25">↑ {{ kpi.delta }}</span>
      </div>
    @endforeach
  </div>

  <!-- Charts + bookings -->
  <div class="grid md:grid-cols-[2fr_1fr] grid-cols-1 gap-6 mb-8">
    <div class="bg-[color:var(--bg-elevated)] border border-[color:var(--border)] rounded-2xl p-6">
      <div class="flex justify-between items-center mb-5">
        <div>
          <h2 class="text-lg font-bold m-0">Earnings over time</h2>
          <p class="text-[color:var(--text-muted)] m-0 mt-1 text-sm">Last 12 months · Total <span class="tabular text-[color:var(--text)] font-semibold">${{ totalE.toLocaleString() }}</span></p>
        </div>
      </div>
      <svg viewBox="0 0 600 220" class="w-full h-[220px]">
        <defs>
          <linearGradient id="earnGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#FF3E54" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#FF3E54" stop-opacity="0"/>
          </linearGradient>
        </defs>
        @foreach (gridLines as y)
          <line x1="40" y1="{{ y }}" x2="590" y2="{{ y }}" stroke="var(--border)" stroke-dasharray="2 4"/>
        @endforeach
        <polygon points="{{ areaPointsStr }}" fill="url(#earnGrad)"/>
        <polyline points="{{ chartPointsStr }}" fill="none" stroke="#FF3E54" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        @foreach (chartDots as dot)
          <circle cx="{{ dot.cx }}" cy="{{ dot.cy }}" r="3.5" fill="white" stroke="#FF3E54" stroke-width="2"/>
          <text x="{{ dot.cx }}" y="205" text-anchor="middle" font-size="10" fill="var(--text-muted)" font-family="Inter, sans-serif">{{ dot.label }}</text>
        @endforeach
      </svg>
    </div>

    <div class="bg-[color:var(--bg-elevated)] border border-[color:var(--border)] rounded-2xl p-6">
      <h2 class="text-lg font-bold m-0 mb-4">Performance mix</h2>
      <div class="flex flex-col gap-4">
        @foreach (perfMix as item)
          <div>
            <div class="flex justify-between text-[0.8125rem] mb-1.5">
              <span class="text-[color:var(--text-secondary)]">{{ item.label }}</span>
              <span class="tabular font-semibold">{{ item.pct }}%</span>
            </div>
            <div class="h-1.5 bg-[color:var(--bg-muted)] rounded-full overflow-hidden">
              <div class="h-full rounded-full" style="width: {{ item.pct }}%; background: {{ item.color }}"></div>
            </div>
          </div>
        @endforeach
      </div>
      <div class="mt-6 pt-4 border-t border-[color:var(--border)] text-sm">
        <p class="text-[color:var(--text-muted)] m-0 mb-1 text-xs uppercase tracking-wider font-semibold">Next payout</p>
        <p class="tabular m-0 text-2xl font-bold">$1,327.55</p>
        <p class="text-[color:var(--text-muted)] m-0 mt-1 text-xs">Expected May 1, 2026</p>
      </div>
    </div>
  </div>

  <!-- Upcoming bookings -->
  <div class="bg-[color:var(--bg-elevated)] border border-[color:var(--border)] rounded-2xl p-6 mb-8">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-bold m-0">Upcoming bookings</h2>
      <a href="#" class="text-[0.8125rem] text-[#FF3E54] font-semibold">View all</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="border-b border-[color:var(--border)]">
            <th class="text-left py-2.5 px-3 font-semibold text-[color:var(--text-muted)] text-xs uppercase tracking-wider">Car</th>
            <th class="text-left py-2.5 px-3 font-semibold text-[color:var(--text-muted)] text-xs uppercase tracking-wider">Guest</th>
            <th class="text-left py-2.5 px-3 font-semibold text-[color:var(--text-muted)] text-xs uppercase tracking-wider">Dates</th>
