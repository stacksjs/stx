  </div>

  <!-- Charts + bookings -->
  <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem; margin-bottom: 2rem">
    <div class="card" style="padding: 1.5rem">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem">
        <div>
          <h2 style="font-size: 1.125rem; font-weight: 700; margin: 0">Earnings over time</h2>
          <p class="muted" style="margin: 0.25rem 0 0; font-size: 0.875rem">Last 12 months · Total <span class="tabular" style="color: var(--text); font-weight: 600">${{ totalE.toLocaleString() }}</span></p>
        </div>
      </div>
      <svg viewBox="0 0 600 220" style="width: 100%; height: 220px">
        <defs>
          <linearGradient id="earnGrad" x1="0" y1="0" x2="0" y2="1">
