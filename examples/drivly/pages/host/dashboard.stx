    </div>
    <div style="overflow-x: auto">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem">
        <thead>
          <tr style="border-bottom: 1px solid var(--border)">
            <th style="text-align: left; padding: 0.625rem 0.75rem; font-weight: 600; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em">Car</th>
            <th style="text-align: left; padding: 0.625rem 0.75rem; font-weight: 600; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em">Guest</th>
