<script client>
  if (!window.__listWiz) {
    window.__listWiz = true

    const step = state(1)
    const price = state(89)

    const titles = {
      1: 'Tell us about your car',
      2: 'Add photos',
      3: 'Set your pricing',
      4: 'Availability & rules',
      5: 'Almost there!',
    }

    effect(() => {
      const n = step()
      document.getElementById('wizStep').textContent = n
      document.getElementById('wizTitle').textContent = titles[n]
      document.getElementById('wizProgress').style.width = (n * 20) + '%'
      document.querySelectorAll('.wiz-panel').forEach(p => {
        p.style.display = Number(p.dataset.panel) === n ? 'block' : 'none'
      })
    })

    document.querySelectorAll('.wiz-next').forEach(b => {
      b.addEventListener('click', function () {
        const next = Number(this.dataset.to)
        // Validate step 1
        if (next === 2) {
          const make = document.getElementById('wMake').value
          const model = document.getElementById('wModel').value
          const vin = document.getElementById('wVin').value
          if (!make || !model || vin.length < 11) {
            window._toast && window._toast('Fill in make, model, and VIN', 'error')
            return
          }
        }
        step.set(next)
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })
    })
    document.querySelectorAll('.wiz-back').forEach(b => {
      b.addEventListener('click', function () { step.set(Number(this.dataset.to)) })
    })

    // Pricing reactive
    document.getElementById('wPrice').addEventListener('input', function () {
      price.set(Number(this.value) || 0)
    })
    effect(() => {
      const p = price()
      const gross = p * 12
      const fee = gross * 0.15
      const net = gross - fee
      document.getElementById('projGross').textContent = '$' + gross.toLocaleString()
      document.getElementById('projFee').textContent = '-$' + fee.toLocaleString()
      document.getElementById('projNet').textContent = '$' + net.toLocaleString()
      document.getElementById('estAmount').textContent = '$' + Math.round(net).toLocaleString()
    })

    // Day chip toggles
    document.querySelectorAll('.day-chip').forEach(l => {
      const cb = l.querySelector('input')
      function sync() {
        if (cb.checked) { l.style.background = 'var(--text)'; l.style.color = 'var(--bg)'; l.style.borderColor = 'var(--text)' }
        else { l.style.background = ''; l.style.color = ''; l.style.borderColor = 'var(--border)' }
      }
      sync()
      l.addEventListener('click', function () { cb.checked = !cb.checked; sync() })
    })

    // Photo slot feedback
    document.querySelectorAll('.photo-slot input[type="file"]').forEach(input => {
      input.addEventListener('change', function (e) {
        const f = e.target.files && e.target.files[0]
        if (!f) return
        const label = this.parentElement
        label.style.borderStyle = 'solid'
        label.style.borderColor = 'var(--brand)'
        label.innerHTML = ''
        label.style.padding = '0'
        const img = document.createElement('img')
        img.style.cssText = 'width: 100%; height: 100%; object-fit: cover; border-radius: inherit'
        img.src = URL.createObjectURL(f)
        label.appendChild(img)
      })
    })

    document.getElementById('submitWiz').addEventListener('click', function () {
      this.disabled = true
      this.innerHTML = '<span style="display:inline-block; width: 16px; height: 16px; border: 2px solid white; border-top-color: transparent; border-radius: 50%; animation: spin 0.7s linear infinite"></span> Publishing...'
      setTimeout(() => {
        window._toast && window._toast('Listing submitted! We\'ll review within 24h.', 'success')
        try { window.navigate && window.navigate('/host/dashboard') } catch (e) { location.href = '/host/dashboard' }
      }, 1400)
    })

    const style = document.createElement('style')
    style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }'
    document.head.appendChild(style)
  }
</script>

@endsection
