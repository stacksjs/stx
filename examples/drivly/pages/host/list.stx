<script server>
const pageTitle = 'List your car · Drivly'
const activePage = 'become-host'

const benefits = [
  { icon: '💰', title: 'Earn on your schedule', desc: 'Hosts average $10,516/year. Rent your car 2 days/week and cover payment + insurance.' },
  { icon: '🛡️', title: 'Protection included', desc: 'Up to $750K in liability coverage. Physical damage up to the cash value of your car.' },
  { icon: '🚘', title: 'You control everything', desc: 'Set the price, availability, rules. Reject trips that don\'t feel right. You own the experience.' },
  { icon: '✨', title: 'Free to list', desc: 'Zero setup fees. Drivly takes a small cut only when you earn. Keep 75–85% of every trip.' },
]

const commonMakes = ['Tesla', 'Toyota', 'Honda', 'Ford', 'Chevrolet', 'BMW', 'Mercedes-Benz', 'Jeep', 'Mazda', 'Subaru', 'Audi', 'Porsche', 'Lexus', 'Volvo']
const years = Array.from({ length: 30 }, (_, i) => 2026 - i)
const photoSlots = Array.from({ length: 6 }, (_, i) => i)
const earliestTimes = ['6:00 AM', '7:00 AM', '8:00 AM', '9:00 AM', '10:00 AM']
const daysOfWeek = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']
</script>

