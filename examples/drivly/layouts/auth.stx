<!DOCTYPE html>
<html lang="en">
<head>
  <script>try{var t=localStorage.getItem('drivly-theme');if(t)document.documentElement.setAttribute('data-theme',t);else if(!window.matchMedia('(prefers-color-scheme:light)').matches)document.documentElement.setAttribute('data-theme','dark');else document.documentElement.setAttribute('data-theme','light')}catch(e){document.documentElement.setAttribute('data-theme','light')}</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle || 'Drivly' }}</title>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --brand: #FF3E54; --brand-hover: #e63349; --brand-soft: rgba(255, 62, 84, 0.1);
    }
    [data-theme="light"] {
      --bg: #ffffff; --bg-subtle: #f7f7f8; --bg-muted: #f0f0f2;
      --text: #0a0a0a; --text-secondary: #3f3f46; --text-muted: #71717a;
      --border: rgba(0,0,0,0.08); --border-strong: rgba(0,0,0,0.14);
      --input-bg: #ffffff;
    }
    [data-theme="dark"] {
      --bg: #0b0b0d; --bg-subtle: #17171b; --bg-muted: #1f1f24;
      --text: #fafafa; --text-secondary: #d4d4d8; --text-muted: #a1a1aa;
      --border: rgba(255,255,255,0.08); --border-strong: rgba(255,255,255,0.14);
      --input-bg: #17171b;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: 'Inter', system-ui, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
    .serif { font-family: 'Instrument Serif', serif; font-weight: 400; letter-spacing: -0.02em; }
    .auth-shell { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; }
    @media (max-width: 900px) { .auth-shell { grid-template-columns: 1fr; } .auth-art { display: none !important; } }
    .auth-form-wrap { display: flex; flex-direction: column; padding: 2rem; }
    .auth-form-inner { margin: auto; width: 100%; max-width: 420px; }
    .logo { display: flex; align-items: center; gap: 0.5rem; font-weight: 800; font-size: 1.375rem; letter-spacing: -0.03em; color: var(--brand); }
    .auth-art { position: relative; background: linear-gradient(135deg, #FF3E54 0%, #9333ea 100%); overflow: hidden; }
    .auth-art::before { content: ''; position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=1600&q=70'); background-size: cover; background-position: center; opacity: 0.5; mix-blend-mode: luminosity; }
    .auth-art-inner { position: relative; height: 100%; padding: 3rem; color: white; display: flex; flex-direction: column; justify-content: flex-end; }
    .input { width: 100%; padding: 0.8125rem 1rem; border: 1px solid var(--border); border-radius: 0.625rem; background: var(--input-bg); color: var(--text); font-size: 0.9375rem; font-family: inherit; }
    .input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-soft); }
    .label { font-size: 0.8125rem; font-weight: 500; margin-bottom: 0.375rem; display: block; }
    .btn-primary { width: 100%; padding: 0.875rem 1.25rem; border-radius: 0.625rem; background: var(--brand); color: white; font-weight: 600; border: none; cursor: pointer; font-size: 0.9375rem; transition: background 120ms; font-family: inherit; }
    .btn-primary:hover { background: var(--brand-hover); }
    .btn-social { display: inline-flex; width: 100%; align-items: center; justify-content: center; gap: 0.625rem; padding: 0.75rem 1.25rem; border-radius: 0.625rem; background: var(--bg-subtle); border: 1px solid var(--border); color: var(--text); font-weight: 500; font-size: 0.9375rem; cursor: pointer; font-family: inherit; }
    .btn-social:hover { background: var(--bg-muted); }
  </style>
</head>
<body>
  <div class="auth-shell">
    <div class="auth-form-wrap">
      <StxLink to="/" class="logo">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
          <rect x="2" y="10" width="28" height="14" rx="4" fill="currentColor"/>
          <rect x="6" y="6" width="20" height="8" rx="3" fill="currentColor" opacity="0.6"/>
          <circle cx="9" cy="24" r="3" fill="var(--bg)"/>
          <circle cx="23" cy="24" r="3" fill="var(--bg)"/>
        </svg>
        drivly
      </StxLink>
      <div class="auth-form-inner">
        @yield('content')
      </div>
      <p style="text-align:center; color: var(--text-muted); font-size:0.8125rem; margin-top: 2rem">
        © 2026 Drivly, Inc. · <a href="/about">Terms</a> · <a href="/about">Privacy</a>
      </p>
    </div>
    <div class="auth-art">
      <div class="auth-art-inner">
        <p style="font-size: 0.875rem; letter-spacing:0.1em; text-transform:uppercase; opacity:0.9; margin:0 0 1rem">Drivly drivers</p>
        <h2 class="serif" style="font-size:3rem; line-height:1.05; margin:0">Find your next drive.<br/>Or earn from yours.</h2>
        <p style="opacity:0.9; max-width: 480px; margin-top: 1rem">Join 14M+ travelers who skip the counter, and 350,000+ hosts earning an average of $10,516 per year.</p>
      </div>
    </div>
  </div>
</body>
</html>
