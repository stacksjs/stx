<!DOCTYPE html>
<html lang="en">
<head>
  <script>try{var t=localStorage.getItem('drivly-theme');if(t)document.documentElement.setAttribute('data-theme',t);else if(!window.matchMedia('(prefers-color-scheme:light)').matches)document.documentElement.setAttribute('data-theme','dark');else document.documentElement.setAttribute('data-theme','light')}catch(e){document.documentElement.setAttribute('data-theme','light')}</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <title>{{ pageTitle || 'Drivly — Rent the perfect car, from real people' }}</title>
  <meta name="description" content="{{ pageDescription || 'Skip the rental counter. Book unique cars from trusted hosts across 10,000+ cities.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --brand: #FF3E54;
      --brand-hover: #e63349;
      --brand-soft: rgba(255, 62, 84, 0.1);
      --brand-border: rgba(255, 62, 84, 0.25);
      --accent: #10B981;
      --warning: #F59E0B;
      --radius-sm: 0.5rem;
      --radius: 0.75rem;
      --radius-lg: 1rem;
      --radius-xl: 1.5rem;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
      --shadow: 0 4px 16px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
      --shadow-lg: 0 24px 48px -12px rgba(0,0,0,0.18);
      --transition-fast: 120ms cubic-bezier(0.16, 1, 0.3, 1);
      --transition: 220ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    [data-theme="light"] {
      --bg: #ffffff;
      --bg-elevated: #ffffff;
      --bg-subtle: #f7f7f8;
      --bg-muted: #f0f0f2;
      --bg-hover: rgba(0,0,0,0.04);
      --text: #0a0a0a;
      --text-secondary: #3f3f46;
      --text-muted: #71717a;
      --text-faint: #a1a1aa;
      --border: rgba(0,0,0,0.08);
      --border-strong: rgba(0,0,0,0.14);
      --input-bg: #ffffff;
      --nav-bg: rgba(255,255,255,0.8);
      --skeleton: linear-gradient(90deg, #f0f0f2 0%, #e4e4e7 50%, #f0f0f2 100%);
    }

    [data-theme="dark"] {
      --bg: #0b0b0d;
      --bg-elevated: #141418;
      --bg-subtle: #17171b;
      --bg-muted: #1f1f24;
      --bg-hover: rgba(255,255,255,0.05);
      --text: #fafafa;
      --text-secondary: #d4d4d8;
      --text-muted: #a1a1aa;
      --text-faint: #71717a;
      --border: rgba(255,255,255,0.08);
      --border-strong: rgba(255,255,255,0.14);
      --input-bg: #17171b;
      --nav-bg: rgba(11,11,13,0.75);
      --skeleton: linear-gradient(90deg, #1f1f24 0%, #2a2a30 50%, #1f1f24 100%);
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0; padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      font-feature-settings: 'ss01', 'cv11';
      scroll-behavior: smooth;
    }

    body {
      min-height: 100vh;
    }

    .serif { font-family: 'Instrument Serif', Georgia, serif; font-weight: 400; letter-spacing: -0.02em; }
    .tabular { font-variant-numeric: tabular-nums; }

    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; }

    /* ── Layout utilities ── */
    .container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
    @media (max-width: 640px) { .container { padding: 0 1rem; } }

    /* ── Buttons ── */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border-radius: var(--radius); font-size: 0.875rem; font-weight: 600; transition: all var(--transition-fast); border: none; white-space: nowrap; }
    .btn-primary { background: var(--brand); color: white; box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 4px 16px rgba(255,62,84,0.2); }
    .btn-primary:hover { background: var(--brand-hover); transform: translateY(-1px); box-shadow: 0 1px 0 rgba(0,0,0,0.08), 0 6px 20px rgba(255,62,84,0.28); }
    .btn-secondary { background: var(--bg-subtle); color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { background: var(--bg-muted); border-color: var(--border-strong); }
    .btn-ghost { background: transparent; color: var(--text); }
    .btn-ghost:hover { background: var(--bg-hover); }
    .btn-outline { background: transparent; color: var(--text); border: 1px solid var(--border-strong); }
    .btn-outline:hover { background: var(--bg-subtle); }
    .btn-sm { padding: 0.5rem 0.875rem; font-size: 0.8125rem; }
    .btn-lg { padding: 0.95rem 1.5rem; font-size: 0.9375rem; }
    .btn-block { width: 100%; }
    .btn-dark { background: var(--text); color: var(--bg); }
    .btn-dark:hover { opacity: 0.88; transform: translateY(-1px); }

    /* ── Cards ── */
    .card { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-lg); transition: all var(--transition); }
    .card:hover { border-color: var(--border-strong); }

    /* ── Inputs ── */
    .input { width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--input-bg); color: var(--text); font-size: 0.875rem; font-family: inherit; transition: border-color var(--transition-fast); }
    .input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-soft); }
    .label { font-size: 0.75rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.375rem; display: block; }

    /* ── Chips / Badges ── */
    .chip { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.3125rem 0.625rem; border-radius: 999px; font-size: 0.75rem; font-weight: 500; background: var(--bg-subtle); color: var(--text-secondary); border: 1px solid var(--border); }
    .chip-brand { background: var(--brand-soft); color: var(--brand); border-color: var(--brand-border); }
    .chip-accent { background: rgba(16,185,129,0.12); color: var(--accent); border-color: rgba(16,185,129,0.25); }
    .chip-warn { background: rgba(245,158,11,0.12); color: var(--warning); border-color: rgba(245,158,11,0.25); }

    /* ── Top Navigation ── */
    .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(1.8) blur(16px); -webkit-backdrop-filter: saturate(1.8) blur(16px); background: var(--nav-bg); border-bottom: 1px solid var(--border); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 72px; gap: 2rem; }
    .logo { display: flex; align-items: center; gap: 0.5rem; font-weight: 800; font-size: 1.375rem; letter-spacing: -0.03em; color: var(--brand); }
    .logo svg { width: 28px; height: 28px; }
    .nav-links { display: flex; align-items: center; gap: 0.25rem; }
    .nav-link { padding: 0.5rem 0.875rem; border-radius: var(--radius); font-size: 0.875rem; font-weight: 500; color: var(--text-secondary); transition: all var(--transition-fast); }
    .nav-link:hover, .nav-link.active { background: var(--bg-hover); color: var(--text); }
    .nav-link.active { font-weight: 600; }

    .avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--brand) 0%, #7c3aed 100%); color: white; display: inline-flex; align-items: center; justify-content: center; font-size: 0.8125rem; font-weight: 600; flex-shrink: 0; }
    .avatar-lg { width: 48px; height: 48px; font-size: 1rem; }
    .avatar-xl { width: 72px; height: 72px; font-size: 1.25rem; }

    /* ── Theme toggle ── */
    .theme-btn { width: 36px; height: 36px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; background: transparent; color: var(--text-secondary); border: 1px solid var(--border); transition: all var(--transition-fast); }
    .theme-btn:hover { background: var(--bg-subtle); color: var(--text); }
    .theme-btn svg { width: 16px; height: 16px; }
    [data-theme="light"] .icon-moon { display: block; } [data-theme="light"] .icon-sun { display: none; }
    [data-theme="dark"] .icon-moon { display: none; } [data-theme="dark"] .icon-sun { display: block; }

    /* ── User menu ── */
    .user-menu { position: relative; }
    .user-menu-btn { display: flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.5rem 0.375rem 0.875rem; border-radius: 999px; background: var(--bg-subtle); border: 1px solid var(--border); transition: all var(--transition-fast); color: var(--text); }
    .user-menu-btn:hover { box-shadow: var(--shadow); border-color: var(--border-strong); }
    .user-menu-panel { position: absolute; top: calc(100% + 0.5rem); right: 0; min-width: 240px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); padding: 0.375rem; z-index: 60; }
    .user-menu-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 0.75rem; border-radius: var(--radius-sm); font-size: 0.875rem; color: var(--text); transition: background var(--transition-fast); }
    .user-menu-item:hover { background: var(--bg-hover); }
    .user-menu-item svg { width: 18px; height: 18px; color: var(--text-muted); }
    .user-menu-sep { height: 1px; background: var(--border); margin: 0.375rem 0; }

    /* ── Mobile nav ── */
    .nav-hamburger { display: none; width: 40px; height: 40px; border-radius: var(--radius); align-items: center; justify-content: center; background: transparent; color: var(--text); border: 1px solid var(--border); }
    @media (max-width: 900px) {
      .nav-links { display: none; }
      .nav-hamburger { display: inline-flex; }
    }
    .mobile-menu { position: fixed; inset: 0; z-index: 100; background: var(--bg); transform: translateX(100%); transition: transform var(--transition); padding: 2rem 1.5rem; overflow-y: auto; }
    .mobile-menu.open { transform: translateX(0); }

    /* ── Toast ── */
    .toast-wrap { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 200; display: flex; flex-direction: column-reverse; gap: 0.625rem; pointer-events: none; max-width: calc(100vw - 3rem); }
    .toast { pointer-events: auto; padding: 0.875rem 1.125rem; border-radius: var(--radius); font-size: 0.875rem; font-weight: 500; background: var(--bg-elevated); color: var(--text); box-shadow: var(--shadow-lg); border: 1px solid var(--border); display: flex; align-items: center; gap: 0.75rem; animation: toastIn 0.32s cubic-bezier(0.16, 1, 0.3, 1); max-width: 380px; }
    .toast.toast-success { border-left: 3px solid var(--accent); }
    .toast.toast-error { border-left: 3px solid var(--brand); }
    .toast.toast-info { border-left: 3px solid #3b82f6; }
    @keyframes toastIn { from { opacity: 0; transform: translateY(1rem) scale(0.95); } to { opacity: 1; transform: none; } }

    /* ── Skeleton ── */
    .skeleton { background: var(--skeleton); background-size: 200% 100%; animation: skeleton 1.4s infinite; border-radius: var(--radius-sm); }
    @keyframes skeleton { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* ── Grid helpers ── */
    .grid { display: grid; gap: 1.25rem; }
    .grid-1 { grid-template-columns: 1fr; }
    .grid-2 { grid-template-columns: repeat(2, 1fr); }
    .grid-3 { grid-template-columns: repeat(3, 1fr); }
    .grid-4 { grid-template-columns: repeat(4, 1fr); }
    @media (max-width: 1024px) {
      .grid-4 { grid-template-columns: repeat(3, 1fr); }
      .grid-3 { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 700px) {
      .grid-4, .grid-3, .grid-2 { grid-template-columns: 1fr; }
    }

    /* ── Misc ── */
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
    .divider { height: 1px; background: var(--border); margin: 1.5rem 0; }
    .muted { color: var(--text-muted); }
    .faint { color: var(--text-faint); }
    .fade-in { animation: fadeIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) both; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(0.5rem); } to { opacity: 1; transform: none; } }
    .hover-lift { transition: transform var(--transition); }
    .hover-lift:hover { transform: translateY(-2px); }

    /* Focus */
    *:focus-visible { outline: 2px solid var(--brand); outline-offset: 2px; border-radius: var(--radius-sm); }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 5px; border: 2px solid var(--bg); }

    @stack('styles')
  </style>
</head>
<body>

  <!-- Top Navigation -->
  <nav class="nav">
    <div class="container nav-inner">
      <div style="display:flex; align-items:center; gap:2rem">
        <StxLink to="/" class="logo">
          <svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect x="2" y="10" width="28" height="14" rx="4" fill="currentColor"/>
            <rect x="6" y="6" width="20" height="8" rx="3" fill="currentColor" opacity="0.6"/>
            <circle cx="9" cy="24" r="3" fill="var(--bg)"/>
            <circle cx="23" cy="24" r="3" fill="var(--bg)"/>
          </svg>
          drivly
        </StxLink>

        <div class="nav-links">
          <StxLink to="/search" class="nav-link {{ activePage === 'search' ? 'active' : '' }}">Browse cars</StxLink>
          <StxLink to="/host/list" class="nav-link {{ activePage === 'become-host' ? 'active' : '' }}">Become a host</StxLink>
          <StxLink to="/about" class="nav-link {{ activePage === 'about' ? 'active' : '' }}">How it works</StxLink>
        </div>
      </div>

      <div style="display:flex; align-items:center; gap:0.5rem">
        <button class="theme-btn" onclick="window._toggleTheme()" aria-label="Toggle theme">
          <svg class="icon-sun" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2m0 16v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M2 12h2m16 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="icon-moon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>

        <StxLink to="/favorites" class="theme-btn" aria-label="Favorites" title="Favorites" style="position:relative">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span id="fav-dot" style="display:none; position:absolute; top:4px; right:4px; width:8px; height:8px; background:var(--brand); border-radius:50%; border:2px solid var(--bg)"></span>
        </StxLink>

        <div class="user-menu" id="userMenu">
          <button class="user-menu-btn" @click="window._toggleUserMenu()" aria-haspopup="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 6h18M3 12h18M3 18h18"/></svg>
            <span class="avatar" id="nav-avatar">U</span>
          </button>
          <div class="user-menu-panel" id="userMenuPanel" style="display:none">
            <div id="userMenuGuest" style="display:none">
              <StxLink to="/login" class="user-menu-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>Log in</StxLink>
              <StxLink to="/signup" class="user-menu-item" style="font-weight:600"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M8.5 7a4 4 0 1 0 0 8 4 4 0 0 0 0-8zM20 8v6M23 11h-6"/></svg>Sign up</StxLink>
              <div class="user-menu-sep"></div>
              <StxLink to="/host/list" class="user-menu-item">List your car</StxLink>
            </div>
            <div id="userMenuUser" style="display:none">
              <StxLink to="/trips" class="user-menu-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 13h12l3-13M3 6l-1-3M3 6h18"/></svg>My trips</StxLink>
              <StxLink to="/favorites" class="user-menu-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>Favorites</StxLink>
              <StxLink to="/host/dashboard" class="user-menu-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h7v9H3zM14 3h7v5h-7zM14 12h7v9h-7zM3 16h7v5H3z"/></svg>Host dashboard</StxLink>
              <div class="user-menu-sep"></div>
              <StxLink to="/host/list" class="user-menu-item">List your car</StxLink>
              <a href="#" class="user-menu-item" onclick="window._logout(); return false;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>Log out</a>
            </div>
          </div>
        </div>

        <button class="nav-hamburger" @click="window._openMobileMenu()" aria-label="Open menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <aside class="mobile-menu" id="mobileMenu">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem">
      <span class="logo">drivly</span>
      <button class="theme-btn" @click="window._closeMobileMenu()" aria-label="Close menu">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <nav style="display:flex; flex-direction:column; gap:0.25rem">
      <StxLink to="/" class="nav-link">Home</StxLink>
      <StxLink to="/search" class="nav-link">Browse cars</StxLink>
      <StxLink to="/host/list" class="nav-link">Become a host</StxLink>
      <StxLink to="/host/dashboard" class="nav-link">Host dashboard</StxLink>
      <StxLink to="/trips" class="nav-link">My trips</StxLink>
      <StxLink to="/favorites" class="nav-link">Favorites</StxLink>
      <StxLink to="/about" class="nav-link">How it works</StxLink>
      <div class="divider"></div>
      <StxLink to="/login" class="nav-link">Log in</StxLink>
      <StxLink to="/signup" class="nav-link">Sign up</StxLink>
    </nav>
  </aside>

  <!-- Page content -->
  <main>
    @yield('content')
  </main>

  @include('footer.stx')

  <!-- Toasts -->
  <div class="toast-wrap" id="toastWrap" aria-live="polite" aria-atomic="true"></div>

  <script client>
    if (!window.__drivlyShell) {
      window.__drivlyShell = true

      window._toggleTheme = function () {
        var html = document.documentElement
        var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
        html.setAttribute('data-theme', next)
        try { localStorage.setItem('drivly-theme', next) } catch (e) {}
      }

      window._openMobileMenu = function () {
        document.getElementById('mobileMenu').classList.add('open')
        document.body.style.overflow = 'hidden'
      }
      window._closeMobileMenu = function () {
        document.getElementById('mobileMenu').classList.remove('open')
        document.body.style.overflow = ''
      }

      window._toggleUserMenu = function () {
        var p = document.getElementById('userMenuPanel')
        if (!p) return
        p.style.display = p.style.display === 'none' ? 'block' : 'none'
      }
      document.addEventListener('click', function (e) {
        var menu = document.getElementById('userMenu')
        var panel = document.getElementById('userMenuPanel')
        if (!menu || !panel) return
        if (!menu.contains(e.target)) panel.style.display = 'none'
      })

      window._toast = function (msg, type) {
        type = type || 'info'
        var wrap = document.getElementById('toastWrap')
        if (!wrap) return
        var t = document.createElement('div')
        t.className = 'toast toast-' + type
        var icon = type === 'success' ? '✓' : type === 'error' ? '⚠' : 'ℹ'
        t.innerHTML = '<span style="font-weight:700; color:var(--text-muted)">' + icon + '</span><span>' + msg + '</span>'
        wrap.appendChild(t)
        setTimeout(function () {
          t.style.transition = 'opacity 0.3s, transform 0.3s'
          t.style.opacity = '0'
          t.style.transform = 'translateY(0.5rem)'
          setTimeout(function () { t.remove() }, 320)
        }, 3200)
      }

      // Hook up session store → update avatar + menu rows
      try {
        const session = useStore('session')
        const favorites = useStore('favorites')

        effect(function () {
          var u = session.user()
          var guest = document.getElementById('userMenuGuest')
          var user = document.getElementById('userMenuUser')
          var av = document.getElementById('nav-avatar')
          if (u) {
            if (guest) guest.style.display = 'none'
            if (user) user.style.display = 'block'
            if (av) av.textContent = u.avatar || 'U'
          } else {
            if (guest) guest.style.display = 'block'
            if (user) user.style.display = 'none'
            if (av) av.textContent = 'U'
          }
        })

        effect(function () {
          var dot = document.getElementById('fav-dot')
          if (dot) dot.style.display = favorites.count() > 0 ? 'block' : 'none'
        })

        window._logout = function () {
          session.logout()
          window._toast('Signed out', 'info')
          try { window.navigate && window.navigate('/') } catch (e) { location.href = '/' }
        }
      } catch (e) {
        console.warn('Store init failed', e)
      }

      // Close menus on ESC
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          window._closeMobileMenu()
          var p = document.getElementById('userMenuPanel')
          if (p) p.style.display = 'none'
        }
      })
    }
  </script>

</body>
</html>
