<body class="bg-black text-white font-sans antialiased">

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 lg:px-12 py-4 flex justify-between items-center bg-black/90 backdrop-blur-xl border-b border-white/5">
