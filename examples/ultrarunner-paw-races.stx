      </a>
    </div>
  </nav>

  <!-- Header -->
  <header class="pt-40 lg:pt-48 pb-16 px-6 lg:px-12 max-w-[1400px] mx-auto">
    <span class="text-[0.6rem] font-semibold tracking-[0.25em] uppercase text-white/25 block mb-8">Race Results</span>
    <h1 class="font-display text-[clamp(4rem,9vw,8rem)] leading-[0.85] tracking-tight">THE RECORD.</h1>
    <p class="text-base text-white/35 leading-relaxed max-w-[560px] mt-8">
      UTMB-indexed results from 100K to 700K. Every start line, every finish, every lesson.
    </p>
  </header>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">

    <!-- Summary Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 border-t border-white/5 mb-16">
      <div class="p-8 border-b border-r border-white/5">
        <div class="text-3xl font-extrabold tracking-tight">9</div>
        <div class="text-[0.6rem] font-medium tracking-[0.15em] uppercase text-white/20 mt-3">UTMB Races</div>
      </div>
      <div class="p-8 border-b border-white/5 lg:border-r">
        <div class="text-3xl font-extrabold tracking-tight">700km</div>
        <div class="text-[0.6rem] font-medium tracking-[0.15em] uppercase text-white/20 mt-3">Longest Distance</div>
      </div>
      <div class="p-8 border-b border-r border-white/5">
        <div class="text-3xl font-extrabold tracking-tight">49,000m</div>
        <div class="text-[0.6rem] font-medium tracking-[0.15em] uppercase text-white/20 mt-3">Max Elevation</div>
      </div>
      <div class="p-8 border-b border-white/5">
        <div class="text-3xl font-extrabold tracking-tight">8 / 9</div>
        <div class="text-[0.6rem] font-medium tracking-[0.15em] uppercase text-white/20 mt-3">Finish Rate</div>
      </div>
    </div>

    <!-- Race Table -->
    <div class="overflow-x-auto">
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-white/10">
            <th class="text-left py-4 px-4 text-[0.55rem] font-semibold tracking-[0.15em] uppercase text-white/25">Date</th>
            <th class="text-left py-4 px-4 text-[0.55rem] font-semibold tracking-[0.15em] uppercase text-white/25">Race</th>
            <th class="text-left py-4 px-4 text-[0.55rem] font-semibold tracking-[0.15em] uppercase text-white/25 hidden md:table-cell">Cat.</th>
            <th class="text-left py-4 px-4 text-[0.55rem] font-semibold tracking-[0.15em] uppercase text-white/25">Distance</th>
            <th class="text-left py-4 px-4 text-[0.55rem] font-semibold tracking-[0.15em] uppercase text-white/25 hidden lg:table-cell">Elevation</th>
            <th class="text-left py-4 px-4 text-[0.55rem] font-semibold tracking-[0.15em] uppercase text-white/25">Time</th>
            <th class="text-right py-4 px-4 text-[0.55rem] font-semibold tracking-[0.15em] uppercase text-white/25">Rank</th>
          </tr>
        </thead>
        <tbody>
          @foreach (races as race)
            <tr class="border-b border-white/[0.03] hover:bg-white/[0.02] transition-colors">
              <td class="py-4 px-4 text-sm text-white/30 tabular-nums whitespace-nowrap">{{ race.date }}</td>
              <td class="py-4 px-4">
                <div class="text-sm font-semibold">{{ race.flag }} {{ race.name }}</div>
                <div class="text-xs text-white/25 mt-0.5 hidden md:block">{{ race.sub }}</div>
              </td>
              <td class="py-4 px-4 hidden md:table-cell">
                <span class="inline-block px-2.5 py-1 border border-white/10 text-[0.65rem] font-semibold text-white/50">{{ race.category }}</span>
              </td>
              <td class="py-4 px-4 text-sm font-medium tabular-nums">{{ race.distance }}</td>
              <td class="py-4 px-4 text-sm text-white/35 tabular-nums hidden lg:table-cell">{{ race.elevation }}</td>
              @if (race.isDnf)
                <td class="py-4 px-4 text-sm text-white/15 italic">DNF</td>
                <td class="py-4 px-4 text-sm text-white/15 italic text-right">—</td>
              @else
                <td class="py-4 px-4 text-sm font-medium tabular-nums">{{ race.time }}</td>
                <td class="py-4 px-4 text-sm font-bold tabular-nums text-right">{{ race.rank }}</td>
              @endif
            </tr>
          @endforeach
        </tbody>
      </table>
    </div>
  </div>

  <!-- Footer -->
  <footer class="border-t border-white/5 px-6 lg:px-12 py-8 mt-24">
    <div class="max-w-[1400px] mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <span class="text-xs text-white/20">© 2026 Paweł Dregan</span>
      <div class="flex items-center gap-8">
