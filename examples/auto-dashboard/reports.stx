    // Open technician detail
    function openTechDetail(name) {
      var tech = technicianDetails[name]
      if (!tech) return

      // Monthly table
      var monthlyHtml = ''
      tech.monthly.forEach(function(m) {
        monthlyHtml += '<tr style="border-bottom: 1px solid var(--row-border)">'
        monthlyHtml += '<td class="py-2 text-left" style="color: var(--text-tertiary)">' + m.month + '</td>'
        monthlyHtml += '<td class="py-2 text-right tabular-nums" style="color: var(--text-primary)">' + m.estimates + '</td>'
        monthlyHtml += '<td class="py-2 text-right tabular-nums" style="color: var(--text-success)">' + m.accuracy + '%</td>'
        monthlyHtml += '<td class="py-2 text-right tabular-nums" style="color: var(--text-tertiary)">' + m.cycle + 'd</td>'
        monthlyHtml += '<td class="py-2 text-right tabular-nums" style="color: var(--badge-amber-text)">' + m.rating + '</td>'
        monthlyHtml += '</tr>'
      })

      // Specializations
      var specHtml = ''
      tech.specializations.forEach(function(s) {
        specHtml += '<span class="spec-pill badge-blue">' + s + '</span>'
      })

      // Certifications
      var certHtml = ''
      if (tech.certifications) {
        tech.certifications.forEach(function(c) {
          var badgeClass = c.status === 'Active' ? 'badge-emerald' : 'badge-amber'
          certHtml += '<div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid var(--row-border);">'
          certHtml += '<div style="display: flex; align-items: center; gap: 0.5rem;">'
          certHtml += '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--text-accent); flex-shrink: 0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>'
          certHtml += '<span style="font-size: 0.875rem; font-weight: 500; color: var(--text-primary);">' + c.name + '</span>'
          certHtml += '</div>'
          certHtml += '<div style="display: flex; align-items: center; gap: 0.75rem;">'
          certHtml += '<span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium ' + badgeClass + '">' + c.status + '</span>'
          certHtml += '<span style="font-size: 0.75rem; color: var(--text-muted);">Expires: ' + c.expires + '</span>'
          certHtml += '</div></div>'
        })
      }

      // Recent work
      var workHtml = ''
      tech.recentWork.forEach(function(w) {
        workHtml += '<tr style="border-bottom: 1px solid var(--row-border)">'
        workHtml += '<td class="py-2 text-left" style="color: var(--text-accent)">' + w.id + '</td>'
        workHtml += '<td class="py-2 text-left" style="color: var(--text-secondary)">' + w.vehicle + '</td>'
        workHtml += '<td class="py-2 text-right tabular-nums" style="color: var(--text-tertiary)">' + w.date + '</td>'
        workHtml += '<td class="py-2 text-right tabular-nums font-medium" style="color: var(--text-primary)">' + w.total + '</td>'
        workHtml += '</tr>'
      })

      var html = ''
        + '<div class="detail-section" style="display: flex; align-items: center; justify-content: space-between;">'
        + '<div>'
        + '<h2 class="text-xl font-bold" style="color: var(--text-primary)">' + name + '</h2>'
        + '<p class="text-sm mt-0.5" style="color: var(--text-muted)">' + tech.role + '</p>'
        + '</div>'
        + '<button onclick="closeSlideOver()" class="p-2 rounded-lg" style="color: var(--text-muted); background: var(--bg-subtle)" aria-label="Close panel">'
        + '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
        + '</button>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Performance Overview</div>'
        + '<div class="detail-row"><span class="detail-row-label">Estimates completed</span><span class="detail-row-value">' + tech.estimates + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Accuracy rate</span><span class="detail-row-value" style="color: var(--text-success)">' + tech.accuracy + '%</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Average cycle time</span><span class="detail-row-value">' + tech.cycleTime + ' days</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Customer rating</span><span class="detail-row-value">' + tech.rating + '/5.0 ' + stx.renderStars(tech.rating) + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Revenue generated</span><span class="detail-row-value" style="color: var(--text-revenue)">' + tech.revenue + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Supplement rate</span><span class="detail-row-value">' + tech.supplementRate + '</span></div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Monthly Performance</div>'
        + '<table class="w-full text-sm">'
        + '<thead><tr class="text-xs uppercase tracking-wider" style="color: var(--text-muted)">'
        + '<th class="text-left py-2 font-medium">Month</th>'
        + '<th class="text-right py-2 font-medium">Estimates</th>'
        + '<th class="text-right py-2 font-medium">Accuracy</th>'
        + '<th class="text-right py-2 font-medium">Cycle</th>'
        + '<th class="text-right py-2 font-medium">Rating</th>'
        + '</tr></thead>'
        + '<tbody>' + monthlyHtml + '</tbody>'
        + '</table>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Specializations</div>'
        + '<div class="flex flex-wrap gap-1">' + specHtml + '</div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Certifications & Training</div>'
        + certHtml
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Recent Work</div>'
        + '<table class="w-full text-sm">'
        + '<thead><tr class="text-xs uppercase tracking-wider" style="color: var(--text-muted)">'
        + '<th class="text-left py-2 font-medium">ID</th>'
        + '<th class="text-left py-2 font-medium">Vehicle</th>'
        + '<th class="text-right py-2 font-medium">Date</th>'
        + '<th class="text-right py-2 font-medium">Total</th>'
        + '</tr></thead>'
        + '<tbody>' + workHtml + '</tbody>'
        + '</table>'
        + '</div>'

        + '<div class="detail-section" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">'
        + '<button class="px-4 py-2 rounded-lg text-sm font-medium text-white" style="background: var(--btn-primary-bg)" onclick="showToast(\'Opening full profile...\', \'info\'); closeSlideOver()">View Full Profile</button>'
        + '<button class="px-4 py-2 rounded-lg text-sm font-medium border" style="background: var(--btn-action-bg); border-color: var(--btn-action-border); color: var(--btn-action-text)" onclick="showToast(\'Assign estimate panel opening...\', \'info\'); closeSlideOver()">Assign Estimate</button>'
        + '<button class="px-4 py-2 rounded-lg text-sm font-medium border" style="background: var(--bg-subtle); border-color: var(--border-input); color: var(--text-tertiary)" onclick="showToast(\'Generating performance report...\', \'info\'); closeSlideOver()">Performance Report</button>'
        + '</div>'

      stx.detail.open(html)
    }
</script>
