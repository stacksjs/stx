                  <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium {{ formatBadgeClass(report.format) }}">{{ report.format }}</span>
                </td>
                <td class="px-5 py-3.5 text-right tabular-nums" style="color: var(--text-muted)">{{ report.size }}</td>
                <td class="px-5 py-3.5 text-right">
                  <a href="#" class="text-sm font-medium" style="color: var(--text-accent)" onclick="event.preventDefault(); showToast('Downloading {{ report.name }}...', 'success')">Download</a>
                </td>
              </tr>
            @endforeach
          </tbody>
        </table>
      </div>
@endsection

<script client>
    // Generate Report slide-over
