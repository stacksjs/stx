function supplementBarColor(color) {
  if (color === 'green') return 'var(--bar-emerald)'
  if (color === 'amber') return 'var(--bar-amber)'
  return 'var(--bar-red)'
}

function formatBadgeClass(format) {
  if (format === 'PDF') return 'badge-red'
  if (format === 'CSV') return 'badge-emerald'
  return 'badge-blue'
}
