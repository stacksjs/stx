        + '<label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text-secondary)"><input type="radio" name="reportFormat" value="pdf" checked style="accent-color: var(--text-accent)"> PDF</label>'
        + '<label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text-secondary)"><input type="radio" name="reportFormat" value="csv" style="accent-color: var(--text-accent)"> CSV</label>'
        + '<label class="flex items-center gap-2 cursor-pointer text-sm" style="color: var(--text-secondary)"><input type="radio" name="reportFormat" value="excel" style="accent-color: var(--text-accent)"> Excel</label>'
        + '</div>'
        + '</div>'
        + '<div class="detail-section">'
        + '<button class="w-full px-4 py-2.5 rounded-lg text-sm font-medium text-white" style="background: var(--btn-primary-bg)" onclick="showToast(\'Report queued for generation...\', \'success\'); closeSlideOver()">Generate Report</button>'
        + '</div>'

      stx.detail.open(html)
    }

