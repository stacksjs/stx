@push('styles')
    .comm-type-sms { background: var(--badge-emerald-bg); color: var(--badge-emerald-text); }
    .comm-type-email { background: var(--badge-blue-bg); color: var(--badge-blue-text); }
    .toggle-switch { position: relative; width: 36px; height: 20px; border-radius: 9999px; cursor: pointer; border: none; padding: 0; transition: background 0.2s; }
    .toggle-switch.on { background: var(--bar-emerald); }
    .toggle-switch.off { background: var(--bg-subtle); border: 1px solid var(--border-input); }
    .toggle-switch .toggle-dot { position: absolute; top: 2px; width: 16px; height: 16px; border-radius: 50%; background: white; transition: left 0.2s; }
    .toggle-switch.on .toggle-dot { left: 18px; }
    .toggle-switch.off .toggle-dot { left: 2px; }
@endpush

