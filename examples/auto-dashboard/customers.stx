        vehicles: [
          { year: 2023, make: 'Kia', model: 'Telluride', vin: '5XYP3DHC7NG182435', insurer: 'Allstate', estimates: 2, status: 'Pending Pickup' },
          { year: 2021, make: 'Hyundai', model: 'Sonata', vin: '5NPEH4JA6MH045218', insurer: 'Allstate', estimates: 2, status: 'No Active Repair' }
        ],
        repairs: [
          { date: '2026-02-05', desc: 'Front-end collision — Telluride', cost: '$8,450', status: 'Pending Pickup', estimateId: 'EST-4710', insurer: 'Allstate', vin: '5XYP3DHC7NG182435' },
          { date: '2025-10-28', desc: 'Door panel dent — Sonata', cost: '$2,900', status: 'Completed', estimateId: 'EST-4555', insurer: 'Allstate', vin: '5NPEH4JA6MH045218' },
          { date: '2025-06-14', desc: 'Rear bumper — Telluride', cost: '$4,500', status: 'Completed', estimateId: 'EST-4320', insurer: 'Allstate', vin: '5XYP3DHC7NG182435' },
          { date: '2025-01-20', desc: 'Windshield replacement — Sonata', cost: '$3,500', status: 'Completed', estimateId: 'EST-4060', insurer: 'Allstate', vin: '5NPEH4JA6MH045218' }
        ],
        financial: { totalSpent: '$19,350', avgRepair: '$4,838', outstanding: '$8,450' },
        notes: 'Two-vehicle household. Prefers weekend pickup. Responsive to reminders.',
        commLog: [
          { date: '2026-02-05', channel: 'SMS', message: 'Reminder: Your Telluride is ready for pickup.' },
          { date: '2026-02-03', channel: 'Email', message: 'Repair complete. Please schedule pickup.' },
          { date: '2025-10-28', channel: 'SMS', message: 'Sonata dent repair done. Pick up anytime.' },
          { date: '2025-06-14', channel: 'Email', message: 'Telluride bumper replacement complete.' },
          { date: '2025-01-20', channel: 'SMS', message: 'Windshield installed. Vehicle ready.' }
        ]
      }
    }

    // Message templates
    var messageTemplates = {
      'vehicle-received': { subject: 'Vehicle Received', body: 'We have received your vehicle at our facility. Our team will begin the assessment process shortly. We will keep you updated on the progress.' },
      'estimate-ready': { subject: 'Estimate Ready', body: 'Your repair estimate is ready for review. Please log in to your portal or contact us to discuss the details and approve the work.' },
      'repair-progress': { subject: 'Repair In Progress', body: 'Your vehicle repair is currently in progress. Our technicians are working diligently to restore your vehicle. Estimated completion date will be provided soon.' },
      'ready-pickup': { subject: 'Ready for Pickup', body: 'Great news! Your vehicle repair is complete and ready for pickup. Please visit our facility during business hours (Mon-Fri 8AM-6PM, Sat 9AM-1PM).' },
      'followup-survey': { subject: 'How Was Your Experience?', body: 'Thank you for choosing AutoEstimate. We value your feedback! Please take a moment to rate your experience and let us know how we can improve.' }
    }

    // Filter customers using stx.table.filter()
    function filterCustomers() {
      stx.table.filter({
        searchId: 'customerSearch',
        rowSelector: '.customer-row',
        filters: [
          { id: 'statusFilter', attr: 'data-status', allValue: '' }
        ],
        searchAttrs: ['data-name', 'data-email', 'data-phone', 'data-vins'],
        sortId: 'sortFilter',
        sortMap: {
          name: { attr: 'data-name', dir: 'asc' },
          vehicles: { attr: 'data-vehicles', dir: 'desc', type: 'number' },
          recent: { attr: 'data-lastvisit', dir: 'desc' }
        },
        tbodyId: 'customerTableBody',
        countId: 'customerShowingLabel',
        totalLabel: '15 customers',
        emptyId: 'emptyState'
      })
    }

    function clearFilters() {
      document.getElementById('customerSearch').value = ''
      document.getElementById('statusFilter').value = ''
      document.getElementById('sortFilter').value = 'recent'
      filterCustomers()
    }

    // Initialize
    filterCustomers()

    // Open customer detail slide-over
    function openCustomerDetail(idx) {
      var c = customerDetails[idx]
      if (!c) return

      var statusBadgeClass = stx.badgeClass(c.status, 'status')

      // Vehicles list
      var vehiclesList = ''
      c.vehicles.forEach(function(v) {
        var vBadge = stx.badgeClass(v.status, 'status')
        var vinParam = v.vin ? encodeURIComponent(v.vin) : ''
        vehiclesList += '<div onclick="closeSlideOver(); window.location.href=\'/vehicles/' + vinParam + '\'" style="padding: 0.625rem; border-radius: 0.5rem; background: var(--bg-subtle); margin-bottom: 0.5rem; cursor: pointer; transition: background 0.15s ease, border-color 0.15s ease; border: 1px solid transparent;" onmouseover="this.style.background=\'var(--bg-subtle-hover)\'; this.style.borderColor=\'var(--bg-glass-border-hover)\'" onmouseout="this.style.background=\'var(--bg-subtle)\'; this.style.borderColor=\'transparent\'">'
        vehiclesList += '<div style="display: flex; justify-content: space-between; align-items: center;">'
        vehiclesList += '<span style="font-size: 0.875rem; font-weight: 500; color: var(--text-primary);">' + v.year + ' ' + v.make + ' ' + v.model + ' <svg style="display:inline;vertical-align:middle;opacity:0.4;margin-left:2px" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg></span>'
        vehiclesList += '<span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium ' + vBadge + '">' + v.status + '</span>'
        vehiclesList += '</div>'
        if (v.vin) {
          vehiclesList += '<div style="display: flex; gap: 1rem; margin-top: 0.375rem; flex-wrap: wrap;">'
          vehiclesList += '<span style="font-size: 0.75rem; color: var(--text-muted);">VIN: <span style="font-family: monospace; color: var(--text-tertiary);">' + v.vin + '</span></span>'
          if (v.insurer) { vehiclesList += '<span style="font-size: 0.75rem; color: var(--text-muted);">Insurer: <span style="color: var(--text-tertiary);">' + v.insurer + '</span></span>' }
          if (v.estimates) { vehiclesList += '<span style="font-size: 0.75rem; color: var(--text-muted);">Estimates: <span style="color: var(--text-accent);">' + v.estimates + '</span></span>' }
          vehiclesList += '</div>'
        }
        vehiclesList += '</div>'
      })

      // Repair timeline using stx.detail.timeline()
      var repairTimelineItems = c.repairs.map(function(r) {
        var color = r.status === 'In Progress' ? 'amber' : r.status === 'Pending Pickup' ? 'blue' : r.status === 'Pending Estimate' ? 'slate' : 'accent'
        var meta = r.date
        if (r.estimateId) meta += ' · <a href="/estimates" style="color: var(--text-accent); text-decoration: none;">' + r.estimateId + '</a>'
        if (r.insurer) meta += ' · ' + r.insurer
        meta += ' · ' + r.status
        if (r.vin) meta += '<br><span style="font-size: 0.6875rem;">VIN: <span style="font-family: monospace;">' + r.vin + '</span></span>'
        return { title: r.desc, description: r.cost, meta: meta, color: color }
      })
      var repairTimeline = stx.detail.timeline(repairTimelineItems)

      // Communication log
      var commLog = ''
      c.commLog.forEach(function(log) {
        var channelClass = log.channel === 'SMS' ? 'comm-type-sms' : 'comm-type-email'
        commLog += '<div style="padding: 0.5rem 0; border-bottom: 1px solid var(--border-main);">'
        commLog += '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">'
        commLog += '<span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium ' + channelClass + '">' + log.channel + '</span>'
        commLog += '<span style="font-size: 0.75rem; color: var(--text-muted);">' + log.date + '</span>'
        commLog += '</div>'
        commLog += '<p style="font-size: 0.8125rem; color: var(--text-tertiary);">' + log.message + '</p>'
        commLog += '</div>'
      })

      var html = stx.detail.panel({ title: c.name, badges: [{ text: c.status, map: 'status' }] })

        // Contact info
        + stx.detail.section('Contact Information', {
          'Email': c.email,
          'Phone': c.phone,
          'Address': c.address
        })

        // Insurance summary
        + stx.detail.section('Insurance', (function() {
          var insurers = {}
          c.vehicles.forEach(function(v) { if (v.insurer) insurers[v.insurer] = true })
          var result = []
          Object.keys(insurers).forEach(function(ins) { result.push({ label: 'Primary Insurer', value: ins }) })
          result.push({ label: 'Total Vehicles', value: c.vehicles.length })
          result.push({ label: 'Total Estimates', value: c.vehicles.reduce(function(sum, v) { return sum + (v.estimates || 0) }, 0) })
          return result
        })())

        // Communication preferences
        + '<div class="detail-section">'
        + '<div class="detail-label">Communication Preferences</div>'
        + '<div class="detail-row"><span class="detail-row-label">SMS Notifications</span><span class="detail-row-value"><button class="toggle-switch ' + (c.smsEnabled ? 'on' : 'off') + '" onclick="this.classList.toggle(\'on\');this.classList.toggle(\'off\')"><span class="toggle-dot"></span></button></span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Email Notifications</span><span class="detail-row-value"><button class="toggle-switch ' + (c.emailEnabled ? 'on' : 'off') + '" onclick="this.classList.toggle(\'on\');this.classList.toggle(\'off\')"><span class="toggle-dot"></span></button></span></div>'
        + '</div>'

        // Vehicles
        + '<div class="detail-section">'
        + '<div class="detail-label">Vehicles</div>'
        + vehiclesList
        + '</div>'

        // Repair history
        + '<div class="detail-section">'
        + '<div class="detail-label">Repair History</div>'
        + repairTimeline
        + '</div>'

        // Financial summary
        + stx.detail.section('Financial Summary', {
          'Total Spent': c.financial.totalSpent,
          'Avg Repair Cost': c.financial.avgRepair,
          'Outstanding Balance': c.financial.outstanding
        })

        // Notes
        + '<div class="detail-section">'
        + '<div class="detail-label">Notes</div>'
        + '<p style="font-size: 0.875rem; color: var(--text-tertiary); line-height: 1.5;">' + c.notes + '</p>'
        + '</div>'

        // Communication log
        + '<div class="detail-section">'
        + '<div class="detail-label">Communication Log</div>'
        + commLog
        + '</div>'

        // Action buttons
        + '<div class="detail-section" style="display: flex; gap: 0.75rem;">'
        + '<button onclick="closeSlideOver(); setTimeout(function(){ openSendMessage(' + idx + '); }, 350);" style="flex: 1; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 500; color: white; background: var(--btn-primary-bg); border: none; cursor: pointer;">Send Update</button>'
        + '<button onclick="showToast(\'Appointment scheduler coming soon\', \'info\')" style="flex: 1; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 500; color: var(--btn-action-text); background: var(--btn-action-bg); border: 1px solid var(--btn-action-border); cursor: pointer;">Schedule Appointment</button>'
        + '</div>'

      stx.detail.open(html)
    }

    // Open send message slide-over
    function openSendMessage(idx) {
      var c = customerDetails[idx]
      if (!c) return

      var html = ''
        + '<div style="display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-main);">'
        + '<div>'
        + '<h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary);">Send Update</h2>'
        + '<p style="font-size: 0.875rem; color: var(--text-muted); margin-top: 0.25rem;">To: ' + c.name + '</p>'
        + '</div>'
        + '<button onclick="closeSlideOver()" style="padding: 0.5rem; border-radius: 0.5rem; color: var(--text-muted); background: none; border: none; cursor: pointer;" aria-label="Close">'
        + '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
        + '</button>'
        + '</div>'

        // Template selection
        + '<div class="detail-section">'
        + '<div class="detail-label">Message Template</div>'
        + '<select id="msgTemplate" onchange="updateMessagePreview()" style="width: 100%; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-primary); padding-left: 0.75rem; padding-right: 2rem;">'
        + '<option value="vehicle-received">Vehicle Received</option>'
        + '<option value="estimate-ready">Estimate Ready</option>'
        + '<option value="repair-progress">Repair In Progress</option>'
        + '<option value="ready-pickup">Ready for Pickup</option>'
        + '<option value="followup-survey">Follow-up Survey</option>'
        + '</select>'
        + '</div>'

        // Channel selection
        + '<div class="detail-section">'
        + '<div class="detail-label">Channel</div>'
        + '<div style="display: flex; gap: 0.75rem;">'
        + '<label style="flex: 1; display: flex; align-items: center; gap: 0.5rem; padding: 0.625rem; border-radius: 0.5rem; border: 1px solid var(--border-input); background: var(--bg-input); cursor: pointer; font-size: 0.875rem; color: var(--text-secondary);">'
        + '<input type="radio" name="msgChannel" value="sms" checked style="accent-color: var(--text-accent);"> SMS'
        + '</label>'
        + '<label style="flex: 1; display: flex; align-items: center; gap: 0.5rem; padding: 0.625rem; border-radius: 0.5rem; border: 1px solid var(--border-input); background: var(--bg-input); cursor: pointer; font-size: 0.875rem; color: var(--text-secondary);">'
        + '<input type="radio" name="msgChannel" value="email" style="accent-color: var(--text-accent);"> Email'
        + '</label>'
        + '<label style="flex: 1; display: flex; align-items: center; gap: 0.5rem; padding: 0.625rem; border-radius: 0.5rem; border: 1px solid var(--border-input); background: var(--bg-input); cursor: pointer; font-size: 0.875rem; color: var(--text-secondary);">'
        + '<input type="radio" name="msgChannel" value="both" style="accent-color: var(--text-accent);"> Both'
        + '</label>'
        + '</div>'
        + '</div>'

        // Message preview
        + '<div class="detail-section">'
        + '<div class="detail-label">Message Preview</div>'
        + '<div id="msgPreview" style="padding: 1rem; border-radius: 0.5rem; background: var(--bg-subtle); border: 1px solid var(--border-main);">'
        + '<p style="font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem;">Vehicle Received</p>'
        + '<p style="font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">We have received your vehicle at our facility. Our team will begin the assessment process shortly. We will keep you updated on the progress.</p>'
        + '<p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.75rem;">— AutoEstimate</p>'
        + '</div>'
        + '</div>'

        // Send button
        + '<div class="detail-section">'
        + '<button onclick="sendMessage(\'' + c.name + '\')" style="width: 100%; padding: 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600; color: white; background: var(--btn-primary-bg); border: none; cursor: pointer;">Send Message</button>'
        + '</div>'

      openSlideOver(html)
    }

    // Update message preview based on template selection
    function updateMessagePreview() {
      var select = document.getElementById('msgTemplate')
      var preview = document.getElementById('msgPreview')
      if (!select || !preview) return
      var tmpl = messageTemplates[select.value]
      if (!tmpl) return
      preview.innerHTML = '<p style="font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem;">' + tmpl.subject + '</p>'
        + '<p style="font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">' + tmpl.body + '</p>'
        + '<p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.75rem;">— AutoEstimate</p>'
    }

    // Send message action
    function sendMessage(customerName) {
      var channel = document.querySelector('input[name="msgChannel"]:checked')
      var channelVal = channel ? channel.value : 'sms'
      var channelLabel = channelVal === 'both' ? 'SMS & Email' : channelVal.toUpperCase()
      closeSlideOver()
      showToast('Message sent to ' + customerName + ' via ' + channelLabel, 'success')
    }

    // Add customer form
    function openAddCustomerForm() {
      var html = ''
        + '<div style="display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-main);">'
        + '<h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary);">Add Customer</h2>'
        + '<button onclick="closeSlideOver()" style="padding: 0.5rem; border-radius: 0.5rem; color: var(--text-muted); background: none; border: none; cursor: pointer;" aria-label="Close">'
        + '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
        + '</button>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Personal Information</div>'
        + '<div style="display: flex; flex-direction: column; gap: 0.75rem;">'
        + '<div><label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Full Name</label>'
        + '<input type="text" placeholder="Enter full name" style="width: 100%; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-primary);" /></div>'
        + '<div><label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Email</label>'
        + '<input type="email" placeholder="Enter email address" style="width: 100%; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-primary);" /></div>'
        + '<div><label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Phone</label>'
        + '<input type="tel" placeholder="(555) 555-0000" style="width: 100%; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-primary);" /></div>'
        + '<div><label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Address</label>'
        + '<input type="text" placeholder="Street address, City, State ZIP" style="width: 100%; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-primary);" /></div>'
        + '</div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Communication Preferences</div>'
        + '<div class="detail-row"><span class="detail-row-label">SMS Notifications</span><span class="detail-row-value"><button class="toggle-switch on" onclick="this.classList.toggle(\'on\');this.classList.toggle(\'off\')"><span class="toggle-dot"></span></button></span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Email Notifications</span><span class="detail-row-value"><button class="toggle-switch on" onclick="this.classList.toggle(\'on\');this.classList.toggle(\'off\')"><span class="toggle-dot"></span></button></span></div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Notes</div>'
        + '<textarea placeholder="Add any notes about this customer..." rows="3" style="width: 100%; padding: 0.625rem; border-radius: 0.5rem; font-size: 0.875rem; background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-primary); resize: vertical; font-family: inherit;"></textarea>'
        + '</div>'

        + '<div class="detail-section">'
        + '<button onclick="closeSlideOver(); showToast(\'Customer added successfully\', \'success\')" style="width: 100%; padding: 0.75rem; border-radius: 0.5rem; font-size: 0.875rem; font-weight: 600; color: white; background: var(--btn-primary-bg); border: none; cursor: pointer;">Add Customer</button>'
        + '</div>'

      openSlideOver(html)
    }
</script>
