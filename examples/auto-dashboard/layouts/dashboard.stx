  <!-- Slide-over -->
  <div id="slideOverBackdrop" class="slide-over-backdrop" @click="closeSlideOver()"></div>
  <div id="slideOverPanel" class="slide-over-panel"></div>

  <!-- Toast container -->
  <div id="toastWrap" class="toast-wrap"></div>

  <!-- Mobile menu -->
  <div id="mobileBackdrop" class="mobile-backdrop" @click="closeMobileMenu()"></div>
  <nav id="mobileNav" class="mobile-nav">
    <div class="flex items-center gap-3 mb-6 pb-4" style="border-bottom: 1px solid var(--border-main)">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-violet-600 flex items-center justify-center text-sm font-bold text-white">A</div>
      <span class="font-semibold" style="color: var(--text-primary)">{{ companyName }}</span>
    </div>
    <div class="space-y-1">
      @foreach (navLinks as link)
        @if (link.label === activePage)
          <a href="{{ link.href }}" onclick="closeMobileMenu()" class="block w-full px-3 py-2.5 rounded-lg text-sm font-medium" style="background: var(--nav-active-bg); color: var(--text-primary)">{{ link.label }}</a>
        @else
          <a href="{{ link.href }}" onclick="closeMobileMenu()" class="block w-full px-3 py-2.5 rounded-lg text-sm" style="color: var(--text-nav)">{{ link.label }}</a>
        @endif
      @endforeach
    </div>
  </nav>

  <script client>
    // Layout shell — runs once, persists across SPA navigations
    if (!window.__stxDashboardInit) {
      window.__stxDashboardInit = true;

      // ── Reactive State (STX Signals) ──
      window._notifOpen = state(false)
      window._notifCount = state(5)
      window._slideOpen = state(false)
      window._slideContent = state('')

      // Notification dropdown effect
      effect(function() {
        var dd = document.getElementById('notifDropdown')
        if (dd) dd.style.display = window._notifOpen() ? 'block' : 'none'
      })

      // Notification badge effect
      effect(function() {
        var badge = document.getElementById('notifBadge')
        if (badge) badge.style.display = window._notifCount() > 0 ? '' : 'none'
      })

      // Slide-over effect
      effect(function() {
        var backdrop = document.getElementById('slideOverBackdrop')
        var panel = document.getElementById('slideOverPanel')
        if (!backdrop || !panel) return
        if (window._slideOpen()) {
          panel.innerHTML = window._slideContent()
          backdrop.classList.add('active')
          panel.classList.add('active')
          document.body.style.overflow = 'hidden'
        } else {
          backdrop.classList.remove('active')
          panel.classList.remove('active')
          document.body.style.overflow = ''
        }
      })

      // ── Theme ──
      window.toggleTheme = function() {
        var html = document.documentElement
        var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
        html.setAttribute('data-theme', next)
        localStorage.setItem('stx-theme', next)
        window.updateToggleIcons(next)
      }
      window.updateToggleIcons = function(theme) {
        var sun = document.querySelector('.sun-icon')
        var moon = document.querySelector('.moon-icon')
        if (sun && moon) { sun.style.display = theme === 'light' ? 'block' : 'none'; moon.style.display = theme === 'dark' ? 'block' : 'none'; }
      }
      window.updateToggleIcons(document.documentElement.getAttribute('data-theme') || 'dark')

      // ── Slide-over (signal-based) ──
      window.openSlideOver = function(html) {
        batch(function() {
          window._slideContent.set(html)
          window._slideOpen.set(true)
        })
      }
      window.closeSlideOver = function() {
        window._slideOpen.set(false)
      }

      // ── Toast ──
      window.showToast = function(msg, type) {
        type = type || 'info'
        var wrap = document.getElementById('toastWrap')
        if (!wrap) return
        var t = document.createElement('div')
        t.className = 'toast toast-' + type
        t.innerHTML = msg
        wrap.appendChild(t)
        setTimeout(function() { t.style.animation = 'toastSlideOut 0.3s forwards'; setTimeout(function() { t.remove() }, 300) }, 3500)
      }

      // ── Mobile Menu ──
      window.openMobileMenu = function() {
        document.getElementById('mobileBackdrop').classList.add('active')
        document.getElementById('mobileNav').classList.add('active')
        document.body.style.overflow = 'hidden'
      }
      window.closeMobileMenu = function() {
        document.getElementById('mobileBackdrop').classList.remove('active')
        document.getElementById('mobileNav').classList.remove('active')
        document.body.style.overflow = ''
      }

      // ── Notifications (signal-based) ──
      window.toggleNotifications = function() {
        window._notifOpen.update(function(v) { return !v })
      }
      // Close on outside click
      document.addEventListener('click', function(e) {
        if (window._notifOpen() && !e.target.closest('#notifDropdown') && !e.target.closest('[onclick*="toggleNotifications"]')) {
          window._notifOpen.set(false)
        }
      })
      window.clearNotifications = function() {
        window._notifCount.set(0)
        window.showToast('All notifications marked as read', 'success')
        var dots = document.querySelectorAll('#notifDropdown .w-2.h-2')
        dots.forEach(function(d) { d.style.background = 'var(--bar-track)' })
      }

      // ── Shop Switcher ──
      window.switchShop = function(el) {
        window.showToast('Switched to ' + el.value, 'success')
      }

      // ── Keyboard shortcuts ──
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          if (window._slideOpen()) window.closeSlideOver()
          window.closeMobileMenu()
          window._notifOpen.set(false)
        }
      })
    }
  </script>
</body>
</html>
