<!DOCTYPE html>
<html lang="en">
<head>
  <script>try{var t=localStorage.getItem("stx-theme");if(t)document.documentElement.setAttribute("data-theme",t);else if(!window.matchMedia("(prefers-color-scheme:light)").matches)document.documentElement.setAttribute("data-theme","dark");else document.documentElement.setAttribute("data-theme","light")}catch(e){document.documentElement.setAttribute("data-theme","dark")}</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ companyName }} — {{ activePage }}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
    body { font-family: 'Inter', system-ui, sans-serif; }
    select { padding-right: 2rem !important; }

    [data-theme="dark"] {
      --bg-body: linear-gradient(to bottom right, #020617, #0f172a, #020617);
      --bg-nav: rgba(2, 6, 23, 0.8);
      --bg-glass: rgba(255,255,255,0.03); --bg-glass-hover: rgba(255,255,255,0.06);
      --bg-glass-border: rgba(255,255,255,0.06); --bg-glass-border-hover: rgba(255,255,255,0.12);
      --bg-subtle: rgba(255,255,255,0.05); --bg-subtle-hover: rgba(255,255,255,0.1);
      --bg-input: rgba(255,255,255,0.05); --border-input: rgba(255,255,255,0.1);
      --border-main: rgba(255,255,255,0.05); --border-nav-sep: rgba(255,255,255,0.1);
      --text-primary: #fff; --text-secondary: #e2e8f0; --text-tertiary: #94a3b8;
      --text-muted: #64748b; --text-nav: #94a3b8; --text-nav-hover: #fff;
      --nav-active-bg: rgba(255,255,255,0.1);
      --text-accent: #60a5fa; --text-accent-hover: #93bbfd;
      --text-success: #34d399; --text-revenue: #34d399;
      --bar-track: rgba(255,255,255,0.05); --rank-bg: rgba(255,255,255,0.05);
      --repair-icon-bg: rgba(59,130,246,0.1); --repair-icon-text: #60a5fa;
      --row-hover: rgba(255,255,255,0.02); --row-border: rgba(255,255,255,0.03);
      --scroll-thumb: rgba(255,255,255,0.1);
      --orb-blue: rgba(37,99,235,0.05); --orb-violet: rgba(124,58,237,0.05); --orb-emerald: rgba(5,150,105,0.05);
      --glow-blue: rgba(59,130,246,0.15); --glow-emerald: rgba(16,185,129,0.15);
      --glow-violet: rgba(139,92,246,0.15); --glow-amber: rgba(245,158,11,0.15);
      --badge-emerald-bg: rgba(16,185,129,0.2); --badge-emerald-text: #34d399;
      --badge-blue-bg: rgba(59,130,246,0.2); --badge-blue-text: #60a5fa;
      --badge-amber-bg: rgba(245,158,11,0.2); --badge-amber-text: #fbbf24;
      --badge-slate-bg: rgba(100,116,139,0.2); --badge-slate-text: #94a3b8;
      --badge-red-bg: rgba(239,68,68,0.2); --badge-red-text: #f87171;
      --sev-light-bg: rgba(34,197,94,0.2); --sev-light-text: #4ade80; --sev-light-border: rgba(34,197,94,0.3);
      --sev-mod-bg: rgba(234,179,8,0.2); --sev-mod-text: #facc15; --sev-mod-border: rgba(234,179,8,0.3);
      --sev-heavy-bg: rgba(239,68,68,0.2); --sev-heavy-text: #f87171; --sev-heavy-border: rgba(239,68,68,0.3);
      --alert-warn-bg: rgba(245,158,11,0.08); --alert-warn-border: rgba(245,158,11,0.3); --alert-warn-text: #fcd34d; --alert-warn-icon: #f59e0b;
      --alert-info-bg: rgba(59,130,246,0.08); --alert-info-border: rgba(59,130,246,0.3); --alert-info-text: #93bbfd; --alert-info-icon: #3b82f6;
      --alert-ok-bg: rgba(16,185,129,0.08); --alert-ok-border: rgba(16,185,129,0.3); --alert-ok-text: #6ee7b7; --alert-ok-icon: #10b981;
      --bar-emerald: #10b981; --bar-blue: #3b82f6; --bar-amber: #f59e0b; --bar-slate: #94a3b8; --bar-red: #ef4444;
      --btn-primary-bg: #2563eb; --btn-primary-hover: #3b82f6;
      --btn-action-bg: rgba(37,99,235,0.1); --btn-action-border: rgba(59,130,246,0.2); --btn-action-text: #60a5fa;
    }

    [data-theme="light"] {
      --bg-body: linear-gradient(to bottom right, #f8fafc, #f1f5f9, #f8fafc);
      --bg-nav: rgba(255,255,255,0.85);
      --bg-glass: rgba(255,255,255,0.7); --bg-glass-hover: rgba(255,255,255,0.9);
      --bg-glass-border: rgba(0,0,0,0.08); --bg-glass-border-hover: rgba(0,0,0,0.14);
      --bg-subtle: rgba(0,0,0,0.04); --bg-subtle-hover: rgba(0,0,0,0.08);
      --bg-input: rgba(0,0,0,0.04); --border-input: rgba(0,0,0,0.12);
      --border-main: rgba(0,0,0,0.08); --border-nav-sep: rgba(0,0,0,0.1);
      --text-primary: #0f172a; --text-secondary: #1e293b; --text-tertiary: #475569;
      --text-muted: #94a3b8; --text-nav: #64748b; --text-nav-hover: #0f172a;
      --nav-active-bg: rgba(0,0,0,0.06);
      --text-accent: #2563eb; --text-accent-hover: #1d4ed8;
      --text-success: #059669; --text-revenue: #059669;
      --bar-track: rgba(0,0,0,0.06); --rank-bg: rgba(0,0,0,0.04);
      --repair-icon-bg: rgba(37,99,235,0.08); --repair-icon-text: #2563eb;
      --row-hover: rgba(0,0,0,0.02); --row-border: rgba(0,0,0,0.05);
      --scroll-thumb: rgba(0,0,0,0.12);
      --orb-blue: rgba(37,99,235,0.04); --orb-violet: rgba(124,58,237,0.04); --orb-emerald: rgba(5,150,105,0.04);
      --glow-blue: rgba(59,130,246,0.1); --glow-emerald: rgba(16,185,129,0.1);
      --glow-violet: rgba(139,92,246,0.1); --glow-amber: rgba(245,158,11,0.1);
      --badge-emerald-bg: rgba(16,185,129,0.12); --badge-emerald-text: #059669;
      --badge-blue-bg: rgba(59,130,246,0.12); --badge-blue-text: #2563eb;
      --badge-amber-bg: rgba(245,158,11,0.12); --badge-amber-text: #d97706;
      --badge-slate-bg: rgba(100,116,139,0.12); --badge-slate-text: #475569;
      --badge-red-bg: rgba(239,68,68,0.12); --badge-red-text: #dc2626;
      --sev-light-bg: rgba(34,197,94,0.1); --sev-light-text: #16a34a; --sev-light-border: rgba(34,197,94,0.3);
      --sev-mod-bg: rgba(234,179,8,0.1); --sev-mod-text: #ca8a04; --sev-mod-border: rgba(234,179,8,0.3);
      --sev-heavy-bg: rgba(239,68,68,0.1); --sev-heavy-text: #dc2626; --sev-heavy-border: rgba(239,68,68,0.3);
      --alert-warn-bg: rgba(245,158,11,0.06); --alert-warn-border: rgba(245,158,11,0.25); --alert-warn-text: #92400e; --alert-warn-icon: #d97706;
      --alert-info-bg: rgba(59,130,246,0.06); --alert-info-border: rgba(59,130,246,0.25); --alert-info-text: #1e40af; --alert-info-icon: #2563eb;
      --alert-ok-bg: rgba(16,185,129,0.06); --alert-ok-border: rgba(16,185,129,0.25); --alert-ok-text: #065f46; --alert-ok-icon: #059669;
      --bar-emerald: #10b981; --bar-blue: #3b82f6; --bar-amber: #f59e0b; --bar-slate: #94a3b8; --bar-red: #ef4444;
      --btn-primary-bg: #2563eb; --btn-primary-hover: #1d4ed8;
      --btn-action-bg: rgba(37,99,235,0.06); --btn-action-border: rgba(59,130,246,0.25); --btn-action-text: #2563eb;
    }

    body { background: var(--bg-body); color: var(--text-primary); }
    .glass { background: var(--bg-glass); backdrop-filter: blur(12px); border: 1px solid var(--bg-glass-border); }
    .glass-card:hover { background: var(--bg-glass-hover); border-color: var(--bg-glass-border-hover); transform: translateY(-1px); }
    .bar-animate { animation: barGrow 1s ease-out forwards; transform-origin: left; }
    @keyframes barGrow { from { transform: scaleX(0); } to { transform: scaleX(1); } }
    .fade-in { animation: fadeIn 0.6s ease-out forwards; opacity: 0; }
    @keyframes fadeIn { to { opacity: 1; } }
    .glow-blue { box-shadow: 0 0 20px var(--glow-blue); }
    .glow-emerald { box-shadow: 0 0 20px var(--glow-emerald); }
    .glow-violet { box-shadow: 0 0 20px var(--glow-violet); }
    .glow-amber { box-shadow: 0 0 20px var(--glow-amber); }
    .badge-emerald { background: var(--badge-emerald-bg); color: var(--badge-emerald-text); }
    .badge-blue { background: var(--badge-blue-bg); color: var(--badge-blue-text); }
    .badge-amber { background: var(--badge-amber-bg); color: var(--badge-amber-text); }
    .badge-slate { background: var(--badge-slate-bg); color: var(--badge-slate-text); }
    .badge-red { background: var(--badge-red-bg); color: var(--badge-red-text); }
    .severity-light { background: var(--sev-light-bg); color: var(--sev-light-text); border-color: var(--sev-light-border); }
    .severity-moderate { background: var(--sev-mod-bg); color: var(--sev-mod-text); border-color: var(--sev-mod-border); }
    .severity-heavy { background: var(--sev-heavy-bg); color: var(--sev-heavy-text); border-color: var(--sev-heavy-border); }
    .alert-warning { background: var(--alert-warn-bg); border-color: var(--alert-warn-border); color: var(--alert-warn-text); }
    .alert-warning .alert-icon { color: var(--alert-warn-icon); }
    .alert-info { background: var(--alert-info-bg); border-color: var(--alert-info-border); color: var(--alert-info-text); }
    .alert-info .alert-icon { color: var(--alert-info-icon); }
    .alert-success { background: var(--alert-ok-bg); border-color: var(--alert-ok-border); color: var(--alert-ok-text); }
    .alert-success .alert-icon { color: var(--alert-ok-icon); }
    .bar-emerald { background: var(--bar-emerald); } .bar-blue { background: var(--bar-blue); }
    .bar-amber { background: var(--bar-amber); } .bar-slate { background: var(--bar-slate); } .bar-red { background: var(--bar-red); }
    ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--scroll-thumb); border-radius: 3px; }
    .theme-toggle { position: relative; z-index: 10; width: 44px; height: 24px; border-radius: 9999px; cursor: pointer; border: none; padding: 0; background: transparent; }
    .theme-toggle .toggle-track { width: 100%; height: 100%; border-radius: 9999px; background: var(--bg-subtle); border: 1px solid var(--border-input); display: flex; align-items: center; padding: 0 3px; }
    .theme-toggle .toggle-knob { width: 18px; height: 18px; border-radius: 9999px; background: var(--text-accent); transition: transform 0.3s ease; display: flex; align-items: center; justify-content: center; }
    [data-theme="dark"] .theme-toggle .toggle-knob { transform: translateX(20px); }
    [data-theme="light"] .theme-toggle .toggle-knob { transform: translateX(0); }
    .theme-toggle svg { width: 11px; height: 11px; color: white; }

    /* Slide-over */
    .slide-over-backdrop { position: fixed; inset: 0; z-index: 60; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
    .slide-over-backdrop.active { opacity: 1; pointer-events: auto; }
    .slide-over-panel { position: fixed; top: 0; right: 0; bottom: 0; width: 680px; max-width: 94vw; z-index: 70; transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.16,1,0.3,1); overflow-y: auto; border-left: 1px solid var(--bg-glass-border); }
    .slide-over-panel.active { transform: translateX(0); }
    [data-theme="dark"] .slide-over-panel { background: #0f172a; }
    [data-theme="light"] .slide-over-panel { background: #ffffff; }

    /* Toast */
    .toast-wrap { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 200; display: flex; flex-direction: column-reverse; gap: 0.5rem; pointer-events: none; }
    .toast-wrap > * { pointer-events: auto; }
    .toast { padding: 0.75rem 1.25rem; border-radius: 0.75rem; font-size: 0.875rem; font-weight: 500; display: flex; align-items: center; gap: 0.75rem; border: 1px solid; animation: toastSlideIn 0.35s cubic-bezier(0.16,1,0.3,1); box-shadow: 0 4px 24px rgba(0,0,0,0.15); }
    .toast-success { background: var(--alert-ok-bg); border-color: var(--alert-ok-border); color: var(--alert-ok-text); }
    .toast-info { background: var(--alert-info-bg); border-color: var(--alert-info-border); color: var(--alert-info-text); }
    .toast-warn { background: var(--alert-warn-bg); border-color: var(--alert-warn-border); color: var(--alert-warn-text); }
    @keyframes toastSlideIn { from { opacity: 0; transform: translateY(0.75rem) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @keyframes toastSlideOut { to { opacity: 0; transform: translateY(0.75rem) scale(0.95); } }

    /* Mobile nav */
    .mobile-backdrop { display: none; position: fixed; inset: 0; z-index: 55; background: rgba(0,0,0,0.5); }
    .mobile-backdrop.active { display: block; }
    .mobile-nav { position: fixed; top: 0; left: 0; bottom: 0; width: 280px; z-index: 56; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); padding: 1.25rem; border-right: 1px solid var(--bg-glass-border); }
    [data-theme="dark"] .mobile-nav { background: #0f172a; }
    [data-theme="light"] .mobile-nav { background: #ffffff; }
    .mobile-nav.active { transform: translateX(0); }

    /* Detail sections in slide-over */
    .detail-section { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-main); }
    .detail-section:last-child { border-bottom: none; }
    .detail-label { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.75rem; }
    .detail-row { display: flex; justify-content: space-between; align-items: center; padding: 0.375rem 0; }
    .detail-row-label { font-size: 0.875rem; color: var(--text-tertiary); }
    .detail-row-value { font-size: 0.875rem; font-weight: 500; color: var(--text-primary); }

    /* Better focus */
    :focus-visible { outline: 2px solid var(--text-accent); outline-offset: 2px; }
    a:focus-visible, button:focus-visible { border-radius: 0.375rem; }

    /* Clickable table row */
    tr.clickable { cursor: pointer; }
    tr.clickable:active { opacity: 0.8; }

    /* Shared utility: empty state */
    .empty-state { text-align: center; padding: 3rem 1.5rem; }

    .nav-icon-btn:hover { background: var(--bg-subtle); }

    @stack('styles')
  </style>
</head>
<body class="min-h-screen antialiased">

  <div class="fixed inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 right-1/4 w-[600px] h-[600px] rounded-full blur-3xl" style="background: var(--orb-blue)"></div>
    <div class="absolute bottom-1/4 left-0 w-[400px] h-[400px] rounded-full blur-3xl" style="background: var(--orb-violet)"></div>
    <div class="absolute top-1/2 right-0 w-[300px] h-[300px] rounded-full blur-3xl" style="background: var(--orb-emerald)"></div>
  </div>

  <div class="relative">

    <nav class="border-b backdrop-blur-xl sticky top-0 z-50" style="border-color: var(--border-main); background: var(--bg-nav)">
      <div class="max-w-[1600px] mx-auto px-6 h-16 flex items-center justify-between">
        <div class="flex items-center gap-8">
          <a href="/" class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-violet-600 flex items-center justify-center text-sm font-bold text-white">A</div>
            <span class="text-lg font-semibold tracking-tight" style="color: var(--text-primary)">{{ companyName }}</span>
          </a>
          <select id="shopSwitcher" class="rounded-lg py-1.5 text-xs focus:outline-none" style="background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-tertiary); padding-left: 0.75rem; padding-right: 2rem" onchange="switchShop(this)">
            <option value="Main Shop — Austin, TX" selected>Main Shop — Austin, TX</option>
            <option value="North Branch — Round Rock, TX">North Branch — Round Rock, TX</option>
            <option value="South Location — San Marcos, TX">South Location — San Marcos, TX</option>
          </select>
          <button class="md:hidden p-2 -ml-2 rounded-lg" style="color: var(--text-nav)" @click="openMobileMenu()" aria-label="Open menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
          </button>
          <div class="hidden md:flex items-center gap-1">
            @foreach (navLinks as link)
              @if (link.label !== 'Customers' && link.label !== 'Schedule' && link.label !== 'Reports')
                @if (link.label === activePage)
                  <a href="{{ link.href }}" class="px-3 py-1.5 rounded-lg text-sm font-medium" style="background: var(--nav-active-bg); color: var(--text-primary)">{{ link.label }}</a>
                @else
                  <a href="{{ link.href }}" class="px-3 py-1.5 rounded-lg text-sm" style="color: var(--text-nav)">{{ link.label }}</a>
                @endif
              @endif
            @endforeach
          </div>
        </div>
        <div class="flex items-center gap-4">
          <button class="theme-toggle" @click="toggleTheme()" aria-label="Toggle theme">
            <div class="toggle-track"><div class="toggle-knob">
              <svg class="sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
              <svg class="moon-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            </div></div>
          </button>
          <!-- Quick-nav icons -->
          <a href="/schedule" class="nav-icon-btn relative p-2 rounded-lg transition-colors" style="color: var(--text-nav)" title="Schedule" aria-label="Schedule">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z"/>
            </svg>
          </a>

          <a href="/customers" class="nav-icon-btn relative p-2 rounded-lg transition-colors" style="color: var(--text-nav)" title="Customers" aria-label="Customers">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
            </svg>
          </a>

          <a href="/reports" class="nav-icon-btn relative p-2 rounded-lg transition-colors" style="color: var(--text-nav)" title="Reports" aria-label="Reports">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
            </svg>
          </a>

          <div class="relative">
            <button onclick="toggleNotifications()" class="nav-icon-btn relative p-2 rounded-lg transition-colors" style="color: var(--text-nav)">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>
