      </div>

      {{-- Today's Schedule Preview --}}
      <div class="glass rounded-xl overflow-hidden fade-in mt-6">
        <div class="px-5 py-4 flex items-center justify-between" style="border-bottom: 1px solid var(--border-main)">
          <h2 class="text-base font-semibold" style="color: var(--text-primary)">Today's Schedule</h2>
          <a href="/schedule" class="text-xs" style="color: var(--text-accent)">View Full Schedule &#8594;</a>
        </div>
        <div>
          @foreach (todaySchedule as appt)
            <div class="flex items-center justify-between px-5 py-3.5" style="border-bottom: 1px solid var(--border-main)">
              <div class="flex items-center gap-4">
                <span class="text-sm font-medium tabular-nums" style="color: var(--text-accent); min-width: 5rem">{{ appt.time }}</span>
                <span class="text-sm" style="color: var(--text-secondary)">{{ appt.customer }}</span>
              </div>
              <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium {{ scheduleTypeBadge(appt.type) }}">{{ appt.type }}</span>
            </div>
          @endforeach
        </div>
      </div>
@endsection

