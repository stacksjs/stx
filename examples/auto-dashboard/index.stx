function statusColor(status) {
  const colors = { 'Approved': 'badge-emerald', 'In Review': 'badge-blue', 'Supplement': 'badge-amber', 'Draft': 'badge-slate', 'Rejected': 'badge-red' }
  return colors[status] || 'badge-slate'
}

function severityBadge(severity) {
  const badges = { 'light': 'severity-light', 'moderate': 'severity-moderate', 'heavy': 'severity-heavy' }
  return badges[severity] || ''
}

function alertClass(type) {
  const styles = { 'warning': 'alert-warning', 'info': 'alert-info', 'success': 'alert-success' }
  return styles[type] || ''
}

const navLinks = [
