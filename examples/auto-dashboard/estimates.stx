    // Build detail HTML from data using stx.detail.* helpers
    function buildDetail(id) {
      var d = ED[id];
      if (!d) return '';
      var h = '';

      // Header
      var badges = [{ text: d.status, map: 'status' }];
      if (d.status === 'Supplement') {
        badges.push({ text: 'Supplement 1 of 2', map: 'status' });
      }
      h += stx.detail.panel({ title: id, subtitle: d.date, badges: badges });

      // Vehicle
      h += stx.detail.section('Vehicle', { 'Year / Make / Model': d.vehicle, 'VIN': d.vin, 'Color': d.color, 'Mileage': d.mileage });
      // Customer
      h += stx.detail.section('Customer', { 'Name': d.owner, 'Phone': d.phone, 'Email': d.email });
      // Insurance
      h += stx.detail.section('Insurance', { 'Company': d.insurer, 'Policy #': d.policy, 'Claim #': d.claim, 'Adjuster': d.adjuster });
      // Compliance
      h += '<div class="detail-section"><div class="detail-label">Compliance</div>';
      h += '<div style="display:flex;flex-direction:column;gap:0.5rem">';
      h += complianceRow(true, 'Labor rate within guidelines ($52/hr < $55/hr max)');
      h += complianceRow(true, 'OEM parts required — OEM parts used');
      h += complianceRow(false, 'Photo documentation — 3 of 4 required photos uploaded');
      h += complianceRow(true, 'Estimate submitted within 48-hour window');
      h += '</div></div>';
      // Damage
      h += '<div class="detail-section"><div class="detail-label">Damage Assessment</div>';
      h += stx.detail.row('Point of Impact', d.impact);
      h += stx.detail.row('Severity', '<span class="inline-flex px-2 py-0.5 rounded text-[11px] font-medium border ' + d.sevClass + '" style="text-transform:capitalize">' + d.severity + '</span>');
      h += stx.detail.row('Driveable', d.driveable) + '</div>';
      // Line Items
      h += '<div class="detail-section"><div class="detail-label">Line Items</div><table class="line-items-table"><thead><tr><th>Description</th><th>Type</th><th>Amount</th></tr></thead><tbody>';
      for (var i = 0; i < d.items.length; i++) {
        var it = d.items[i];
        var tc = 'type-' + it[1].toLowerCase();
        h += '<tr><td>' + it[0] + '</td><td><span class="type-badge ' + tc + '">' + it[1] + '</span></td><td>' + it[2] + '</td></tr>';
      }
      h += '</tbody></table></div>';
      // Totals
      h += '<div class="detail-section"><div class="detail-label">Cost Summary</div>';
      h += stx.detail.row('Labor', d.labor) + stx.detail.row('Parts', d.parts) + stx.detail.row('Paint &amp; Materials', d.paintMat);
      h += '<div class="detail-row" style="margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid var(--border-main)"><span class="detail-row-label" style="font-weight:600;color:var(--text-primary)">Grand Total</span><span class="detail-row-value" style="font-size:1rem;color:var(--text-accent)">' + d.total + '</span></div></div>';
      // Timeline
      var timelineItems = [];
      for (var j = 0; j < d.timeline.length; j++) {
        var t = d.timeline[j];
        timelineItems.push({ title: t[1], meta: t[0], color: t[2] });
      }
      h += stx.detail.timeline(timelineItems);
      // Photos & Documentation
      h += '<div class="detail-section"><div class="detail-label">Photos &amp; Documentation <span style="font-size:0.6875rem;font-weight:400;color:var(--text-muted)">(3 photos)</span></div>';
      h += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.5rem;margin-bottom:0.75rem">';
      var photoLabels = ['Front damage', 'Side angle', 'Close-up panel', 'VIN plate'];
      var photoColors = ['#3b82f6', '#8b5cf6', '#10b981', '#f59e0b'];
      for (var pi = 0; pi < photoLabels.length; pi++) {
        h += '<div style="aspect-ratio:4/3;border-radius:0.5rem;display:flex;align-items:center;justify-content:center;font-size:0.625rem;font-weight:500;color:#fff;text-align:center;padding:0.25rem;background:' + photoColors[pi] + (pi === 3 ? ';opacity:0.4;border:2px dashed var(--border-input)' : '') + '">' + photoLabels[pi] + '</div>';
      }
      h += '</div>';
      h += '<button onclick="showToast(\'Photo upload dialog opened\', \'info\')" style="padding:0.375rem 0.75rem;border-radius:0.375rem;font-size:0.75rem;font-weight:500;background:var(--bg-subtle);border:1px solid var(--border-input);color:var(--text-tertiary);cursor:pointer">Upload Photos</button>';
      h += '</div>';
      // Supplements
      h += '<div class="detail-section"><div class="detail-label">Supplements</div>';
      if (d.status === 'Supplement') {
        h += stx.detail.row('Original Estimate', d.total);
        h += '<div class="detail-row"><span class="detail-row-label">Supplement 1</span><span class="detail-row-value">' + stx.badge('approved', 'status') + ' +$1,240.00</span></div>';
        h += '<div class="detail-row"><span class="detail-row-label">Supplement 2</span><span class="detail-row-value">' + stx.badge('pending', 'status') + ' +$680.00</span></div>';
        var origNum = parseFloat(d.total.replace(/[$,]/g, ''));
        var revisedTotal = stx.formatCurrency(origNum + 1240 + 680);
        h += '<div class="detail-row" style="margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid var(--border-main)"><span class="detail-row-label" style="font-weight:600;color:var(--text-primary)">Revised Total</span><span class="detail-row-value" style="color:var(--text-accent)">' + revisedTotal + '</span></div>';
      } else {
        h += '<p style="font-size:0.8125rem;color:var(--text-muted)">No supplements filed</p>';
      }
      h += '</div>';
      // Actions
      h += '<div class="detail-section" style="display:flex;gap:0.75rem;flex-wrap:wrap">';
      h += btn('Edit Estimate', "showToast('Opening editor for " + id + "...', 'info'); closeSlideOver();", true);
      h += btn('Print', "showToast('Printing " + id + "...', 'info'); closeSlideOver();", false);
      h += btn('Submit', "showToast('" + id + " submitted for review', 'success'); closeSlideOver();", false);
      h += btn('Create Supplement', "openSupplementForm('" + id + "')", false);
      h += '</div>';
      return h;
    }

    function btn(label, onclick, primary) {
      if (primary) return '<button onclick="' + onclick + '" style="flex:1;text-align:center;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">' + label + '</button>';
      return '<button onclick="' + onclick + '" style="flex:1;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;background:var(--bg-subtle);border:1px solid var(--border-input);color:var(--text-tertiary);cursor:pointer">' + label + '</button>';
    }

    function openEstimateDetail(id) {
      var html = buildDetail(id);
      if (html) stx.detail.open(html);
    }

    function openNewEstimateForm() {
      var h = '';
      h += '<div class="detail-section" style="display:flex;align-items:center;justify-content:space-between">';
      h += '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">New Estimate</h2>';
      h += '<button onclick="closeSlideOver()" style="color:var(--text-muted);font-size:1.5rem;background:none;border:none;cursor:pointer;line-height:1">&times;</button></div>';
      // Vehicle info
      h += '<div class="detail-section"><div class="detail-label">Vehicle Information</div>';
      h += '<div style="display:flex;gap:0.5rem;align-items:flex-end">';
      h += '<div style="flex:1">' + formField('VIN', 'newVin', 'text', 'e.g. 5YJ3E1EA8RF109186') + '</div>';
      h += '<button id="decodeVinBtn" onclick="decodeVIN()" style="margin-bottom:0.75rem;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.8125rem;font-weight:500;color:var(--btn-action-text);background:var(--btn-action-bg);border:1px solid var(--btn-action-border);cursor:pointer;white-space:nowrap">Decode VIN</button>';
      h += '</div>';
      h += '<div id="vinDecodedInfo" style="display:none"></div>';
      h += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">';
      h += formField('Year', 'newYear', 'number', '2024');
      h += formField('Make', 'newMake', 'text', 'e.g. Tesla');
      h += '</div>';
      h += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">';
      h += formField('Model', 'newModel', 'text', 'e.g. Model Y');
      h += formField('Color', 'newColor', 'text', 'e.g. Pearl White');
      h += '</div>';
      h += formField('Mileage', 'newMileage', 'text', 'e.g. 12,480 mi');
      h += '</div>';
      // Customer
      h += '<div class="detail-section"><div class="detail-label">Customer</div>';
      h += formField('Full Name', 'newOwner', 'text', 'e.g. James Rodriguez');
      h += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">';
      h += formField('Phone', 'newPhone', 'tel', '(512) 555-0147');
      h += formField('Email', 'newEmail', 'email', 'customer@email.com');
      h += '</div></div>';
      // Insurance
      h += '<div class="detail-section"><div class="detail-label">Insurance</div>';
      h += formSelect('Insurance Company', 'newInsurer', ['Select...','State Farm','Progressive','GEICO','Allstate','USAA','Liberty Mutual','Farmers','Other']);
      h += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">';
      h += formField('Policy #', 'newPolicy', 'text', 'SF-9847362');
      h += formField('Claim #', 'newClaim', 'text', 'CLM-2026-XXXXX');
      h += '</div>';
      h += formField('Adjuster Name', 'newAdjuster', 'text', 'Patricia Holloway');
      h += '</div>';
      // Damage
      h += '<div class="detail-section"><div class="detail-label">Damage Assessment</div>';
      h += formSelect('Point of Impact', 'newImpact', ['Select...','Front End','Rear End','Driver Side','Passenger Side','Front Left Quarter','Front Right Quarter','Rear Left Quarter','Rear Right Quarter','Roof','Undercarriage']);
      h += formSelect('Severity', 'newSeverity', ['Select...','Light','Moderate','Heavy']);
      h += formSelect('Driveable', 'newDriveable', ['Yes','No']);
      h += '</div>';
      // Notes
      h += '<div class="detail-section"><div class="detail-label">Notes</div>';
      h += '<textarea id="newNotes" rows="3" placeholder="Initial damage observations, special instructions..." style="width:100%;padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem;resize:vertical;font-family:inherit"></textarea></div>';
      // Actions
      h += '<div class="detail-section" style="display:flex;gap:0.75rem">';
      h += '<button onclick="submitNewEstimate(\'draft\')" style="flex:1;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;background:var(--bg-subtle);border:1px solid var(--border-input);color:var(--text-tertiary);cursor:pointer">Save as Draft</button>';
      h += '<button onclick="submitNewEstimate(\'submit\')" style="flex:1;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Create &amp; Submit</button>';
      h += '</div>';
      openSlideOver(h);
    }

    function formField(label, id, type, placeholder) {
      return '<div style="margin-bottom:0.75rem"><label style="display:block;font-size:0.75rem;font-weight:500;color:var(--text-muted);margin-bottom:0.25rem">' + label + '</label><input id="' + id + '" type="' + type + '" placeholder="' + placeholder + '" style="width:100%;padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem" /></div>';
    }
    function formSelect(label, id, options) {
      var h = '<div style="margin-bottom:0.75rem"><label style="display:block;font-size:0.75rem;font-weight:500;color:var(--text-muted);margin-bottom:0.25rem">' + label + '</label><select id="' + id + '" style="width:100%;padding:0.5rem 2rem 0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem">';
      for (var i = 0; i < options.length; i++) h += '<option>' + options[i] + '</option>';
      return h + '</select></div>';
    }

    // Compliance row helper
    function complianceRow(pass, text) {
      var icon = pass ? '<span style="color:var(--text-success)">&#10003;</span>' : '<span style="color:var(--badge-amber-text)">&#9888;</span>';
      return '<div style="display:flex;align-items:center;gap:0.5rem;font-size:0.8125rem;color:var(--text-tertiary)">' + icon + ' ' + text + '</div>';
    }

    // Decode VIN in New Estimate form
    function decodeVIN() {
      var vinInput = document.getElementById('newVin');
      if (!vinInput || !vinInput.value) {
        showToast('Please enter a VIN first', 'warn');
        return;
      }
      var btnEl = document.getElementById('decodeVinBtn');
      btnEl.textContent = 'Decoding...';
      btnEl.disabled = true;
      setTimeout(function() {
        var yearEl = document.getElementById('newYear');
        var makeEl = document.getElementById('newMake');
        var modelEl = document.getElementById('newModel');
        var colorEl = document.getElementById('newColor');
        if (yearEl) yearEl.value = '2024';
        if (makeEl) makeEl.value = 'Toyota';
        if (modelEl) modelEl.value = 'RAV4';
        if (colorEl) colorEl.value = 'Magnetic Gray';
        var infoEl = document.getElementById('vinDecodedInfo');
        if (infoEl) {
          infoEl.style.display = 'block';
          infoEl.innerHTML = '<div style="margin-bottom:0.75rem;padding:0.75rem;border-radius:0.5rem;background:var(--alert-ok-bg);border:1px solid var(--alert-ok-border)">' +
            '<div style="font-size:0.75rem;font-weight:600;color:var(--alert-ok-text);margin-bottom:0.25rem">Decoded: 2024 Toyota RAV4 XLE Premium</div>' +
            '<div style="font-size:0.6875rem;color:var(--alert-ok-text)">Build Sheet: XLE Premium Package, Panoramic Roof, JBL Audio, BSM, RCTA</div>' +
            '</div>';
        }
        btnEl.textContent = 'Decode VIN';
        btnEl.disabled = false;
        showToast('VIN decoded successfully', 'success');
      }, 1000);
    }

    // AI Photo Estimate
    function openAIPhotoEstimate() {
      var h = '';
      h += '<div class="detail-section" style="display:flex;align-items:center;justify-content:space-between">';
      h += '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">AI Photo Estimate</h2>';
      h += '<button onclick="closeSlideOver()" style="color:var(--text-muted);font-size:1.5rem;background:none;border:none;cursor:pointer;line-height:1">&times;</button></div>';
      h += '<div class="detail-section">';
      h += '<div id="aiPhotoDropZone" style="border:2px dashed var(--border-input);border-radius:0.75rem;padding:2.5rem 1.5rem;text-align:center;cursor:pointer;margin-bottom:1rem">';
      h += '<svg style="width:2.5rem;height:2.5rem;margin:0 auto 0.75rem;color:var(--text-muted)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>';
      h += '<p style="font-size:0.875rem;font-weight:500;color:var(--text-secondary)">Drop damage photos here or click to upload</p>';
      h += '<p style="font-size:0.75rem;color:var(--text-muted);margin-top:0.25rem">Supports JPG, PNG up to 20MB each</p>';
      h += '</div>';
      h += formField('Vehicle VIN', 'aiPhotoVin', 'text', 'e.g. 5YJ3E1EA8RF109186');
      h += '<button id="aiAnalyzeBtn" onclick="runAIPhotoAnalysis()" style="width:100%;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:linear-gradient(135deg,#2563eb,#7c3aed);border:none;cursor:pointer">Analyze &amp; Generate Estimate</button>';
      h += '<div id="aiPhotoResults" style="display:none;margin-top:1rem"></div>';
      h += '</div>';
      openSlideOver(h);
    }

    function runAIPhotoAnalysis() {
      var btn = document.getElementById('aiAnalyzeBtn');
      btn.textContent = 'Analyzing damage with AI...';
      btn.disabled = true;
      btn.style.opacity = '0.7';
      var resultsEl = document.getElementById('aiPhotoResults');
      resultsEl.style.display = 'block';
      resultsEl.innerHTML = '<div style="text-align:center;padding:1.5rem"><div style="display:inline-block;width:2rem;height:2rem;border:3px solid var(--border-input);border-top-color:var(--text-accent);border-radius:50%;animation:spin 0.8s linear infinite"></div><p style="font-size:0.8125rem;color:var(--text-muted);margin-top:0.75rem">Analyzing 4 photos with AI vision model...</p></div><style>@keyframes spin{to{transform:rotate(360deg)}}</style>';
      setTimeout(function() {
        btn.textContent = 'Analyze & Generate Estimate';
        btn.disabled = false;
        btn.style.opacity = '1';
        var lines = [
          ['R&R front bumper cover', '$1,280.00', 95],
          ['R&R hood panel', '$2,340.00', 92],
          ['Headlamp assembly LH', '$1,860.00', 97],
          ['Headlamp assembly RH', '$1,420.00', 88],
          ['Blend fender LH', '$485.00', 85],
          ['Refinish materials', '$390.00', 93]
        ];
        var rh = '<div style="margin-bottom:0.75rem"><div class="detail-label">AI-Generated Line Items</div>';
        rh += '<table class="line-items-table"><thead><tr><th>Description</th><th>Amount</th><th style="text-align:right">Confidence</th></tr></thead><tbody>';
        var total = 0;
        for (var i = 0; i < lines.length; i++) {
          var amt = parseFloat(lines[i][1].replace(/[$,]/g, ''));
          total += amt;
          rh += '<tr><td>' + lines[i][0] + '</td><td>' + lines[i][1] + '</td><td style="text-align:right"><span style="font-size:0.75rem;font-weight:600;color:var(--text-success)">' + lines[i][2] + '%</span></td></tr>';
        }
        rh += '</tbody></table></div>';
        rh += '<div class="detail-row" style="padding-top:0.5rem;border-top:1px solid var(--border-main)"><span class="detail-row-label" style="font-weight:600">Estimated Total</span><span class="detail-row-value" style="color:var(--text-accent)">$' + total.toLocaleString('en-US', {minimumFractionDigits:2}) + '</span></div>';
        rh += '<button onclick="showToast(\'Estimate created from AI analysis\', \'success\'); closeSlideOver();" style="width:100%;margin-top:1rem;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Accept &amp; Create Estimate</button>';
        resultsEl.innerHTML = rh;
      }, 3000);
    }

    // AI Review
    function openAIReview() {
      var h = '';
      h += '<div class="detail-section" style="display:flex;align-items:center;justify-content:space-between">';
      h += '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">AI Estimate Review</h2>';
      h += '<button onclick="closeSlideOver()" style="color:var(--text-muted);font-size:1.5rem;background:none;border:none;cursor:pointer;line-height:1">&times;</button></div>';
      h += '<div class="detail-section"><div class="detail-label">Analysis of Current Estimates</div>';
      var suggestions = [
        { icon: '+', color: 'var(--badge-amber-text)', title: 'Missing operation: Blend adjacent panel', desc: 'Commonly needed for quarter panel repairs (+$420)', bg: 'var(--alert-warn-bg)', border: 'var(--alert-warn-border)' },
        { icon: '!', color: 'var(--badge-blue-text)', title: 'Labor hours may be low', desc: 'Hood R&R typically requires 4.5 hrs, estimate shows 3.2 hrs', bg: 'var(--alert-info-bg)', border: 'var(--alert-info-border)' },
        { icon: '%', color: 'var(--badge-amber-text)', title: 'Supplement likelihood: 73%', desc: 'Hidden damage probable based on impact point', bg: 'var(--alert-warn-bg)', border: 'var(--alert-warn-border)' }
      ];
      for (var i = 0; i < suggestions.length; i++) {
        var s = suggestions[i];
        h += '<div style="padding:0.875rem;border-radius:0.5rem;margin-bottom:0.75rem;background:' + s.bg + ';border:1px solid ' + s.border + '">';
        h += '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:0.75rem">';
        h += '<div><p style="font-size:0.8125rem;font-weight:600;color:var(--text-primary)">' + s.title + '</p>';
        h += '<p style="font-size:0.75rem;color:var(--text-tertiary);margin-top:0.25rem">' + s.desc + '</p></div>';
        h += '<button onclick="showToast(\'Suggestion applied to estimate\', \'success\')" style="padding:0.375rem 0.75rem;border-radius:0.375rem;font-size:0.75rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer;white-space:nowrap">Apply</button>';
        h += '</div></div>';
      }
      h += '</div>';
      openSlideOver(h);
    }

    // Voice/Text Estimate
    function openVoiceTextEstimate() {
      var h = '';
      h += '<div class="detail-section" style="display:flex;align-items:center;justify-content:space-between">';
      h += '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">Voice/Text Estimate</h2>';
      h += '<button onclick="closeSlideOver()" style="color:var(--text-muted);font-size:1.5rem;background:none;border:none;cursor:pointer;line-height:1">&times;</button></div>';
      h += '<div class="detail-section">';
      h += '<div class="detail-label">Describe the Damage</div>';
      h += '<textarea id="voiceTextInput" rows="6" placeholder="Front bumper cracked and displaced, hood buckled with 3-inch crease, both headlamps shattered, radiator support bent, airbags deployed" style="width:100%;padding:0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem;resize:vertical;font-family:inherit;margin-bottom:1rem"></textarea>';
      h += '<button id="voiceGenBtn" onclick="generateFromText()" style="width:100%;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Generate Estimate</button>';
      h += '<div id="voiceTextResults" style="display:none;margin-top:1rem"></div>';
      h += '</div>';
      openSlideOver(h);
    }

    function generateFromText() {
      var input = document.getElementById('voiceTextInput');
      if (!input || !input.value.trim()) {
        showToast('Please describe the damage first', 'warn');
        return;
      }
      var btn = document.getElementById('voiceGenBtn');
      btn.textContent = 'Generating estimate from description...';
      btn.disabled = true;
      btn.style.opacity = '0.7';
      var resultsEl = document.getElementById('voiceTextResults');
      resultsEl.style.display = 'block';
      resultsEl.innerHTML = '<div style="text-align:center;padding:1.5rem"><div style="display:inline-block;width:2rem;height:2rem;border:3px solid var(--border-input);border-top-color:var(--text-accent);border-radius:50%;animation:spin 0.8s linear infinite"></div><p style="font-size:0.8125rem;color:var(--text-muted);margin-top:0.75rem">Parsing damage description with AI...</p></div>';
      setTimeout(function() {
        btn.textContent = 'Generate Estimate';
        btn.disabled = false;
        btn.style.opacity = '1';
        var lines = [
          ['R&R front bumper cover', 'Part', '$1,480.00'],
          ['R&R hood panel', 'Labor', '$890.00'],
          ['Hood panel OEM', 'Part', '$2,340.00'],
          ['Headlamp assembly LH', 'Part', '$1,640.00'],
          ['Headlamp assembly RH', 'Part', '$1,640.00'],
          ['Radiator support repair', 'Labor', '$1,920.00'],
          ['Airbag module replacement', 'Part', '$2,800.00'],
          ['Refinish 3 panels', 'Paint', '$1,180.00']
        ];
        var rh = '<div class="detail-label">Generated Line Items</div>';
        rh += '<table class="line-items-table"><thead><tr><th>Description</th><th>Type</th><th>Amount</th></tr></thead><tbody>';
        var total = 0;
        for (var i = 0; i < lines.length; i++) {
          var amt = parseFloat(lines[i][2].replace(/[$,]/g, ''));
          total += amt;
          var tc = 'type-' + lines[i][1].toLowerCase();
          rh += '<tr><td>' + lines[i][0] + '</td><td><span class="type-badge ' + tc + '">' + lines[i][1] + '</span></td><td>' + lines[i][2] + '</td></tr>';
        }
        rh += '</tbody></table>';
        rh += '<div class="detail-row" style="margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid var(--border-main)"><span class="detail-row-label" style="font-weight:600">Total</span><span class="detail-row-value" style="color:var(--text-accent)">$' + total.toLocaleString('en-US', {minimumFractionDigits:2}) + '</span></div>';
        rh += '<button onclick="showToast(\'Estimate created from text description\', \'success\'); closeSlideOver();" style="width:100%;margin-top:1rem;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Create Estimate</button>';
        resultsEl.innerHTML = rh;
      }, 2500);
    }

    // Supplement form
    function openSupplementForm(id) {
      var h = '';
      h += '<div class="detail-section" style="display:flex;align-items:center;justify-content:space-between">';
      h += '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">Create Supplement — ' + id + '</h2>';
      h += '<button onclick="closeSlideOver()" style="color:var(--text-muted);font-size:1.5rem;background:none;border:none;cursor:pointer;line-height:1">&times;</button></div>';
      h += '<div class="detail-section"><div class="detail-label">Supplement Details</div>';
      h += formSelect('Reason', 'suppReason', ['Select reason...', 'Hidden damage discovered', 'Additional parts needed', 'Labor adjustment', 'Paint/refinish adjustment', 'Mechanical supplement', 'Other']);
      h += '<div class="detail-label" style="margin-top:0.75rem">Additional Line Items</div>';
      h += '<div style="display:grid;grid-template-columns:2fr 1fr;gap:0.5rem;margin-bottom:0.5rem">';
      h += '<input placeholder="Description" style="padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.8125rem" />';
      h += '<input placeholder="Amount" style="padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.8125rem" />';
      h += '</div>';
      h += '<div style="display:grid;grid-template-columns:2fr 1fr;gap:0.5rem;margin-bottom:0.5rem">';
      h += '<input placeholder="Description" style="padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.8125rem" />';
      h += '<input placeholder="Amount" style="padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.8125rem" />';
      h += '</div>';
      h += '<textarea rows="3" placeholder="Notes and justification for supplement..." style="width:100%;padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem;resize:vertical;font-family:inherit;margin-top:0.5rem"></textarea>';
      h += '</div>';
      h += '<div class="detail-section" style="display:flex;gap:0.75rem">';
      h += '<button onclick="closeSlideOver()" style="flex:1;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;background:var(--bg-subtle);border:1px solid var(--border-input);color:var(--text-tertiary);cursor:pointer">Cancel</button>';
      h += '<button onclick="showToast(\'Supplement created for ' + id + '\', \'success\'); closeSlideOver();" style="flex:1;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Submit Supplement</button>';
      h += '</div>';
      openSlideOver(h);
    }

    function submitNewEstimate(action) {
      var vin = document.getElementById('newVin');
      var make = document.getElementById('newMake');
      var model = document.getElementById('newModel');
      if (!vin || !vin.value || !make || !make.value || !model || !model.value) {
        showToast('Please fill in VIN, Make, and Model', 'warn');
        return;
      }
      var year = document.getElementById('newYear').value || '2024';
      var vehicle = year + ' ' + make.value + ' ' + model.value;
      if (action === 'draft') {
        showToast('Draft estimate saved for ' + vehicle, 'success');
      } else {
        showToast('Estimate created & submitted for ' + vehicle, 'success');
      }
      closeSlideOver();
    }
</script>
