@push('styles')
    /* Stat chip hover */
    .stat-chip { cursor: pointer; transition: transform 0.15s ease, box-shadow 0.15s ease; }
    .stat-chip:hover { transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,0.1); }

    /* Line items table in slide-over */
    .line-items-table { width: 100%; font-size: 0.8125rem; border-collapse: collapse; }
    .line-items-table th { text-align: left; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); padding: 0.375rem 0; border-bottom: 1px solid var(--border-main); }
    .line-items-table th:last-child { text-align: right; }
    .line-items-table td { padding: 0.375rem 0; color: var(--text-tertiary); }
    .line-items-table td:last-child { text-align: right; font-weight: 500; color: var(--text-primary); font-variant-numeric: tabular-nums; }
    .type-badge { display: inline-flex; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .type-labor { background: var(--badge-blue-bg); color: var(--badge-blue-text); }
    .type-part { background: var(--badge-emerald-bg); color: var(--badge-emerald-text); }
    .type-paint { background: var(--badge-amber-bg); color: var(--badge-amber-text); }
    .type-material { background: var(--badge-slate-bg); color: var(--badge-slate-text); }

    /* Timeline in slide-over */
    .timeline-item { display: flex; gap: 0.75rem; padding: 0.5rem 0; }
    .timeline-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 0.375rem; flex-shrink: 0; }
    .timeline-text { font-size: 0.8125rem; color: var(--text-tertiary); }
    .timeline-date { font-size: 0.6875rem; color: var(--text-muted); }
@endpush

