<script client>
    // Pagination state
    var currentPage = state(1)
    var perPage = state(10)
    var filteredRows = [];

    function getFilteredRows() {
      return stx.table.filter({
        searchId: 'searchInput',
        rowSelector: '#estimatesTable tbody tr',
        filters: [
          { id: 'statusFilter', attr: 'data-status', allValue: 'All Statuses' },
          { id: 'severityFilter', attr: 'data-severity', allValue: 'All Severities' },
          { id: 'insurerFilter', attr: 'data-insurer', allValue: 'All Insurers' }
        ]
      });
    }

    function filterEstimates() {
      currentPage.set(1);
      applyPagination();
    }

    function applyPagination() {
      filteredRows = getFilteredRows();
      stx.pagination({
        page: currentPage(),
        perPage: perPage(),
        items: filteredRows,
        countId: 'visibleCount',
        totalId: 'totalCount',
        emptyId: 'emptyState',
        barId: 'paginationBar',
        buttonsId: 'paginationButtons',
        goToPage: goToPage
      });
    }

    function goToPage(page) {
      var totalPages = Math.max(1, Math.ceil(filteredRows.length / perPage()));
      if (page < 1 || page > totalPages) return;
      currentPage.set(page);
      applyPagination();
      document.getElementById('estimatesTable').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function filterByStatus(status) {
      var sel = document.getElementById('statusFilter');
      if (!status) {
        sel.value = 'All Statuses';
      } else {
        sel.value = status;
      }
      document.getElementById('searchInput').value = '';
      document.getElementById('severityFilter').selectedIndex = 0;
      document.getElementById('insurerFilter').selectedIndex = 0;
      filterEstimates();
    }

    // Initialize pagination on load
    applyPagination();

    // Estimate detail data — structured as objects, rendered dynamically
    var ED = {
      'EST-4821': { date: 'March 9, 2026', status: 'Approved', statusClass: 'badge-emerald', vehicle: '2024 Tesla Model Y', vin: '5YJ3E1EA8RF109186', color: 'Pearl White Multi-Coat', mileage: '12,480 mi', owner: 'James Rodriguez', phone: '(512) 555-0147', email: 'j.rodriguez@email.com', insurer: 'State Farm', policy: 'SF-9847362', claim: 'CLM-2026-08421', adjuster: 'Patricia Holloway', impact: 'Rear Left Quarter', severity: 'moderate', sevClass: 'severity-moderate', driveable: 'Yes',
        items: [['R&R rear quarter panel','Labor','$1,420.00'],['Rear quarter panel OEM','Part','$1,890.00'],['Blend rear bumper cover','Paint','$485.00'],['R&R tail lamp assembly','Labor','$380.00'],['Tail lamp assembly','Part','$1,240.00'],['Refinish materials','Material','$290.00'],['Clear coat & blending','Paint','$392.50']],
