        timeline: [['2026-03-09','Estimate approved by adjuster','var(--bar-emerald)'],['2026-03-07','Submitted to State Farm','var(--bar-blue)'],['2026-03-06','Photos uploaded, estimate written','var(--bar-blue)'],['2026-03-05','Vehicle received, initial inspection','var(--bar-slate)']] },
      'EST-4820': { date: 'March 9, 2026', status: 'In Review', statusClass: 'badge-blue', vehicle: '2023 BMW X5', vin: '5UXCR6C05PL872934', color: 'Alpine White', mileage: '28,340 mi', owner: 'Lisa Chen', phone: '(415) 555-0293', email: 'lisa.chen@email.com', insurer: 'Progressive', policy: 'PRG-5528410', claim: 'CLM-2026-08390', adjuster: 'Michael Torres', impact: 'Front End', severity: 'heavy', sevClass: 'severity-heavy', driveable: 'No',
        items: [['R&R front bumper assembly','Labor','$1,680.00'],['Front bumper cover OEM','Part','$2,450.00'],['R&R hood panel','Labor','$890.00'],['Hood panel OEM','Part','$3,200.00'],['Headlamp assembly LH','Part','$1,860.00'],['Blend & refinish hood','Paint','$1,020.00'],['Structural pull & measure','Labor','$690.00']],
