<div class="glass rounded-xl p-5 glass-card transition-all duration-300 glow-{{ color }} fade-in">
  <div class="flex items-center justify-between mb-3">
    <span class="text-xs font-medium uppercase tracking-wider" style="color: var(--text-tertiary)">{{ label }}</span>
    <span class="text-lg">{{ icon }}</span>
  </div>
  <div class="text-2xl font-bold tracking-tight" style="color: var(--text-primary)">{{ value }}</div>
  @if (slot)
    {{ slot }}
  @endif
</div>
