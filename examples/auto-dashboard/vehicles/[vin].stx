function statusColor(status) {
  const colors = { 'Active Repair': 'badge-amber', 'Complete': 'badge-emerald', 'Pending': 'badge-blue', 'Pending Pickup': 'badge-blue', 'In Progress': 'badge-amber', 'Completed': 'badge-emerald', 'Pending Estimate': 'badge-slate' }
  return colors[status] || 'badge-slate'
}
