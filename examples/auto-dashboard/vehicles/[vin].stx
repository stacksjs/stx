@extends('../layouts/dashboard.stx')

@push('styles')
    .vehicle-hero { display: flex; gap: 2rem; flex-wrap: wrap; }
    .vehicle-hero-main { flex: 1; min-width: 300px; }
    .vehicle-hero-side { width: 280px; flex-shrink: 0; }
    .spec-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .spec-item { padding: 0.75rem; border-radius: 0.5rem; background: var(--bg-subtle); }
    .spec-label { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.25rem; }
    .spec-value { font-size: 0.9375rem; font-weight: 500; color: var(--text-primary); }
    .timeline-card { padding: 0.875rem; border-radius: 0.5rem; background: var(--bg-subtle); margin-bottom: 0.75rem; transition: background 0.15s ease; }
    .timeline-card:hover { background: var(--bg-subtle-hover); }
    @media (max-width: 768px) { .vehicle-hero-side { width: 100%; } .spec-grid { grid-template-columns: 1fr; } }
@endpush

@section('content')
      <div id="vehiclePage">
        {{-- Loading state replaced by JS --}}
        <div id="vehicleLoading" class="text-center py-20">
          <p style="color: var(--text-muted)">Loading vehicle data...</p>
        </div>
        <div id="vehicleContent" style="display: none;"></div>
        <div id="vehicleNotFound" style="display: none;" class="text-center py-20">
          <svg class="w-16 h-16 mx-auto mb-4" style="color: var(--text-muted)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
          <h2 class="text-xl font-semibold mb-2" style="color: var(--text-primary)">Vehicle Not Found</h2>
          <p class="text-sm mb-6" style="color: var(--text-muted)">The VIN you requested was not found in our database.</p>
          <a href="/vehicles" class="px-6 py-2.5 rounded-lg text-sm font-medium text-white" style="background: var(--btn-primary-bg); text-decoration: none;">Back to Vehicles</a>
        </div>
      </div>
@endsection

