      { id: 14, day: 2, startHour: 9, duration: 1, type: 'Drop-off', color: 'blue', customer: 'Michelle Wu', vehicle: '2021 BMW 330i', staff: 'Amy Nguyen', notes: 'Front-end collision major. Tow-in scheduled.', phone: '(212) 555-0443', email: 'm.wu@email.com', estimate: 'EST-4720' },
