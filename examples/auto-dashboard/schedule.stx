@push('styles')
    {{-- Calendar-specific styles --}}
    .cal-grid { display: grid; grid-template-columns: 64px repeat(7, 1fr); border: 1px solid var(--bg-glass-border); border-radius: 0.75rem; overflow: hidden; }
    .cal-header-cell { padding: 0.75rem 0.5rem; text-align: center; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--bg-glass-border); background: var(--bg-subtle); }
    .cal-header-cell.today { color: var(--text-accent); }
    .cal-time-label { padding: 0.25rem 0.5rem; font-size: 0.6875rem; font-weight: 500; color: var(--text-muted); text-align: right; border-right: 1px solid var(--bg-glass-border); border-bottom: 1px solid var(--bg-glass-border); height: 60px; display: flex; align-items: flex-start; justify-content: flex-end; }
    .cal-cell { position: relative; border-right: 1px solid var(--bg-glass-border); border-bottom: 1px solid var(--bg-glass-border); height: 60px; cursor: pointer; transition: background 0.15s; }
    .cal-cell:hover { background: var(--row-hover); }
    .cal-cell:last-child { border-right: none; }
    .cal-appt { position: absolute; left: 2px; right: 2px; border-radius: 4px; padding: 3px 6px; font-size: 0.6875rem; line-height: 1.3; overflow: hidden; cursor: pointer; z-index: 2; transition: opacity 0.15s, transform 0.15s; }
    .cal-appt:hover { opacity: 0.9; transform: scale(1.02); z-index: 3; }
    .cal-appt-blue { background: var(--badge-blue-bg); color: var(--badge-blue-text); border-left: 3px solid var(--bar-blue); }
    .cal-appt-amber { background: var(--badge-amber-bg); color: var(--badge-amber-text); border-left: 3px solid var(--bar-amber); }
    .cal-appt-emerald { background: var(--badge-emerald-bg); color: var(--badge-emerald-text); border-left: 3px solid var(--bar-emerald); }
    .cal-appt-violet { background: var(--badge-violet-bg); color: var(--badge-violet-text); border-left: 3px solid var(--bar-violet); }
    .cal-appt-red { background: var(--badge-red-bg); color: var(--badge-red-text); border-left: 3px solid var(--bar-red); }
    .cal-now-line { position: absolute; left: 0; right: 0; height: 2px; background: var(--bar-red); z-index: 4; pointer-events: none; }
    .cal-now-line::before { content: ''; position: absolute; left: -4px; top: -3px; width: 8px; height: 8px; border-radius: 50%; background: var(--bar-red); }
    .view-toggle-btn { padding: 0.375rem 0.875rem; border-radius: 0.5rem; font-size: 0.8125rem; font-weight: 500; border: 1px solid transparent; cursor: pointer; transition: all 0.2s; }
    .view-toggle-btn.active { background: var(--btn-primary-bg); color: #fff; border-color: var(--btn-primary-bg); }
    .view-toggle-btn:not(.active) { background: var(--bg-subtle); color: var(--text-tertiary); border-color: var(--border-input); }
    .view-toggle-btn:not(.active):hover { color: var(--text-primary); background: var(--bg-subtle-hover); }

    {{-- Day view styles --}}
    .day-grid { display: grid; grid-template-columns: 64px 1fr; border: 1px solid var(--bg-glass-border); border-radius: 0.75rem; overflow: hidden; }
    .day-time-label { padding: 0.125rem 0.5rem; font-size: 0.6875rem; font-weight: 500; color: var(--text-muted); text-align: right; border-right: 1px solid var(--bg-glass-border); border-bottom: 1px solid var(--bg-glass-border); height: 36px; display: flex; align-items: flex-start; justify-content: flex-end; }
    .day-cell { position: relative; border-bottom: 1px solid var(--bg-glass-border); height: 36px; cursor: pointer; transition: background 0.15s; }
    .day-cell:hover { background: var(--row-hover); }
    .day-appt { position: absolute; left: 2px; right: 2px; border-radius: 4px; padding: 4px 8px; font-size: 0.75rem; line-height: 1.3; overflow: hidden; cursor: pointer; z-index: 2; display: flex; align-items: center; gap: 0.5rem; }
    .day-appt:hover { opacity: 0.9; }

    .staff-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .staff-available { background: var(--bar-emerald); }
    .staff-busy { background: var(--bar-amber); }
    .staff-off { background: var(--bar-slate); }

    {{-- Month view styles --}}
    .month-grid { display: grid; grid-template-columns: repeat(7, 1fr); border: 1px solid var(--bg-glass-border); border-radius: 0.75rem; overflow: hidden; }
    .month-header-cell { padding: 0.625rem 0.5rem; text-align: center; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--bg-glass-border); background: var(--bg-subtle); }
    .month-day-cell { min-height: 100px; padding: 0.5rem; border-right: 1px solid var(--bg-glass-border); border-bottom: 1px solid var(--bg-glass-border); cursor: pointer; transition: background 0.15s; position: relative; }
    .month-day-cell:nth-child(7n) { border-right: none; }
    .month-day-cell:hover { background: var(--row-hover); }
    .month-day-cell.month-today { border: 2px solid var(--text-accent); border-radius: 2px; }
    .month-day-cell.month-weekend { background: var(--bg-subtle); }
    .month-day-cell.month-weekend:hover { background: var(--bg-subtle-hover); }
    .month-day-cell.month-empty { background: var(--bg-subtle); opacity: 0.4; cursor: default; }
    .month-day-num { font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.375rem; display: flex; align-items: center; gap: 0.375rem; }
    .month-appt-count { display: inline-flex; align-items: center; justify-content: center; min-width: 18px; height: 18px; border-radius: 9px; font-size: 0.625rem; font-weight: 600; padding: 0 4px; }
    .month-appt-item { font-size: 0.625rem; line-height: 1.3; padding: 2px 5px; border-radius: 3px; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .month-appt-item.type-drop { background: var(--badge-blue-bg); color: var(--badge-blue-text); }
    .month-appt-item.type-estimate { background: var(--badge-amber-bg); color: var(--badge-amber-text); }
    .month-appt-item.type-pickup { background: var(--badge-emerald-bg); color: var(--badge-emerald-text); }
    .month-appt-item.type-follow { background: var(--badge-violet-bg); color: var(--badge-violet-text); }
    .month-appt-item.type-insurance { background: var(--badge-red-bg); color: var(--badge-red-text); }
    .month-more { font-size: 0.625rem; color: var(--text-muted); padding-top: 1px; }
@endpush

