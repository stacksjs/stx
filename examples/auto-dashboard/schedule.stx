      { id: 21, day: 4, startHour: 9, duration: 1, type: 'Drop-off', color: 'blue', customer: 'Emily Tran', vehicle: '2024 Subaru Outback', staff: 'Amy Nguyen', notes: 'Deer strike front-end. Airbags did not deploy.', phone: '(802) 555-0412', email: 'e.tran@email.com', estimate: 'EST-4845' },
      { id: 22, day: 4, startHour: 11, duration: 1, type: 'Pickup', color: 'emerald', customer: 'David Martinez', vehicle: '2023 Nissan Altima', staff: 'Carlos Reyes', notes: 'Front bumper and hood repair complete. Ready for pickup.', phone: '(602) 555-0278', email: 'd.martinez@email.com', estimate: 'EST-4742' },
      { id: 23, day: 4, startHour: 13, duration: 1, type: 'Estimate Appointment', color: 'amber', customer: 'Rachel Foster', vehicle: '2025 Volvo XC60', staff: 'Sarah Mitchell', notes: 'Side swipe damage on driver side. Premium paint match required.', phone: '(312) 555-0189', email: 'r.foster@email.com', estimate: 'EST-4848' },
      { id: 24, day: 4, startHour: 15, duration: 1, type: 'Follow-up', color: 'violet', customer: 'James Rodriguez', vehicle: '2024 Tesla Model Y', staff: 'Jake Wilson', notes: 'Mid-repair update call. Parts ETA discussion.', phone: '(512) 555-0174', email: 'j.rodriguez@email.com', estimate: 'EST-4821' },

      { id: 25, day: 5, startHour: 9, duration: 1, type: 'Drop-off', color: 'blue', customer: 'Brian Kowalski', vehicle: '2023 GMC Sierra', staff: 'Amy Nguyen', notes: 'Tailgate damage from backing incident.', phone: '(414) 555-0276', email: 'b.kowalski@email.com', estimate: 'EST-4850' },
      { id: 26, day: 5, startHour: 11, duration: 1, type: 'Estimate Appointment', color: 'amber', customer: 'Linda Park', vehicle: '2022 Lexus RX 350', staff: 'Mike Torres', notes: 'Bumper and grille damage. Walk-in estimate.', phone: '(408) 555-0321', email: 'l.park@email.com', estimate: 'EST-4852' },
    ]

    // Staff schedule data
    var staffSchedule = [
      { name: 'Mike Torres', initials: 'MT', role: 'Lead Estimator', status: 'busy', note: 'In estimate — until 11 AM' },
      { name: 'Sarah Mitchell', initials: 'SM', role: 'Senior Estimator', status: 'available', note: 'Available' },
      { name: 'Jake Wilson', initials: 'JW', role: 'Technician', status: 'busy', note: 'Follow-up calls — until 12 PM' },
      { name: 'Amy Nguyen', initials: 'AN', role: 'Service Advisor', status: 'available', note: 'Available' },
      { name: 'Carlos Reyes', initials: 'CR', role: 'Detailer', status: 'busy', note: 'Vehicle prep — until 2 PM' },
    ]

    // Render appointments on the week calendar
    function renderWeekCalendar() {
      // Clear existing appointments
      var cells = document.querySelectorAll('.cal-cell')
      cells.forEach(function(cell) {
        var existing = cell.querySelectorAll('.cal-appt')
        existing.forEach(function(a) { a.remove() })
      })

      appointments.forEach(function(appt) {
        var cell = document.querySelector('.cal-cell[data-day="' + appt.day + '"][data-hour="' + appt.startHour + '"]')
        if (!cell) return
        var el = document.createElement('div')
        el.className = 'cal-appt cal-appt-' + appt.color
        el.style.top = '1px'
        el.style.height = (appt.duration * 60 - 4) + 'px'
        el.innerHTML = '<div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + appt.customer.split(' ')[0] + '</div><div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;opacity:0.8">' + appt.type + '</div>'
        el.onclick = function(e) {
          e.stopPropagation()
          openAppointmentDetail(appt)
        }
        cell.appendChild(el)
      })
    }

    // Render today's schedule sidebar
    function renderTodaySchedule() {
      var list = document.getElementById('todayScheduleList')
      var todayAppts = appointments.filter(function(a) { return a.day === 0 })
      todayAppts.sort(function(a, b) { return a.startHour - b.startHour })
      var html = ''
      todayAppts.forEach(function(appt) {
        var timeStr = formatHour(appt.startHour) + ' – ' + formatHour(appt.startHour + appt.duration)
        html += '<div class="flex items-center gap-3 p-2 rounded-lg cursor-pointer" style="background: var(--bg-subtle)" onclick="openAppointmentDetail(appointments.find(function(a){return a.id===' + appt.id + '}))">'
        html += '<div class="w-1 h-8 rounded-full" style="background: var(--bar-' + appt.color + ')"></div>'
        html += '<div class="flex-1 min-w-0">'
        html += '<p class="text-xs font-medium truncate" style="color: var(--text-primary)">' + appt.customer + '</p>'
        html += '<p class="text-xs" style="color: var(--text-muted)">' + timeStr + ' — ' + appt.type + '</p>'
        html += '</div></div>'
      })
      list.innerHTML = html
    }

    // Render staff availability sidebar
    function renderStaffList() {
      var list = document.getElementById('staffList')
      var html = ''
      staffSchedule.forEach(function(s) {
        var dotClass = s.status === 'available' ? 'staff-available' : s.status === 'busy' ? 'staff-busy' : 'staff-off'
        html += '<div class="flex items-center gap-3">'
        html += '<div class="w-7 h-7 rounded-full bg-gradient-to-br from-blue-400 to-violet-500 flex items-center justify-center text-[10px] font-semibold text-white flex-shrink-0">' + s.initials + '</div>'
        html += '<div class="flex-1 min-w-0">'
        html += '<p class="text-sm font-medium truncate" style="color: var(--text-primary)">' + s.name + '</p>'
        html += '<p class="text-xs" style="color: var(--text-muted)">' + s.note + '</p>'
        html += '</div>'
        html += '<div class="staff-dot ' + dotClass + '"></div>'
        html += '</div>'
      })
      list.innerHTML = html
    }

    // Render the day view (30-minute granularity)
    function renderDayView() {
      var grid = document.getElementById('dayGrid')
      var html = ''
      var todayAppts = appointments.filter(function(a) { return a.day === 0 })

      // Header
      html += '<div class="cal-header-cell" style="border-right: 1px solid var(--bg-glass-border)">Time</div>'
      html += '<div class="cal-header-cell today">Monday, March 9</div>'

      // 30-minute slots from 7:00 AM to 6:00 PM
      for (var h = 7; h <= 18; h++) {
        for (var m = 0; m < 2; m++) {
          var minutes = m * 30
          var label = (m === 0) ? formatHour(h) : ''
          html += '<div class="day-time-label" style="' + (m === 1 ? 'border-bottom-style:dashed;' : '') + '">' + label + '</div>'
          html += '<div class="day-cell" data-day-hour="' + h + '" data-day-min="' + minutes + '" onclick="onDayCellClick(' + h + ',' + minutes + ')" style="' + (m === 1 ? 'border-bottom-style:dashed;' : '') + '">'

          // Check if an appointment starts at this slot
          if (m === 0) {
            var appt = todayAppts.find(function(a) { return a.startHour === h })
            if (appt) {
              html += '<div class="day-appt cal-appt-' + appt.color + '" style="height:' + (appt.duration * 72 - 4) + 'px;z-index:2" onclick="event.stopPropagation();openAppointmentDetail(appointments.find(function(a){return a.id===' + appt.id + '}))">'
              html += '<div class="w-1 h-full rounded-full flex-shrink-0" style="background: var(--bar-' + appt.color + ')"></div>'
              html += '<div class="flex-1 min-w-0">'
              html += '<span class="font-semibold">' + appt.customer + '</span>'
              html += '<span style="opacity:0.7;margin-left:0.5rem">' + formatHour(appt.startHour) + ' – ' + formatHour(appt.startHour + appt.duration) + '</span>'
              html += '<span style="opacity:0.7;margin-left:0.5rem">' + appt.vehicle + '</span>'
              html += '</div></div>'
            }
          }
          html += '</div>'
        }
      }
      grid.innerHTML = html
    }

    // Format hour number to display string
    function formatHour(h) {
      if (h === 0 || h === 24) return '12:00 AM'
      if (h === 12) return '12:00 PM'
      if (h < 12) return h + ':00 AM'
      return (h - 12) + ':00 PM'
    }

    // View switching (signal)
    var currentView = state('week')
    effect(function() {
      var view = currentView()
      document.getElementById('btnDay').classList.toggle('active', view === 'day')
      document.getElementById('btnWeek').classList.toggle('active', view === 'week')
      document.getElementById('btnMonth').classList.toggle('active', view === 'month')
      document.getElementById('weekView').style.display = view === 'week' ? '' : 'none'
      document.getElementById('dayView').style.display = view === 'day' ? '' : 'none'
      document.getElementById('monthView').style.display = view === 'month' ? '' : 'none'
      if (view === 'month') {
        renderMonthApptSamples()
      }
    })
    function switchView(view) {
      currentView.set(view)
    }

    // Week navigation
    function navigateWeek(dir) {
      if (dir === -1) {
        showToast('Showing previous week: Mar 2 – 8, 2026', 'info')
      } else {
        showToast('Showing next week: Mar 16 – 22, 2026', 'info')
      }
    }

    // Cell click handlers
    function onCellClick(day, hour) {
      openNewAppointmentForm(day, hour)
    }
    function onDayCellClick(hour, minutes) {
      openNewAppointmentForm(0, hour)
    }

    // Open appointment detail slide-over
    function openAppointmentDetail(appt) {
      if (!appt) return
      var dayNames = ['Monday, Mar 9', 'Tuesday, Mar 10', 'Wednesday, Mar 11', 'Thursday, Mar 12', 'Friday, Mar 13', 'Saturday, Mar 14', 'Sunday, Mar 15']
      var timeStr = formatHour(appt.startHour) + ' – ' + formatHour(appt.startHour + appt.duration)
      var badgeClass = 'badge-' + appt.color

      var html = ''
      html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid var(--border-main)">'
      html += '<div>'
      html += '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">' + appt.customer + '</h2>'
      html += '<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium ' + badgeClass + '" style="margin-top:0.5rem">' + appt.type + '</span>'
      html += '</div>'
      html += '<button onclick="closeSlideOver()" style="padding:0.5rem;border-radius:0.5rem;color:var(--text-muted);background:none;border:none;cursor:pointer" aria-label="Close">'
      html += '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
      html += '</button></div>'

      html += '<div class="detail-section">'
      html += '<div class="detail-label">Appointment Details</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Date</span><span class="detail-row-value">' + dayNames[appt.day] + ', 2026</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Time</span><span class="detail-row-value">' + timeStr + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Type</span><span class="detail-row-value">' + appt.type + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Assigned To</span><span class="detail-row-value">' + appt.staff + '</span></div>'
      html += '</div>'

      html += '<div class="detail-section">'
      html += '<div class="detail-label">Vehicle</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Vehicle</span><span class="detail-row-value">' + appt.vehicle + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Estimate</span><span class="detail-row-value" style="color:var(--text-accent)">' + appt.estimate + '</span></div>'
      html += '</div>'

      html += '<div class="detail-section">'
      html += '<div class="detail-label">Customer Contact</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Phone</span><span class="detail-row-value">' + appt.phone + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Email</span><span class="detail-row-value" style="color:var(--text-accent)">' + appt.email + '</span></div>'
      html += '</div>'

      html += '<div class="detail-section">'
      html += '<div class="detail-label">Notes</div>'
      html += '<p style="font-size:0.875rem;color:var(--text-secondary);line-height:1.6">' + appt.notes + '</p>'
      html += '</div>'

      html += '<div class="detail-section" style="display:flex;gap:0.75rem;flex-wrap:wrap">'
      html += '<button onclick="showToast(\'Opening estimate ' + appt.estimate + '...\', \'success\'); closeSlideOver();" style="flex:1;min-width:140px;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">View Estimate</button>'
      html += '<button onclick="showToast(\'Sending reminder to ' + appt.customer + '...\', \'info\'); closeSlideOver();" style="flex:1;min-width:140px;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:var(--btn-action-text);background:var(--btn-action-bg);border:1px solid var(--btn-action-border);cursor:pointer">Send Reminder</button>'
      html += '<button onclick="showToast(\'Appointment cancelled\', \'warn\'); closeSlideOver();" style="flex:1;min-width:140px;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:var(--badge-red-text);background:var(--badge-red-bg);border:1px solid rgba(239,68,68,0.3);cursor:pointer">Cancel</button>'
      html += '</div>'

      openSlideOver(html)
    }

    // New appointment form
    function openNewAppointmentForm(day, hour) {
      var dayNames = ['Monday, Mar 9', 'Tuesday, Mar 10', 'Wednesday, Mar 11', 'Thursday, Mar 12', 'Friday, Mar 13', 'Saturday, Mar 14', 'Sunday, Mar 15']
      var preDay = (typeof day === 'number') ? day : ''
      var preHour = (typeof hour === 'number') ? hour : ''

      var html = ''
      html += '<div class="detail-section" style="display:flex;align-items:center;justify-content:space-between">'
      html += '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">New Appointment</h2>'
      html += '<button onclick="closeSlideOver()" style="color:var(--text-muted);font-size:1.5rem;background:none;border:none;cursor:pointer;line-height:1">&times;</button></div>'

      // Customer
      html += '<div class="detail-section"><div class="detail-label">Customer</div>'
      html += apptField('Customer Name', 'apptCustomer', 'text', 'Search customer...')
      html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">'
      html += apptField('Phone', 'apptPhone', 'tel', '(555) 555-0000')
      html += apptField('Email', 'apptEmail', 'email', 'customer@email.com')
      html += '</div></div>'

      // Vehicle
      html += '<div class="detail-section"><div class="detail-label">Vehicle</div>'
      html += apptField('Vehicle', 'apptVehicle', 'text', '2024 Tesla Model Y')
      html += apptField('Estimate #', 'apptEstimate', 'text', 'EST-XXXX (optional)')
      html += '</div>'

      // Scheduling
      html += '<div class="detail-section"><div class="detail-label">Scheduling</div>'
      html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">'
      html += '<div style="margin-bottom:0.75rem"><label style="display:block;font-size:0.75rem;font-weight:500;color:var(--text-muted);margin-bottom:0.25rem">Date</label>'
      html += '<select id="apptDay" style="width:100%;padding:0.5rem;padding-left:0.75rem;padding-right:2rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem">'
      for (var i = 0; i < dayNames.length; i++) {
        html += '<option value="' + i + '"' + (i === preDay ? ' selected' : '') + '>' + dayNames[i] + '</option>'
      }
      html += '</select></div>'

      html += '<div style="margin-bottom:0.75rem"><label style="display:block;font-size:0.75rem;font-weight:500;color:var(--text-muted);margin-bottom:0.25rem">Time</label>'
      html += '<select id="apptHour" style="width:100%;padding:0.5rem;padding-left:0.75rem;padding-right:2rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem">'
      for (var t = 7; t <= 17; t++) {
        html += '<option value="' + t + '"' + (t === preHour ? ' selected' : '') + '>' + formatHour(t) + '</option>'
      }
      html += '</select></div>'
      html += '</div>'

      html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">'
      html += '<div style="margin-bottom:0.75rem"><label style="display:block;font-size:0.75rem;font-weight:500;color:var(--text-muted);margin-bottom:0.25rem">Type</label>'
      html += '<select id="apptType" style="width:100%;padding:0.5rem;padding-left:0.75rem;padding-right:2rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem">'
      html += '<option value="Drop-off">Drop-off</option>'
      html += '<option value="Estimate Appointment">Estimate Appointment</option>'
      html += '<option value="Pickup">Pickup</option>'
      html += '<option value="Follow-up">Follow-up</option>'
      html += '<option value="Insurance Inspection">Insurance Inspection</option>'
      html += '</select></div>'

      html += '<div style="margin-bottom:0.75rem"><label style="display:block;font-size:0.75rem;font-weight:500;color:var(--text-muted);margin-bottom:0.25rem">Assigned Staff</label>'
      html += '<select id="apptStaff" style="width:100%;padding:0.5rem;padding-left:0.75rem;padding-right:2rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem">'
      html += '<option value="Mike Torres">Mike Torres</option>'
      html += '<option value="Sarah Mitchell">Sarah Mitchell</option>'
      html += '<option value="Jake Wilson">Jake Wilson</option>'
      html += '<option value="Amy Nguyen">Amy Nguyen</option>'
      html += '<option value="Carlos Reyes">Carlos Reyes</option>'
      html += '</select></div>'
      html += '</div></div>'

      // Notes
      html += '<div class="detail-section"><div class="detail-label">Notes</div>'
      html += '<textarea id="apptNotes" rows="3" placeholder="Additional details..." style="width:100%;padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem;resize:vertical;font-family:inherit"></textarea></div>'

      // Actions
      html += '<div class="detail-section" style="display:flex;gap:0.75rem">'
      html += '<button onclick="closeSlideOver()" style="flex:1;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;background:var(--bg-subtle);border:1px solid var(--border-input);color:var(--text-tertiary);cursor:pointer">Cancel</button>'
      html += '<button onclick="submitNewAppointment()" style="flex:1;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Create Appointment</button>'
      html += '</div>'

      openSlideOver(html)
    }

    function apptField(label, id, type, placeholder) {
      return '<div style="margin-bottom:0.75rem"><label style="display:block;font-size:0.75rem;font-weight:500;color:var(--text-muted);margin-bottom:0.25rem">' + label + '</label><input id="' + id + '" type="' + type + '" placeholder="' + placeholder + '" style="width:100%;padding:0.5rem 0.75rem;border-radius:0.5rem;border:1px solid var(--border-input);background:var(--bg-subtle);color:var(--text-primary);font-size:0.875rem" /></div>'
    }

    function submitNewAppointment() {
      var customer = document.getElementById('apptCustomer')
      var vehicle = document.getElementById('apptVehicle')
      if (!customer || !customer.value || !vehicle || !vehicle.value) {
        showToast('Please fill in customer name and vehicle', 'warn')
        return
      }
      var typeEl = document.getElementById('apptType')
      var hourEl = document.getElementById('apptHour')
      var dayEl = document.getElementById('apptDay')
      var staffEl = document.getElementById('apptStaff')
      var typeColors = { 'Drop-off': 'blue', 'Estimate Appointment': 'amber', 'Pickup': 'emerald', 'Follow-up': 'violet', 'Insurance Inspection': 'red' }
      var newAppt = {
        id: appointments.length + 1,
        day: parseInt(dayEl.value),
        startHour: parseInt(hourEl.value),
        duration: 1,
        type: typeEl.value,
        color: typeColors[typeEl.value] || 'blue',
        customer: customer.value,
        vehicle: vehicle.value,
        staff: staffEl.value,
        notes: document.getElementById('apptNotes').value || '',
        phone: document.getElementById('apptPhone').value || '',
        email: document.getElementById('apptEmail').value || '',
        estimate: document.getElementById('apptEstimate').value || 'N/A'
      }
      appointments.push(newAppt)
      renderWeekCalendar()
      renderTodaySchedule()
      renderDayView()
      showToast('Appointment created for ' + customer.value, 'success')
      closeSlideOver()
    }

    // Month view: render appointment samples into day cells
    var monthApptSamples = {
      2: ['Drop-off: Rivera', 'Estimate: Park'],
      3: ['Drop-off: Adams', 'Estimate: Bell', 'Follow-up: Scott'],
      4: ['Estimate: Young', 'Insurance: Allstate'],
      5: ['Drop-off: Harris', 'Pickup: Turner', 'Estimate: White'],
      6: ['Follow-up: Clark', 'Drop-off: Lewis'],
      7: ['Estimate: Walker', 'Pickup: Hall'],
      9: ['Drop-off: Watts', 'Estimate: Chen', 'Insurance: StateFarm'],
      10: ['Drop-off: Thompson', 'Estimate: Liu', 'Insurance: GEICO'],
      11: ['Drop-off: Wu', 'Estimate: Mendoza', 'Pickup: Kim'],
      12: ['Drop-off: Owens', 'Estimate: Reed', 'Insurance: Progressive'],
      13: ['Drop-off: Tran', 'Pickup: Martinez', 'Estimate: Foster'],
      14: ['Drop-off: Kowalski', 'Estimate: Park'],
      15: ['Follow-up: Rodriguez'],
      16: ['Drop-off: Nguyen', 'Estimate: Baker', 'Insurance: USAA'],
      17: ['Drop-off: Garcia', 'Estimate: Moore'],
      18: ['Estimate: Taylor', 'Pickup: Anderson', 'Follow-up: Thomas'],
      19: ['Drop-off: Jackson', 'Estimate: White'],
      20: ['Pickup: Harris', 'Follow-up: Clark'],
      21: ['Estimate: King'],
      23: ['Drop-off: Wright', 'Estimate: Lopez', 'Insurance: Farmers'],
      24: ['Drop-off: Hill', 'Estimate: Scott'],
      25: ['Estimate: Green', 'Pickup: Adams', 'Follow-up: Bell'],
      26: ['Drop-off: Nelson', 'Insurance: Liberty'],
      27: ['Estimate: Carter', 'Follow-up: Mitchell'],
      28: ['Pickup: Perez', 'Drop-off: Roberts']
    }

    function getApptTypeClass(label) {
      if (label.indexOf('Drop-off') === 0) return 'type-drop'
      if (label.indexOf('Estimate') === 0) return 'type-estimate'
      if (label.indexOf('Pickup') === 0) return 'type-pickup'
      if (label.indexOf('Follow-up') === 0) return 'type-follow'
      if (label.indexOf('Insurance') === 0) return 'type-insurance'
      return 'type-drop'
    }

    function renderMonthApptSamples() {
      for (var day = 1; day <= 31; day++) {
        var container = document.getElementById('monthDayAppts' + day)
        if (!container) continue
        var samples = monthApptSamples[day]
        if (!samples || samples.length === 0) {
          container.innerHTML = ''
          continue
        }
        var html = ''
        var show = Math.min(samples.length, 2)
        for (var i = 0; i < show; i++) {
          html += '<div class="month-appt-item ' + getApptTypeClass(samples[i]) + '">' + samples[i] + '</div>'
        }
        if (samples.length > 2) {
          html += '<div class="month-more">+' + (samples.length - 2) + ' more</div>'
        }
        container.innerHTML = html
      }
    }

    // Month day click handler
    function onMonthDayClick(day) {
      // For days 9-15 (the current week), switch to day view
      if (day >= 9 && day <= 15) {
        // Map month day to weekday index (9=Mon=0, 10=Tue=1, etc.)
        var dayIndex = day - 9
        switchView('day')
        // Update the day view header to show the selected day
        var dayViewHeader = document.querySelector('#dayView h2')
        var dayFullNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']
        if (dayViewHeader) {
          dayViewHeader.textContent = dayFullNames[dayIndex] + ', March ' + day + ', 2026'
        }
        showToast('Showing appointments for March ' + day, 'info')
      } else {
        var samples = monthApptSamples[day]
        if (samples && samples.length > 0) {
          showToast('March ' + day + ': ' + samples.length + ' appointment' + (samples.length > 1 ? 's' : ''), 'info')
        } else {
          showToast('No appointments on March ' + day, 'info')
        }
      }
    }

    // Initialize all views
    renderWeekCalendar()
    renderTodaySchedule()
    renderStaffList()
    renderDayView()
</script>
