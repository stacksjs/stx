                <span class="text-xs ml-2" style="color: var(--text-muted)">{{ insurer.phone }}</span>
              </div>
            </div>

            {{-- Stats 2x2 Grid --}}
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div class="rounded-lg p-3" style="background: var(--bg-subtle)">
                <p class="text-[11px] uppercase tracking-wider mb-1" style="color: var(--text-muted)">Estimates</p>
                <p class="text-sm font-semibold tabular-nums" style="color: var(--text-primary)">{{ insurer.estimates }}</p>
              </div>
              <div class="rounded-lg p-3" style="background: var(--bg-subtle)">
                <p class="text-[11px] uppercase tracking-wider mb-1" style="color: var(--text-muted)">Revenue</p>
                <p class="text-sm font-semibold tabular-nums" style="color: var(--text-revenue)">{{ insurer.revenue }}</p>
              </div>
              <div class="rounded-lg p-3" style="background: var(--bg-subtle)">
                <p class="text-[11px] uppercase tracking-wider mb-1" style="color: var(--text-muted)">Avg Cycle</p>
                <p class="text-sm font-semibold tabular-nums" style="color: var(--text-primary)">{{ insurer.avgCycle }} days</p>
              </div>
              <div class="rounded-lg p-3" style="background: var(--bg-subtle)">
                <p class="text-[11px] uppercase tracking-wider mb-1" style="color: var(--text-muted)">Supplement Rate</p>
                <p class="text-sm font-semibold tabular-nums" style="color: var(--text-primary)">{{ insurer.supplementRate }}%</p>
              </div>
            </div>

            {{-- CSI Score Bar --}}
            <div class="mb-4 csi-bar-wrapper">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-xs font-medium" style="color: var(--text-tertiary)">CSI Score</span>
                <span class="text-xs font-semibold tabular-nums" style="color: var(--text-primary)">{{ insurer.csi }}%</span>
              </div>
              <div class="h-2 rounded-full overflow-hidden" style="background: var(--bar-track)">
                <div class="h-full rounded-full bar-animate" style="width: {{ insurer.csi }}%; background: {{ csiBarColor(insurer.csi) }}"></div>
              </div>
            </div>

            {{-- View Details Link + Manage DRP --}}
            <div class="flex items-center gap-3">
              <button onclick="openInsurerDetail('{{ insurer.name }}')" class="text-xs font-medium inline-flex items-center gap-1 bg-transparent border-none cursor-pointer p-0" style="color: var(--text-accent)">View Details <span>&rarr;</span></button>
              @if (insurer.drpStatus === 'Active DRP')
                <button onclick="event.stopPropagation(); openDrpManagement('{{ insurer.name }}')" class="text-xs font-medium inline-flex items-center gap-1 px-2.5 py-1 rounded-lg cursor-pointer" style="background: var(--btn-action-bg); border: 1px solid var(--btn-action-border); color: var(--btn-action-text)">Manage DRP</button>
              @endif
            </div>
          </div>
        @endforeach
      </div>

      {{-- No Results Message --}}
      <div id="noResults" class="hidden text-center py-12">
        <svg class="w-12 h-12 mx-auto mb-3" style="color: var(--text-muted)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
        <p class="text-sm font-medium" style="color: var(--text-tertiary)">No insurers match your search</p>
        <p class="text-xs mt-1" style="color: var(--text-muted)">Try a different search term or filter</p>
      </div>
@endsection

