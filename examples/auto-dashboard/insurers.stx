          { id: 'EST-4796', vehicle: '2022 Toyota Tacoma', date: 'Feb 28, 2026', total: '$7,650', status: 'Approved' },
          { id: 'EST-4783', vehicle: '2021 Nissan Rogue', date: 'Feb 24, 2026', total: '$4,280', status: 'Supplement' }
        ]
      },
      'Nationwide': {
        since: 2023, drpTier: 'Bronze', region: 'Nationwide', manager: 'Lisa Navarro',
        contacts: [
          { name: 'Karen Brown', title: 'Primary Adjuster', phone: '(555) 901-2345', email: 'kbrown@nationwide.com', color: 'from-slate-400 to-gray-500' },
          { name: 'Steven Clark', title: 'Regional Manager', phone: '(555) 901-2347', email: 'sclark@nationwide.com', color: 'from-amber-400 to-yellow-500' }
        ],
        metrics: { estimates: 35, revenue: '$18,400', cycle: '4.1', supplement: '26.5', approval: 78, csi: 85, estTrend: '+1%', revTrend: '+3%', cycleTrend: '+0.2' },
        agreement: { labor: '$44/hr', paint: '$48/hr', parts: 'Aftermarket Allowed', photos: '8 minimum', suppThreshold: '$500', payment: 'Net 30' },
        recentEstimates: [
          { id: 'EST-4808', vehicle: '2022 Hyundai Sonata', date: 'Mar 3, 2026', total: '$3,940', status: 'In Review' },
          { id: 'EST-4790', vehicle: '2021 Kia Sportage', date: 'Feb 27, 2026', total: '$5,210', status: 'Approved' },
          { id: 'EST-4778', vehicle: '2023 Subaru Forester', date: 'Feb 22, 2026', total: '$4,680', status: 'Supplement' }
        ]
      }
    }

    function getInitials(name) {
      return name.split(' ').map(function(w) { return w[0] }).join('').toUpperCase()
    }

    function csiBarColorClient(csi) {
      if (csi >= 95) return 'var(--bar-emerald)'
      if (csi >= 90) return 'var(--bar-blue)'
      if (csi >= 85) return 'var(--bar-amber)'
      return 'var(--bar-red)'
    }

    function drpBadgeClassClient(status) {
      var classes = { 'Active DRP': 'badge-emerald', 'Preferred': 'badge-blue', 'Standard': 'badge-slate' }
      return classes[status] || 'badge-slate'
    }

    function statusBadgeClass(status) {
      var classes = { 'Approved': 'badge-emerald', 'In Review': 'badge-amber', 'Supplement': 'badge-blue', 'Denied': 'badge-red' }
      return classes[status] || 'badge-slate'
    }

    function trendClass(val) {
      if (!val) return ''
      return val.indexOf('-') === 0 && val.indexOf('days') === -1
        ? (val.indexOf('+') === -1 ? 'trend-down' : 'trend-up')
        : (val.indexOf('+') === 0 ? 'trend-up' : 'trend-down')
    }

    function trendIcon(val) {
      if (!val) return ''
      var isUp = val.indexOf('+') === 0 || (val.indexOf('-') === 0 && val.indexOf('days') !== -1)
      // For cycle time, negative is good
      if (isUp) return '<svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>'
      return '<svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>'
    }

    function openInsurerDetail(name) {
      var d = insurerDetails[name]
      if (!d) return

      // Find base insurer data for drpStatus
      var drpStatusMap = {
        'State Farm': 'Active DRP', 'Progressive': 'Active DRP', 'GEICO': 'Preferred',
        'Allstate': 'Active DRP', 'USAA': 'Preferred', 'Liberty Mutual': 'Standard',
        'Farmers': 'Active DRP', 'Nationwide': 'Standard'
      }
      var drpStatus = drpStatusMap[name] || 'Standard'

      var html = ''

      // Header
      html += '<div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-main); display: flex; align-items: center; justify-content: space-between;">'
      html += '<div>'
      html += '<h2 id="slideOverTitle" style="font-size: 1.375rem; font-weight: 700; color: var(--text-primary); margin: 0;">' + name + '</h2>'
      html += '<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium ' + drpBadgeClassClient(drpStatus) + '" style="margin-top: 0.5rem; display: inline-flex;">' + drpStatus + '</span>'
      html += '</div>'
      html += '<button onclick="closeSlideOver()" style="padding: 0.5rem; border-radius: 0.5rem; border: none; cursor: pointer; background: var(--bg-subtle); color: var(--text-tertiary);" aria-label="Close panel">'
      html += '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
      html += '</button>'
      html += '</div>'

      // Overview section
      html += '<div class="detail-section">'
      html += '<div class="detail-label">OVERVIEW</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Relationship since</span><span class="detail-row-value">' + d.since + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">DRP tier</span><span class="detail-row-value">' + d.drpTier + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Region</span><span class="detail-row-value">' + d.region + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Account manager</span><span class="detail-row-value">' + d.manager + '</span></div>'
      html += '</div>'

      // Contacts section
      html += '<div class="detail-section">'
      html += '<div class="detail-label">CONTACTS</div>'
      html += '<div style="display: flex; flex-direction: column; gap: 0.625rem;">'
      for (var i = 0; i < d.contacts.length; i++) {
        var c = d.contacts[i]
        html += '<div class="contact-card" style="background: var(--bg-subtle); display: flex; align-items: center; gap: 0.75rem;">'
        html += '<div class="initials-avatar bg-gradient-to-br ' + c.color + '">' + getInitials(c.name) + '</div>'
        html += '<div style="flex: 1; min-width: 0;">'
        html += '<div style="font-size: 0.875rem; font-weight: 600; color: var(--text-primary);">' + c.name + '</div>'
        html += '<div style="font-size: 0.75rem; color: var(--text-muted);">' + c.title + '</div>'
        html += '<div style="font-size: 0.75rem; color: var(--text-tertiary); margin-top: 0.25rem;">' + c.phone
        if (c.email) html += ' &middot; ' + c.email
        html += '</div>'
        html += '</div>'
        html += '</div>'
      }
      html += '</div>'
      html += '</div>'

      // Performance metrics
      var m = d.metrics
      html += '<div class="detail-section">'
      html += '<div class="detail-label">PERFORMANCE METRICS</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Estimates this month</span><span class="detail-row-value">' + m.estimates + ' <span class="' + trendClass(m.estTrend) + '" style="font-size: 0.75rem; margin-left: 0.25rem; display: inline-flex; align-items: center; gap: 2px;">' + trendIcon(m.estTrend) + ' ' + m.estTrend + '</span></span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Revenue MTD</span><span class="detail-row-value">' + m.revenue + ' <span class="' + trendClass(m.revTrend) + '" style="font-size: 0.75rem; margin-left: 0.25rem; display: inline-flex; align-items: center; gap: 2px;">' + trendIcon(m.revTrend) + ' ' + m.revTrend + '</span></span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Average cycle time</span><span class="detail-row-value">' + m.cycle + ' days <span class="' + (m.cycleTrend.indexOf('-') === 0 ? 'trend-up' : 'trend-down') + '" style="font-size: 0.75rem; margin-left: 0.25rem; display: inline-flex; align-items: center; gap: 2px;">' + m.cycleTrend + ' days</span></span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Supplement rate</span><span class="detail-row-value">' + m.supplement + '%</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">First-time approval rate</span><span class="detail-row-value">' + m.approval + '%</span></div>'

      // CSI with colored bar
      html += '<div style="margin-top: 0.75rem;">'
      html += '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.375rem;">'
      html += '<span class="detail-row-label">CSI score</span>'
      html += '<span class="detail-row-value">' + m.csi + '%</span>'
      html += '</div>'
      html += '<div style="height: 8px; border-radius: 9999px; overflow: hidden; background: var(--bar-track);">'
      html += '<div style="height: 100%; border-radius: 9999px; width: ' + m.csi + '%; background: ' + csiBarColorClient(m.csi) + '; transition: width 0.8s ease;"></div>'
      html += '</div>'
      html += '</div>'
      html += '</div>'

      // DRP agreement
      var a = d.agreement
      html += '<div class="detail-section">'
      html += '<div class="detail-label">DRP AGREEMENT</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Labor rate</span><span class="detail-row-value">' + a.labor + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Paint rate</span><span class="detail-row-value">' + a.paint + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Parts sourcing</span><span class="detail-row-value">' + a.parts + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Photo requirements</span><span class="detail-row-value">' + a.photos + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Supplement threshold</span><span class="detail-row-value">' + a.suppThreshold + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Payment terms</span><span class="detail-row-value">' + a.payment + '</span></div>'
      html += '</div>'

      // Recent estimates table
      html += '<div class="detail-section">'
      html += '<div class="detail-label">RECENT ESTIMATES</div>'
      html += '<div style="overflow-x: auto;">'
      html += '<table class="estimate-table"><thead><tr><th>ID</th><th>Vehicle</th><th>Date</th><th>Total</th><th>Status</th></tr></thead><tbody>'
      for (var j = 0; j < d.recentEstimates.length; j++) {
        var e = d.recentEstimates[j]
        html += '<tr>'
        html += '<td style="font-weight: 500; color: var(--text-accent);">' + e.id + '</td>'
        html += '<td>' + e.vehicle + '</td>'
        html += '<td style="color: var(--text-muted); font-size: 0.75rem;">' + e.date + '</td>'
        html += '<td style="font-weight: 600; color: var(--text-primary);">' + e.total + '</td>'
        html += '<td><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium ' + statusBadgeClass(e.status) + '">' + e.status + '</span></td>'
        html += '</tr>'
      }
      html += '</tbody></table>'
      html += '</div>'
      html += '</div>'

      // Guidelines & Compliance section
      var guidelinesData = {
        'State Farm': { maxLabor: '$52/hr body, $56/hr frame, $48/hr paint', partsPolicy: 'OEM required for vehicles <3 years, aftermarket acceptable for older', reqDocs: '4+ photos required, pre/post scan mandatory', payTerms: 'Net 30, direct deposit available', suppProcess: 'Submit via portal, 24hr approval SLA', compliance: 94 },
        'Progressive': { maxLabor: '$50/hr body, $54/hr frame, $46/hr paint', partsPolicy: 'Aftermarket allowed for all; OEM upon request with justification', reqDocs: '4+ photos required, pre/post scan for ADAS vehicles', payTerms: 'Net 30, ACH or check', suppProcess: 'Submit via Mitchell, 48hr approval SLA', compliance: 91 },
        'GEICO': { maxLabor: '$48/hr body, $52/hr frame, $44/hr paint', partsPolicy: 'Aftermarket preferred; OEM for structural only', reqDocs: '6+ photos required, damage overview mandatory', payTerms: 'Net 30, check only', suppProcess: 'Submit via CCC ONE, 72hr approval SLA', compliance: 87 },
        'Allstate': { maxLabor: '$50/hr body, $54/hr frame, $46/hr paint', partsPolicy: 'OEM preferred for vehicles <5 years, aftermarket for older', reqDocs: '4+ photos required, pre/post scan mandatory', payTerms: 'Net 15, direct deposit available', suppProcess: 'Submit via portal, 24hr approval SLA', compliance: 95 },
        'USAA': { maxLabor: '$54/hr body, $58/hr frame, $50/hr paint', partsPolicy: 'OEM required for all repairs', reqDocs: '4+ photos required, pre/post scan mandatory, line notes detailed', payTerms: 'Net 15, direct deposit available', suppProcess: 'Submit via portal, 12hr approval SLA', compliance: 98 },
        'Liberty Mutual': { maxLabor: '$46/hr body, $50/hr frame, $42/hr paint', partsPolicy: 'Aftermarket required when available; OEM with prior approval', reqDocs: '8+ photos required, supplement photos mandatory', payTerms: 'Net 30, check only', suppProcess: 'Email submission, 72hr approval SLA', compliance: 82 },
        'Farmers': { maxLabor: '$48/hr body, $52/hr frame, $44/hr paint', partsPolicy: 'OEM preferred, aftermarket with customer consent', reqDocs: '4+ photos required, pre-scan recommended', payTerms: 'Net 30, ACH available', suppProcess: 'Submit via portal, 48hr approval SLA', compliance: 89 },
        'Nationwide': { maxLabor: '$44/hr body, $48/hr frame, $40/hr paint', partsPolicy: 'Aftermarket preferred for all; OEM with written justification', reqDocs: '8+ photos required, detailed damage notes', payTerms: 'Net 30, check only', suppProcess: 'Email submission, 96hr approval SLA', compliance: 78 }
      }
      var g = guidelinesData[name]
      if (g) {
        html += '<div class="detail-section">'
        html += '<div class="detail-label">GUIDELINES & COMPLIANCE</div>'
        html += '<div class="detail-row"><span class="detail-row-label">Max labor rate</span><span class="detail-row-value" style="text-align: right; max-width: 55%; font-size: 0.8125rem;">' + g.maxLabor + '</span></div>'
        html += '<div class="detail-row"><span class="detail-row-label">Parts preference</span><span class="detail-row-value" style="text-align: right; max-width: 55%; font-size: 0.8125rem;">' + g.partsPolicy + '</span></div>'
        html += '<div class="detail-row"><span class="detail-row-label">Required documentation</span><span class="detail-row-value" style="text-align: right; max-width: 55%; font-size: 0.8125rem;">' + g.reqDocs + '</span></div>'
        html += '<div class="detail-row"><span class="detail-row-label">Payment terms</span><span class="detail-row-value" style="font-size: 0.8125rem;">' + g.payTerms + '</span></div>'
        html += '<div class="detail-row"><span class="detail-row-label">Supplement process</span><span class="detail-row-value" style="text-align: right; max-width: 55%; font-size: 0.8125rem;">' + g.suppProcess + '</span></div>'
        html += '<div style="margin-top: 0.75rem;">'
        html += '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.375rem;">'
        html += '<span class="detail-row-label">Compliance this quarter</span>'
        html += '<span class="detail-row-value">' + g.compliance + '%</span>'
        html += '</div>'
        html += '<div style="height: 8px; border-radius: 9999px; overflow: hidden; background: var(--bar-track);">'
        html += '<div style="height: 100%; border-radius: 9999px; width: ' + g.compliance + '%; background: ' + (g.compliance >= 90 ? 'var(--bar-emerald)' : g.compliance >= 80 ? 'var(--bar-amber)' : 'var(--bar-red)') + '; transition: width 0.8s ease;"></div>'
        html += '</div>'
        html += '</div>'
        html += '</div>'
      }

      // Action buttons
      html += '<div class="detail-section" style="display: flex; flex-wrap: wrap; gap: 0.625rem;">'
      html += '<button class="detail-action-btn detail-action-primary" onclick="showToast(\'Message sent to ' + name + '\', \'success\'); closeSlideOver();">'
      html += '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>'
      html += 'Send Message</button>'
      html += '<button class="detail-action-btn detail-action-secondary" onclick="showToast(\'Exporting ' + name + ' performance report...\', \'info\'); closeSlideOver();">'
      html += '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>'
      html += 'Export Report</button>'
      html += '<button class="detail-action-btn detail-action-secondary" onclick="showToast(\'Opening agreement editor for ' + name + '\', \'info\'); closeSlideOver();">'
      html += '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>'
      html += 'Edit Agreement</button>'
      html += '<a href="/estimates" class="detail-action-btn detail-action-secondary" style="text-decoration: none;">'
      html += '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>'
      html += 'View All Estimates</a>'
      html += '</div>'

      openSlideOver(html)
    }

    // DRP Agreement Management
    function openDrpManagement(name) {
      var drpData = {
        'State Farm': { tier: 'Gold', renewed: '2025-06-15', expires: '2026-06-15', volumeReq: '25+ estimates/month', cycleReq: '<3.0 days avg cycle time', csiReq: '95%+ CSI score', suppReq: '<18% supplement rate', penalties: 'Tier downgrade after 2 consecutive quarters below targets', benefits: 'Priority assignment, higher labor rates, dedicated adjuster' },
        'Progressive': { tier: 'Gold', renewed: '2025-09-01', expires: '2026-09-01', volumeReq: '20+ estimates/month', cycleReq: '<3.5 days avg cycle time', csiReq: '92%+ CSI score', suppReq: '<20% supplement rate', penalties: 'Volume reduction after 1 quarter below targets', benefits: 'West Coast preferred shop, marketing co-op, quarterly bonuses' },
        'Allstate': { tier: 'Gold', renewed: '2025-04-01', expires: '2026-04-01', volumeReq: '15+ estimates/month', cycleReq: '<3.2 days avg cycle time', csiReq: '93%+ CSI score', suppReq: '<18% supplement rate', penalties: 'Agreement review after missed targets', benefits: 'Faster payment terms (Net 15), OEM parts approval, dedicated team' },
        'Farmers': { tier: 'Silver', renewed: '2025-11-01', expires: '2026-11-01', volumeReq: '10+ estimates/month', cycleReq: '<3.5 days avg cycle time', csiReq: '90%+ CSI score', suppReq: '<22% supplement rate', penalties: 'Standard tier revert after 2 missed quarters', benefits: 'Preferred referrals, streamlined supplement process' }
      }
      var dd = drpData[name]
      if (!dd) { showToast('No DRP agreement data for ' + name, 'warn'); return }

      var html = ''
      html += '<div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-main); display: flex; align-items: center; justify-content: space-between;">'
      html += '<div>'
      html += '<h2 style="font-size: 1.375rem; font-weight: 700; color: var(--text-primary); margin: 0;">DRP Agreement — ' + name + '</h2>'
      html += '<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium badge-emerald" style="margin-top: 0.5rem; display: inline-flex;">' + dd.tier + ' Tier</span>'
      html += '</div>'
      html += '<button onclick="closeSlideOver()" style="padding: 0.5rem; border-radius: 0.5rem; border: none; cursor: pointer; background: var(--bg-subtle); color: var(--text-tertiary);" aria-label="Close panel">'
      html += '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
      html += '</button></div>'

      html += '<div class="detail-section">'
      html += '<div class="detail-label">AGREEMENT TERMS</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Last renewed</span><span class="detail-row-value">' + dd.renewed + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Expires</span><span class="detail-row-value">' + dd.expires + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Benefits</span><span class="detail-row-value" style="text-align: right; max-width: 55%; font-size: 0.8125rem;">' + dd.benefits + '</span></div>'
      html += '</div>'

      html += '<div class="detail-section">'
      html += '<div class="detail-label">PERFORMANCE REQUIREMENTS</div>'
      html += '<div class="detail-row"><span class="detail-row-label">Volume requirement</span><span class="detail-row-value">' + dd.volumeReq + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Cycle time target</span><span class="detail-row-value">' + dd.cycleReq + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">CSI requirement</span><span class="detail-row-value">' + dd.csiReq + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Supplement target</span><span class="detail-row-value">' + dd.suppReq + '</span></div>'
      html += '<div class="detail-row"><span class="detail-row-label">Non-compliance</span><span class="detail-row-value" style="text-align: right; max-width: 55%; font-size: 0.8125rem;">' + dd.penalties + '</span></div>'
      html += '</div>'

      html += '<div class="detail-section" style="display: flex; flex-wrap: wrap; gap: 0.625rem;">'
      html += '<button class="detail-action-btn detail-action-primary" onclick="showToast(\'Initiating DRP renewal for ' + name + '...\', \'success\'); closeSlideOver();">Renew Agreement</button>'
      html += '<button class="detail-action-btn detail-action-secondary" onclick="showToast(\'Exporting DRP terms for ' + name + '...\', \'info\'); closeSlideOver();">Export Terms</button>'
      html += '</div>'

      openSlideOver(html)
    }

    // Search and filter
    function filterCards() {
      var query = (document.getElementById('searchInput').value || '').toLowerCase()
      var statusFilter = document.getElementById('statusFilter').value
      var cards = document.querySelectorAll('#insurerGrid .insurer-card')
      var visibleCount = 0

      for (var i = 0; i < cards.length; i++) {
        var name = (cards[i].getAttribute('data-name') || '').toLowerCase()
        var status = cards[i].getAttribute('data-status') || ''
        var matchesSearch = !query || name.indexOf(query) !== -1
        var matchesStatus = statusFilter === 'all' || status === statusFilter
        if (matchesSearch && matchesStatus) {
          cards[i].style.display = ''
          visibleCount++
        } else {
          cards[i].style.display = 'none'
        }
      }

      document.getElementById('noResults').style.display = visibleCount === 0 ? 'block' : 'none'
    }

    // Sort cards
    function sortCards() {
      var sortBy = document.getElementById('sortSelect').value
      var grid = document.getElementById('insurerGrid')
      var cards = Array.prototype.slice.call(grid.querySelectorAll('.insurer-card'))

      cards.sort(function(a, b) {
        if (sortBy === 'name') {
          return (a.getAttribute('data-name') || '').localeCompare(b.getAttribute('data-name') || '')
        }
        if (sortBy === 'estimates') {
          return parseInt(b.getAttribute('data-estimates') || 0) - parseInt(a.getAttribute('data-estimates') || 0)
        }
        if (sortBy === 'revenue') {
          var ra = parseInt((a.getAttribute('data-revenue') || '').replace(/[$,]/g, '')) || 0
          var rb = parseInt((b.getAttribute('data-revenue') || '').replace(/[$,]/g, '')) || 0
          return rb - ra
        }
        if (sortBy === 'cycle') {
          return parseFloat(a.getAttribute('data-cycle') || 0) - parseFloat(b.getAttribute('data-cycle') || 0)
        }
        if (sortBy === 'csi') {
          return parseInt(b.getAttribute('data-csi') || 0) - parseInt(a.getAttribute('data-csi') || 0)
        }
        return 0
      })

      for (var i = 0; i < cards.length; i++) {
        grid.appendChild(cards[i])
      }
    }
</script>
