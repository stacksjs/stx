function typeBadge(type) {
  const colors = { 'OEM': 'badge-blue', 'Aftermarket': 'badge-amber', 'Recycled': 'badge-emerald', 'Reman': 'badge-slate' }
  return colors[type] || 'badge-slate'
}

function availabilityColor(avail) {
  if (avail === 'In Stock') return 'color: var(--text-success)'
  if (avail === 'Backordered') return 'color: var(--badge-red-text)'
  return 'color: var(--badge-amber-text)'
}

function orderStatusBadge(status) {
  const colors = { 'Delivered': 'badge-emerald', 'Shipped': 'badge-blue', 'Processing': 'badge-amber' }
  return colors[status] || 'badge-slate'
}
