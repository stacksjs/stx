    // Filter parts
    function filterParts() {
      var query = document.getElementById('partSearch').value.toLowerCase().trim()
      var typeVal = document.getElementById('typeFilter').value
      var makeVal = document.getElementById('makeFilter').value
      var catVal = document.getElementById('categoryFilter').value
      var cards = document.querySelectorAll('#partsGrid .part-card')
      var visible = 0

      cards.forEach(function(card) {
        var name = (card.getAttribute('data-name') || '').toLowerCase()
        var oem = (card.getAttribute('data-oem') || '').toLowerCase()
        var type = card.getAttribute('data-type') || ''
        var make = card.getAttribute('data-make') || ''
        var category = card.getAttribute('data-category') || ''
        var show = true

        if (query && name.indexOf(query) === -1 && oem.indexOf(query) === -1) show = false
        if (typeVal && type !== typeVal) show = false
        if (makeVal && make !== makeVal) show = false
        if (catVal && category !== catVal) show = false

        card.style.display = show ? '' : 'none'
        if (show) visible++
      })

      var label = visible === 0 ? 'No results' : 'Showing ' + visible + ' parts'
      document.getElementById('partsShowingLabel').textContent = label
      document.getElementById('emptyState').style.display = visible === 0 ? '' : 'none'
    }

    function clearFilters() {
      document.getElementById('partSearch').value = ''
      document.getElementById('typeFilter').value = ''
      document.getElementById('makeFilter').value = ''
      document.getElementById('categoryFilter').value = ''
      filterParts()
    }

    // Add to estimate
    function addToEstimate(name, oem) {
      showToast(name + ' (' + oem + ') added to estimate', 'success')
    }

    // Open part detail slide-over
    function openPartDetail(idx) {
      var p = partsData[idx]
      if (!p) return

      var typeBadge = p.type === 'OEM' ? 'badge-blue' : p.type === 'Aftermarket' ? 'badge-amber' : p.type === 'Recycled' ? 'badge-emerald' : 'badge-slate'

      // Build suppliers table
      var suppliersHtml = ''
      p.allSuppliers.forEach(function(s) {
        var sBadge = s.type === 'OEM' ? 'badge-blue' : s.type === 'Aftermarket' ? 'badge-amber' : s.type === 'Recycled' ? 'badge-emerald' : 'badge-slate'
        suppliersHtml += '<div style="display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid var(--row-border)">'
        suppliersHtml += '<div>'
        suppliersHtml += '<span style="font-size:0.875rem;font-weight:500;color:var(--text-primary)">' + s.name + '</span>'
        suppliersHtml += '<span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium ' + sBadge + '" style="margin-left:0.5rem">' + s.type + '</span>'
        suppliersHtml += '<div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.125rem">' + s.delivery + ' — ' + s.stock + '</div>'
        suppliersHtml += '</div>'
        suppliersHtml += '<span style="font-size:0.875rem;font-weight:600;color:var(--text-primary)">' + s.price + '</span>'
        suppliersHtml += '</div>'
      })

      // Build price history
      var priceHtml = ''
      p.priceHistory.forEach(function(ph) {
        priceHtml += '<div style="display:flex;justify-content:space-between;padding:0.375rem 0">'
        priceHtml += '<span style="font-size:0.8125rem;color:var(--text-tertiary)">' + ph.date + '</span>'
        priceHtml += '<div style="display:flex;gap:1rem">'
        priceHtml += '<span style="font-size:0.8125rem;color:var(--badge-blue-text)">' + ph.oem + '</span>'
        priceHtml += '<span style="font-size:0.8125rem;color:var(--badge-amber-text)">' + ph.after + '</span>'
        priceHtml += '</div></div>'
      })

      // Build order history
      var orderHtml = ''
      if (p.orderHistory.length === 0) {
        orderHtml = '<p style="font-size:0.8125rem;color:var(--text-muted);text-align:center;padding:0.5rem 0">No previous orders</p>'
      } else {
        p.orderHistory.forEach(function(o) {
          orderHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:0.375rem 0">'
          orderHtml += '<div>'
          orderHtml += '<span style="font-size:0.8125rem;font-weight:500;color:var(--text-primary)">' + o.order + '</span>'
          orderHtml += '<span style="font-size:0.75rem;color:var(--text-muted);margin-left:0.75rem">' + o.date + '</span>'
          orderHtml += '</div>'
          orderHtml += '<div style="text-align:right">'
          orderHtml += '<span style="font-size:0.8125rem;color:var(--text-muted)">Qty ' + o.qty + '</span>'
          orderHtml += '<span style="font-size:0.8125rem;font-weight:500;color:var(--text-primary);margin-left:0.75rem">' + o.total + '</span>'
          orderHtml += '</div></div>'
        })
      }

      var html = ''
        + '<div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid var(--border-main)">'
        + '<div>'
        + '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">' + p.name + '</h2>'
        + '<div style="display:flex;align-items:center;gap:0.5rem;margin-top:0.5rem">'
        + '<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium ' + typeBadge + '">' + p.type + '</span>'
        + '<span style="font-size:0.75rem;font-family:monospace;color:var(--text-muted)">OEM# ' + p.oem + '</span>'
        + '</div>'
        + '</div>'
        + '<button onclick="closeSlideOver()" style="padding:0.5rem;border-radius:0.5rem;color:var(--text-muted);background:none;border:none;cursor:pointer" aria-label="Close">'
        + '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
        + '</button>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Part Information</div>'
        + '<div class="detail-row"><span class="detail-row-label">Category</span><span class="detail-row-value">' + p.category + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Compatible Vehicles</span><span class="detail-row-value">' + p.vehicles + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Weight</span><span class="detail-row-value">' + p.weight + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Material</span><span class="detail-row-value">' + p.material + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Color / Finish</span><span class="detail-row-value">' + p.color + '</span></div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Available Suppliers</div>'
        + suppliersHtml
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Price History <span style="font-size:0.625rem;font-weight:400;text-transform:none;letter-spacing:0">(OEM vs Aftermarket)</span></div>'
        + priceHtml
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Order History</div>'
        + orderHtml
        + '</div>'

        + '<div class="detail-section" style="display:flex;gap:0.75rem;flex-wrap:wrap">'
        + '<button onclick="addToEstimate(\'' + p.name.replace(/'/g, "\\'") + '\', \'' + p.oem + '\'); closeSlideOver();" style="flex:1;min-width:140px;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Add to Estimate</button>'
        + '<button onclick="showToast(\'Ordering ' + p.name.replace(/'/g, "\\'") + ' from ' + p.supplier.replace(/'/g, "\\'") + '...\', \'info\'); closeSlideOver();" style="flex:1;min-width:140px;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:var(--btn-action-text);background:var(--btn-action-bg);border:1px solid var(--btn-action-border);cursor:pointer">Order Part</button>'
        + '</div>'

      openSlideOver(html)
    }

    // Open supplier detail slide-over
    function openSupplierDetail(idx) {
      var s = suppliersData[idx]
      if (!s) return

      // Stars
      var starsHtml = ''
      for (var i = 1; i <= 5; i++) {
        if (i <= Math.floor(s.rating)) {
          starsHtml += '<svg width="14" height="14" style="color:var(--badge-amber-text)" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
        } else {
          starsHtml += '<svg width="14" height="14" style="color:var(--text-muted);opacity:0.3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>'
        }
      }

      // Categories
      var catsHtml = ''
      s.topCategories.forEach(function(c) {
        catsHtml += '<span style="display:inline-flex;padding:0.25rem 0.625rem;border-radius:9999px;font-size:0.75rem;font-weight:500;background:var(--bg-subtle);color:var(--text-tertiary);margin-right:0.375rem;margin-bottom:0.375rem">' + c + '</span>'
      })

      // Recent orders
      var ordersHtml = ''
      s.recentOrders.forEach(function(o) {
        var oBadge = o.status === 'Delivered' ? 'badge-emerald' : o.status === 'Shipped' ? 'badge-blue' : 'badge-amber'
        ordersHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:0.5rem 0;border-bottom:1px solid var(--row-border)">'
        ordersHtml += '<div>'
        ordersHtml += '<span style="font-size:0.8125rem;font-weight:500;color:var(--text-primary)">' + o.part + '</span>'
        ordersHtml += '<div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.125rem">' + o.order + ' — ' + o.date + '</div>'
        ordersHtml += '</div>'
        ordersHtml += '<div style="text-align:right">'
        ordersHtml += '<span style="font-size:0.8125rem;font-weight:500;color:var(--text-primary)">' + o.total + '</span>'
        ordersHtml += '<div><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium ' + oBadge + '">' + o.status + '</span></div>'
        ordersHtml += '</div></div>'
      })

      var html = ''
        + '<div style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;border-bottom:1px solid var(--border-main)">'
        + '<div>'
        + '<h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary)">' + s.name + '</h2>'
        + '<div style="display:flex;align-items:center;gap:0.375rem;margin-top:0.5rem">'
        + starsHtml
        + '<span style="font-size:0.875rem;font-weight:500;color:var(--text-primary);margin-left:0.25rem">' + s.rating + '</span>'
        + '</div>'
        + '</div>'
        + '<button onclick="closeSlideOver()" style="padding:0.5rem;border-radius:0.5rem;color:var(--text-muted);background:none;border:none;cursor:pointer" aria-label="Close">'
        + '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
        + '</button>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Contact Information</div>'
        + '<div class="detail-row"><span class="detail-row-label">Phone</span><span class="detail-row-value">' + s.contact.phone + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Email</span><span class="detail-row-value" style="color:var(--text-accent)">' + s.contact.email + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Account Rep</span><span class="detail-row-value">' + s.contact.rep + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Location</span><span class="detail-row-value">' + s.contact.address + '</span></div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Performance Metrics</div>'
        + '<div class="detail-row"><span class="detail-row-label">Parts Catalog</span><span class="detail-row-value">' + s.parts.toLocaleString() + ' parts</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Avg Delivery</span><span class="detail-row-value">' + s.avgDelivery + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">On-Time Delivery</span><span class="detail-row-value" style="color:var(--text-success)">' + s.onTime + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Orders This Month</span><span class="detail-row-value">' + s.metrics.ordersThisMonth + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Total Orders</span><span class="detail-row-value">' + s.metrics.totalOrders.toLocaleString() + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Return Rate</span><span class="detail-row-value">' + s.metrics.returnRate + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Avg Response Time</span><span class="detail-row-value">' + s.metrics.avgResponseTime + '</span></div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Top Categories</div>'
        + '<div style="display:flex;flex-wrap:wrap">' + catsHtml + '</div>'
        + '</div>'

        + '<div class="detail-section">'
        + '<div class="detail-label">Recent Orders</div>'
        + ordersHtml
        + '</div>'

        + '<div class="detail-section" style="display:flex;gap:0.75rem;flex-wrap:wrap">'
        + '<button onclick="showToast(\'Opening order form for ' + s.name.replace(/'/g, "\\'") + '...\', \'info\'); closeSlideOver();" style="flex:1;min-width:140px;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:#fff;background:var(--btn-primary-bg);border:none;cursor:pointer">Place Order</button>'
        + '<button onclick="showToast(\'Contacting ' + s.contact.rep.replace(/'/g, "\\'") + '...\', \'info\'); closeSlideOver();" style="flex:1;min-width:140px;padding:0.625rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:var(--btn-action-text);background:var(--btn-action-bg);border:1px solid var(--btn-action-border);cursor:pointer">Contact Rep</button>'
        + '</div>'

      openSlideOver(html)
    }

    // Initialize showing label
    filterParts()
</script>
