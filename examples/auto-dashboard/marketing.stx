          </div>
        @endforeach
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="m-section">
    <div class="m-section-inner">
      <div class="m-section-hdr fade-up">
        <h2>Trusted by collision professionals</h2>
        <p>Hear from shop owners and estimators who made the switch.</p>
      </div>
      <div class="m-testimonials">
        @foreach (testimonials as t)
          <div class="m-testimonial fade-up">
            <div class="m-testimonial-stars">
              <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <div class="m-testimonial-quote">"{{ t.quote }}"</div>
            <div class="m-testimonial-footer">
              <div class="m-testimonial-avatar">{{ t.avatar }}</div>
              <div>
                <div class="m-testimonial-name">{{ t.name }}</div>
                <div class="m-testimonial-role">{{ t.role }}</div>
              </div>
            </div>
          </div>
        @endforeach
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="m-section m-section-alt">
    <div class="m-section-inner">
      <div class="m-section-hdr fade-up">
        <h2>Simple, transparent pricing</h2>
        <p>Flat monthly rate per location. No per-seat fees. No surprises.</p>
      </div>
      <div class="m-pricing">
        @foreach (plans as plan)
          <div class="m-price-card{{ plan.highlight ? ' featured' : '' }} fade-up">
            @if (plan.highlight)
              <div class="m-price-badge">Most Popular</div>
            @endif
            <div class="m-price-name">{{ plan.name }}</div>
            <div class="m-price-amount">
              <span>{{ plan.price }}</span>
            </div>
            <div class="m-price-period">{{ plan.period }}</div>
            <ul class="m-price-features">
              @foreach (plan.features as feat)
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {{ feat }}
                </li>
              @endforeach
            </ul>
            <button class="m-price-cta" onclick="showToast('Starting your {{ plan.name }} trial...', 'success')">{{ plan.cta }}</button>
          </div>
        @endforeach
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="m-cta">
    <div class="m-cta-bg"></div>
    <div class="fade-up" style="position: relative">
      <h2>Ready to modernize your shop?</h2>
      <p>Join 2,400+ collision repair professionals who chose a better way to estimate.</p>
      <div class="m-hero-actions">
        <a href="/" class="m-btn-primary">
          Start Free Trial
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#pricing" class="m-btn-ghost">View Pricing</a>
      </div>
      <div class="m-cta-note">14-day free trial. No credit card required.</div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="m-footer">
    <div class="m-footer-inner">
      <div class="m-footer-left">
        <div class="m-footer-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <span class="m-footer-copy">{{ companyName }} &copy; 2026</span>
      </div>
      <div class="m-footer-links">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">Support</a>
        <a href="#">API</a>
        <a href="#">Status</a>
      </div>
    </div>
  </footer>

  <!-- Toast container -->
  <div id="toastWrap" class="m-toast-wrap"></div>

<script client>
  function toggleTheme() {
    var html = document.documentElement
    var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
    html.setAttribute('data-theme', next)
    localStorage.setItem('stx-theme', next)
    updateToggleIcon(next)
  }

  function updateToggleIcon(theme) {
    var icon = document.getElementById('themeIcon')
    if (!icon) return
    if (theme === 'dark') {
      icon.innerHTML = '<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>'
    } else {
      icon.innerHTML = '<path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0z"/>'
    }
  }
  updateToggleIcon(document.documentElement.getAttribute('data-theme') || 'dark')

  function showToast(msg, type) {
    var wrap = document.getElementById('toastWrap')
    var colors = { success: 'var(--text-success)', info: 'var(--text-accent)' }
    var bgColors = { success: 'rgba(16,185,129,0.08)', info: 'rgba(59,130,246,0.08)' }
    var borderColors = { success: 'rgba(16,185,129,0.2)', info: 'rgba(59,130,246,0.2)' }
    var t = document.createElement('div')
    t.style.cssText = 'pointer-events:auto;padding:0.625rem 1.125rem;border-radius:0.5rem;font-size:0.8125rem;font-weight:500;display:flex;align-items:center;gap:0.625rem;border:1px solid ' + (borderColors[type] || borderColors.info) + ';background:' + (bgColors[type] || bgColors.info) + ';color:' + (colors[type] || colors.info) + ';box-shadow:0 8px 32px rgba(0,0,0,0.12);animation:toastIn 0.3s cubic-bezier(0.16,1,0.3,1)'
    t.textContent = msg
    wrap.appendChild(t)
    setTimeout(function() { t.style.opacity = '0'; t.style.transform = 'translateY(8px)'; t.style.transition = 'all 0.25s'; }, 3000)
    setTimeout(function() { if (t.parentNode) t.parentNode.removeChild(t) }, 3300)
  }

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible')
      }
    })
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' })

  document.querySelectorAll('.fade-up').forEach(function(el) {
    observer.observe(el)
  })

  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'))
      if (target) {
        e.preventDefault()
        target.scrollIntoView({ behavior: 'smooth', block: 'start' })
      }
    })
  })
</script>

</body>
</html>
