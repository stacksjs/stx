      <div class="m-nav-right">
        <button class="m-theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
          <span class="knob"><svg id="themeIcon" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0z"/></svg></span>
        </button>
        <a href="#" class="m-nav-signin">Sign in</a>
        <a href="/" class="m-nav-cta">Start Free Trial</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="m-hero">
    <div class="m-hero-bg"></div>
    <div class="m-hero-content fade-up">
      <div class="m-hero-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        New: AI Photo Analysis
      </div>
      <h1>The modern platform for<br><span class="accent">collision estimating</span></h1>
      <p class="m-hero-sub">Write faster, more accurate estimates. Stay compliant with every insurer. Track production from check-in to delivery. All in one place.</p>
      <div class="m-hero-actions">
        <a href="/" class="m-btn-primary">
          Start Free Trial
