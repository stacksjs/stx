    </div>
  </div>

  <!-- Stats -->
  <section class="m-stats">
    <div class="m-stats-inner">
      @foreach (stats as stat)
        <div class="m-stat fade-up">
          <div class="m-stat-value">{{ stat.value }}</div>
          <div class="m-stat-label">{{ stat.label }}</div>
