  </section>

  <!-- Features -->
  <section id="features" class="m-section m-section-alt">
    <div class="m-section-inner">
      <div class="m-section-hdr fade-up">
        <h2>Everything your shop needs.<br>Nothing it doesn't.</h2>
        <p>Replace fragmented tools with one integrated platform built specifically for collision repair.</p>
      </div>
      <div class="m-features">
        @foreach (features as feature)
          <div class="m-feature{{ feature.highlight ? ' featured' : '' }} fade-up">
            <div class="m-feature-icon">
              @if (feature.id === 'ai')
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4c0 1.95-1.4 3.58-3.25 3.93L12 22"/><path d="M8 6a4 4 0 0 1 8 0"/><path d="M17 12.5c1.77.54 3 2.2 3 4.15 0 2.42-1.96 4.38-4.38 4.38H8.38C5.96 21.03 4 19.07 4 16.65c0-1.95 1.23-3.61 3-4.15"/></svg>
              @endif
              @if (feature.id === 'production')
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>
              @endif
              @if (feature.id === 'compliance')
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
              @endif
              @if (feature.id === 'parts')
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
              @endif
              @if (feature.id === 'reports')
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
              @endif
              @if (feature.id === 'crm')
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              @endif
