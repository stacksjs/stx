    <div class="m-trusted-logos">
      @foreach (trustedBy as brand)
        <span>{{ brand }}</span>
      @endforeach
    </div>
  </div>

  <!-- Dashboard Preview -->
  <div class="m-preview fade-up">
    <div class="m-preview-window">
      <div class="m-preview-bar">
        <div class="m-preview-dot" style="background: #ef4444"></div>
        <div class="m-preview-dot" style="background: #f59e0b"></div>
        <div class="m-preview-dot" style="background: #22c55e"></div>
        <div class="m-preview-url">app.autoestimatepro.com/dashboard</div>
      </div>
      <div class="m-preview-body">
        <div class="m-preview-grid">
          <div class="m-preview-stat">
            <div class="m-preview-stat-label">Total Estimates</div>
            <div class="m-preview-stat-val" style="color: var(--text-accent)">1,247</div>
