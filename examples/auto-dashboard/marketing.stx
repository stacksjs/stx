          </div>
          <div class="m-preview-stat">
            <div class="m-preview-stat-label">Revenue (MTD)</div>
            <div class="m-preview-stat-val" style="color: var(--text-success)">$482,630</div>
            <div class="m-preview-stat-bar" style="background: linear-gradient(90deg, #059669, #34d399); width: 62%"></div>
          </div>
          <div class="m-preview-stat">
            <div class="m-preview-stat-label">Avg Cycle Time</div>
            <div class="m-preview-stat-val" style="color: #8b5cf6">3.2 days</div>
            <div class="m-preview-stat-bar" style="background: linear-gradient(90deg, #7c3aed, #a78bfa); width: 40%"></div>
          </div>
        </div>
        <div class="m-preview-table">
          <div class="m-preview-table-hdr">
            <span>Estimate</span><span>Vehicle</span><span>Insurer</span><span>Status</span>
