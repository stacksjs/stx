          <div class="m-preview-table-row">
            <span style="color: var(--text-accent); font-weight: 600">EST-4821</span>
            <span>2024 Tesla Model Y</span>
            <span>State Farm</span>
            <span><span class="m-preview-badge" style="background: rgba(16,185,129,0.15); color: var(--text-success)">Approved</span></span>
          </div>
          <div class="m-preview-table-row">
            <span style="color: var(--text-accent); font-weight: 600">EST-4820</span>
            <span>2023 BMW X5</span>
            <span>Progressive</span>
            <span><span class="m-preview-badge" style="background: var(--badge-blue-bg); color: var(--badge-blue-text)">In Review</span></span>
          </div>
          <div class="m-preview-table-row">
            <span style="color: var(--text-accent); font-weight: 600">EST-4819</span>
            <span>2022 Honda Civic</span>
            <span>GEICO</span>
            <span><span class="m-preview-badge" style="background: rgba(245,158,11,0.12); color: #d97706">Supplement</span></span>
          </div>
