      {{-- Board View --}}
      <div id="boardView" class="fade-in">
        <div class="kanban-scroll">
          <div class="kanban-board" id="kanbanBoard">
            @foreach (stages as stage)
              <div class="kanban-column" data-stage="{{ stage.id }}">
                <div class="kanban-column-header" style="background: linear-gradient(135deg, var(--bar-{{ stage.color }}), var(--bar-{{ stage.color }}))">
                  <span class="text-sm font-semibold text-white">{{ stage.label }}</span>
                  <span class="text-xs font-bold text-white px-2 py-0.5 rounded-full" style="background: rgba(255,255,255,0.25)" data-count="{{ stage.id }}">{{ vehicles.filter(function(v) { return v.stage === stage.id }).length }}</span>
                </div>
                <div class="kanban-column-body glass" data-column="{{ stage.id }}">
                  @foreach (vehicles as v)
                    @if (v.stage === stage.id)
                      <div class="kanban-card" data-vehicle-id="{{ v.id }}" data-tech="{{ v.tech }}" data-priority="{{ v.priority }}" data-insurer="{{ v.insurer }}" onclick="openVehicleDetail({{ v.id }})">
                        <div class="flex items-start justify-between gap-2 mb-2">
                          <span class="text-sm font-semibold leading-tight" style="color: var(--text-primary)">{{ v.year }} {{ v.make }} {{ v.model }}</span>
                          <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-semibold flex-shrink-0 {{ stx.badgeClass(v.priority, 'priority') }}">{{ v.priority }}</span>
                        </div>
                        <div class="text-xs mb-1.5" style="color: var(--text-muted)">
                          <span class="font-mono" style="color: var(--text-accent)">{{ v.estimate }}</span>
                        </div>
                        <div class="text-xs mb-1" style="color: var(--text-tertiary)">{{ v.owner }}</div>
                        <div class="text-xs mb-2" style="color: var(--text-muted)">{{ v.insurer }}</div>
                        <div class="flex items-center justify-between mb-2">
                          <span class="text-xs" style="color: var(--text-muted)">{{ v.tech }}</span>
                          <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-semibold {{ v.days < 2 ? 'badge-emerald' : v.days <= 4 ? 'badge-amber' : 'badge-red' }}">{{ v.days }}d</span>
                        </div>
                        <div class="progress-dots">
                          @foreach (stages as si => s)
                            @if (stageIndex(v.stage) > si)
                              <div class="progress-dot completed"></div>
                            @elseif (stageIndex(v.stage) === si)
                              <div class="progress-dot current"></div>
                            @else
                              <div class="progress-dot pending"></div>
                            @endif
                          @endforeach
                        </div>
                      </div>
                    @endif
                  @endforeach
                </div>
              </div>
            @endforeach
          </div>
        </div>
      </div>

      {{-- List View --}}
      <div id="listView" class="fade-in glass rounded-xl overflow-hidden" style="display: none">
        <div class="px-5 py-4 flex items-center justify-between" style="border-bottom: 1px solid var(--border-main)">
          <h2 class="text-base font-semibold" style="color: var(--text-primary)">All Vehicles in Production</h2>
          <span id="listCount" class="text-xs" style="color: var(--text-muted)">19 vehicles</span>
        </div>
        <div class="overflow-x-auto">
          <table class="list-view-table" id="listTable">
            <thead>
              <tr>
                <th>Vehicle</th>
                <th>Estimate</th>
                <th>Owner</th>
                <th>Insurer</th>
                <th>Technician</th>
                <th>Stage</th>
                <th>Days</th>
                <th>Priority</th>
              </tr>
            </thead>
            <tbody id="listTableBody">
              @foreach (vehicles as v)
                <tr data-vehicle-id="{{ v.id }}" data-tech="{{ v.tech }}" data-priority="{{ v.priority }}" data-insurer="{{ v.insurer }}" onclick="openVehicleDetail({{ v.id }})">
                  <td>
                    <span class="font-medium" style="color: var(--text-secondary)">{{ v.year }} {{ v.make }} {{ v.model }}</span>
                  </td>
                  <td>
                    <span class="font-mono text-xs" style="color: var(--text-accent)">{{ v.estimate }}</span>
                  </td>
                  <td style="color: var(--text-tertiary)">{{ v.owner }}</td>
                  <td style="color: var(--text-muted)">{{ v.insurer }}</td>
                  <td style="color: var(--text-tertiary)">{{ v.tech }}</td>
                  <td>
                    <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium badge-{{ stages.find(function(s) { return s.id === v.stage }).color }}">{{ stages.find(function(s) { return s.id === v.stage }).label }}</span>
                  </td>
                  <td>
                    <span class="inline-flex px-1.5 py-0.5 rounded text-xs font-semibold {{ v.days < 2 ? 'badge-emerald' : v.days <= 4 ? 'badge-amber' : 'badge-red' }}">{{ v.days }}d</span>
                  </td>
                  <td>
                    <span class="inline-flex px-2 py-0.5 rounded text-xs font-semibold {{ stx.badgeClass(v.priority, 'priority') }}">{{ v.priority }}</span>
                  </td>
                </tr>
              @endforeach
            </tbody>
          </table>
        </div>
      </div>
