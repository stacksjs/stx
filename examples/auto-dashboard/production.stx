      { id: 15, year: 2022, make: 'Mazda', model: 'CX-5', estimate: 'EST-4660', owner: 'Tyler Nguyen', insurer: 'Progressive', tech: 'James Wilson', days: 1, priority: 'Normal', stage: 'qc', vin: 'JM3KFBCM5N1234567', color: 'Soul Red Crystal Metallic', phone: '(949) 555-0176', damage: 'Rear bumper replacement', notes: 'QC inspection in progress. Minor touch-up needed on clear.' },
      { id: 16, year: 2024, make: 'Volkswagen', model: 'Tiguan', estimate: 'EST-4648', owner: 'Amanda Foster', insurer: 'Liberty Mutual', tech: 'Ana Reyes', days: 0, priority: 'Low', stage: 'qc', vin: '3VV3B7AX5RM456789', color: 'Pure White', phone: '(813) 555-0298', damage: 'Door ding repair — PDR and touch-up', notes: 'Detail and final wash scheduled today.' },
      { id: 17, year: 2023, make: 'Toyota', model: 'Tacoma', estimate: 'EST-4635', owner: 'Carlos Mendez', insurer: 'GEICO', tech: 'Chris Webb', days: 0, priority: 'Normal', stage: 'ready', vin: '3TMCZ5AN5PM567890', color: 'Magnetic Gray Metallic', phone: '(520) 555-0443', damage: 'Front bumper and fender repair', notes: 'Ready. Customer notified, pickup scheduled for tomorrow 10am.' },
      { id: 18, year: 2024, make: 'Audi', model: 'Q5', estimate: 'EST-4620', owner: 'Natalie Cooper', insurer: 'Allstate', tech: 'Derek Hall', days: 1, priority: 'Normal', stage: 'ready', vin: 'WA1BNAFY5R2678901', color: 'Navarra Blue Metallic', phone: '(612) 555-0187', damage: 'Hail damage — full PDR and paint correction', notes: 'Complete. Awaiting customer pickup. Insurance check ready.' },
      { id: 19, year: 2022, make: 'Jeep', model: 'Grand Cherokee', estimate: 'EST-4610', owner: 'Greg Lawson', insurer: 'USAA', tech: 'Mike Torres', days: 0, priority: 'Low', stage: 'ready', vin: '1C4RJKBG5N8789012', color: 'Sting-Gray', phone: '(480) 555-0356', damage: 'Rear-end minor — bumper and tailgate', notes: 'Complete. Customer picking up this afternoon.' }
    ]

    // View toggle (signal)
    var currentView = state('board')
    effect(function() {
      var v = currentView()
      var boardEl = document.getElementById('boardView')
      var listEl = document.getElementById('listView')
      var btnBoard = document.getElementById('btnBoardView')
      var btnList = document.getElementById('btnListView')
      if (!boardEl || !listEl) return
      if (v === 'board') {
        boardEl.style.display = ''
        listEl.style.display = 'none'
        if (btnBoard) btnBoard.classList.add('active')
        if (btnList) btnList.classList.remove('active')
      } else {
        boardEl.style.display = 'none'
        listEl.style.display = ''
        if (btnBoard) btnBoard.classList.remove('active')
        if (btnList) btnList.classList.add('active')
      }
    })
    function setView(view) { currentView.set(view) }

    // Filtering
    function applyFilters() {
      var tech = document.getElementById('filterTech').value
      var priority = document.getElementById('filterPriority').value
      var insurer = document.getElementById('filterInsurer').value

      // Filter board cards
      var cards = document.querySelectorAll('.kanban-card')
      cards.forEach(function(card) {
        var matchTech = !tech || card.getAttribute('data-tech') === tech
        var matchPriority = !priority || card.getAttribute('data-priority') === priority
        var matchInsurer = !insurer || card.getAttribute('data-insurer') === insurer
        card.style.display = (matchTech && matchPriority && matchInsurer) ? '' : 'none'
      })

      // Filter list rows
      var rows = document.querySelectorAll('#listTableBody tr')
      var visibleCount = 0
      rows.forEach(function(row) {
        var matchTech = !tech || row.getAttribute('data-tech') === tech
        var matchPriority = !priority || row.getAttribute('data-priority') === priority
        var matchInsurer = !insurer || row.getAttribute('data-insurer') === insurer
        var visible = matchTech && matchPriority && matchInsurer
        row.style.display = visible ? '' : 'none'
        if (visible) visibleCount++
      })

      // Update column counts
      stageOrder.forEach(function(stageId) {
        var col = document.querySelector('[data-column="' + stageId + '"]')
        if (col) {
          var visibleCards = col.querySelectorAll('.kanban-card:not([style*="display: none"])')
          var countEl = document.querySelector('[data-count="' + stageId + '"]')
          if (countEl) countEl.textContent = visibleCards.length
        }
      })

      document.getElementById('listCount').textContent = visibleCount + ' vehicles'
    }

    function clearFilters() {
      document.getElementById('filterTech').value = ''
      document.getElementById('filterPriority').value = ''
      document.getElementById('filterInsurer').value = ''
      applyFilters()
      showToast('Filters cleared', 'info')
    }

    // Vehicle detail slide-over
    function openVehicleDetail(id) {
      var v = null
      for (var i = 0; i < vehicleData.length; i++) {
        if (vehicleData[i].id === id) { v = vehicleData[i]; break; }
      }
      if (!v) return

      var currentIdx = stageOrder.indexOf(v.stage)
      var isLastStage = currentIdx === stageOrder.length - 1

      // Build progress timeline
      var timeline = ''
      stageOrder.forEach(function(sid, idx) {
        var isCurrent = sid === v.stage
        var isCompleted = idx < currentIdx
        var dotStyle = ''
        var labelStyle = ''
        if (isCompleted) {
          dotStyle = 'background: var(--text-accent);'
          labelStyle = 'color: var(--text-accent);'
        } else if (isCurrent) {
          dotStyle = 'background: var(--bar-amber); box-shadow: 0 0 8px var(--bar-amber);'
          labelStyle = 'color: var(--text-primary); font-weight: 600;'
        } else {
          dotStyle = 'background: var(--bar-track);'
          labelStyle = 'color: var(--text-muted);'
        }
        var lineColor = isCompleted ? 'var(--text-accent)' : 'var(--bar-track)'
        timeline += '<div style="display: flex; align-items: center; gap: 0.5rem;">'
        timeline += '<div style="width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; ' + dotStyle + '"></div>'
        timeline += '<span style="font-size: 0.8125rem; ' + labelStyle + '">' + stageLabels[sid] + '</span>'
        timeline += '</div>'
        if (idx < stageOrder.length - 1) {
          timeline += '<div style="width: 2px; height: 16px; margin-left: 5px; background: ' + lineColor + ';"></div>'
        }
      })

      // Days badge
      var daysBadge = v.days < 2 ? 'badge-emerald' : v.days <= 4 ? 'badge-amber' : 'badge-red'

      var priorityBadge = stx.badgeClass(v.priority, 'priority')

      var nextStageLabel = isLastStage ? '' : stageLabels[stageOrder[currentIdx + 1]]

      var html = ''
        + '<div style="display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-main);">'
        + '<div>'
        + '<h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary);">' + v.year + ' ' + v.make + ' ' + v.model + '</h2>'
        + '<div style="display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap;">'
        + '<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium ' + priorityBadge + '">' + v.priority + '</span>'
        + '<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium badge-' + stageColors[v.stage] + '">' + stageLabels[v.stage] + '</span>'
        + '<span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium ' + daysBadge + '">' + v.days + ' day' + (v.days !== 1 ? 's' : '') + ' in stage</span>'
        + '</div>'
        + '</div>'
        + '<button onclick="closeSlideOver()" style="padding: 0.5rem; border-radius: 0.5rem; color: var(--text-muted); background: none; border: none; cursor: pointer;" aria-label="Close">'
        + '<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
        + '</button>'
        + '</div>'

        // Vehicle info
        + '<div class="detail-section">'
        + '<div class="detail-label">Vehicle Information</div>'
        + '<div class="detail-row"><span class="detail-row-label">VIN</span><span class="detail-row-value" style="font-family: monospace; font-size: 0.8125rem;">' + v.vin + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Color</span><span class="detail-row-value">' + v.color + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Estimate</span><span class="detail-row-value" style="color: var(--text-accent);">' + v.estimate + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Damage</span><span class="detail-row-value" style="max-width: 320px; text-align: right;">' + v.damage + '</span></div>'
        + '</div>'

        // Owner & insurer
        + '<div class="detail-section">'
        + '<div class="detail-label">Owner & Insurer</div>'
        + '<div class="detail-row"><span class="detail-row-label">Owner</span><span class="detail-row-value">' + v.owner + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Phone</span><span class="detail-row-value">' + v.phone + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Insurer</span><span class="detail-row-value">' + v.insurer + '</span></div>'
        + '</div>'

        // Assigned tech
        + '<div class="detail-section">'
        + '<div class="detail-label">Assignment</div>'
        + '<div class="detail-row"><span class="detail-row-label">Technician</span><span class="detail-row-value">' + v.tech + '</span></div>'
        + '<div class="detail-row"><span class="detail-row-label">Priority</span><span class="detail-row-value"><span class="inline-flex px-2 py-0.5 rounded text-xs font-semibold ' + priorityBadge + '">' + v.priority + '</span></span></div>'
        + '</div>'

        // Repair timeline
        + '<div class="detail-section">'
        + '<div class="detail-label">Repair Timeline</div>'
        + '<div style="display: flex; flex-direction: column; gap: 2px; padding: 0.5rem 0;">'
        + timeline
        + '</div>'
        + '</div>'

        // Notes
        + '<div class="detail-section">'
        + '<div class="detail-label">Notes</div>'
        + '<p style="font-size: 0.875rem; color: var(--text-tertiary); line-height: 1.6;">' + v.notes + '</p>'
        + '</div>'

        // Action buttons
        + '<div class="detail-section" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">'
        + (isLastStage
          ? '<button onclick="markDelivered(' + v.id + ')" class="px-4 py-2.5 rounded-lg text-sm font-medium text-white flex items-center gap-2" style="background: var(--bar-emerald);"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Mark Delivered</button>'
          : '<button onclick="moveToNextStage(' + v.id + ')" class="px-4 py-2.5 rounded-lg text-sm font-medium text-white flex items-center gap-2" style="background: var(--btn-primary-bg);"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>Move to ' + nextStageLabel + '</button>')
        + '<button onclick="closeSlideOver(); showToast(\'Estimate ' + v.estimate + ' opened\', \'info\')" class="px-4 py-2.5 rounded-lg text-sm font-medium flex items-center gap-2" style="background: var(--btn-action-bg); border: 1px solid var(--btn-action-border); color: var(--btn-action-text);"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>View Estimate</button>'
        + '</div>'

      openSlideOver(html)
    }

    // Move vehicle to next stage
    function moveToNextStage(id) {
      var v = null
      var vIdx = -1
      for (var i = 0; i < vehicleData.length; i++) {
        if (vehicleData[i].id === id) { v = vehicleData[i]; vIdx = i; break; }
      }
      if (!v) return

      var currentIdx = stageOrder.indexOf(v.stage)
      if (currentIdx >= stageOrder.length - 1) return

      var nextStage = stageOrder[currentIdx + 1]
      var oldStage = v.stage

      // Update data
      vehicleData[vIdx].stage = nextStage
      vehicleData[vIdx].days = 0

      // Move card in the DOM
      var card = document.querySelector('.kanban-card[data-vehicle-id="' + id + '"]')
      var targetColumn = document.querySelector('[data-column="' + nextStage + '"]')
      if (card && targetColumn) {
        card.remove()
        targetColumn.appendChild(card)
      }

      // Also update the list view row stage badge
      var row = document.querySelector('#listTableBody tr[data-vehicle-id="' + id + '"]')
      if (row) {
        var stageTd = row.querySelectorAll('td')[5]
        if (stageTd) {
          stageTd.innerHTML = '<span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium badge-' + stageColors[nextStage] + '">' + stageLabels[nextStage] + '</span>'
        }
        var daysTd = row.querySelectorAll('td')[6]
        if (daysTd) {
          daysTd.innerHTML = '<span class="inline-flex px-1.5 py-0.5 rounded text-xs font-semibold badge-emerald">0d</span>'
        }
      }

      // Update column counts
      updateColumnCounts()

      closeSlideOver()
      showToast(v.year + ' ' + v.make + ' ' + v.model + ' moved to ' + stageLabels[nextStage], 'success')
    }

    function markDelivered(id) {
      var v = null
      for (var i = 0; i < vehicleData.length; i++) {
        if (vehicleData[i].id === id) { v = vehicleData[i]; break; }
      }
      if (!v) return

      // Remove from board
      var card = document.querySelector('.kanban-card[data-vehicle-id="' + id + '"]')
      if (card) card.remove()

      // Remove from list
      var row = document.querySelector('#listTableBody tr[data-vehicle-id="' + id + '"]')
      if (row) row.remove()

      updateColumnCounts()
      closeSlideOver()
      showToast(v.year + ' ' + v.make + ' ' + v.model + ' marked as delivered!', 'success')
    }

    function updateColumnCounts() {
      stageOrder.forEach(function(stageId) {
        var col = document.querySelector('[data-column="' + stageId + '"]')
        if (col) {
          var visibleCards = col.querySelectorAll('.kanban-card:not([style*="display: none"])')
          var countEl = document.querySelector('[data-count="' + stageId + '"]')
          if (countEl) countEl.textContent = visibleCards.length
        }
      })
    }
</script>
