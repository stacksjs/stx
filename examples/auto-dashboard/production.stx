          <select id="filterTech" onchange="applyFilters()" class="rounded-lg py-2.5 text-sm focus:outline-none" style="background: var(--bg-input); border: 1px solid var(--border-input); color: var(--text-tertiary); padding-left: 0.75rem; padding-right: 2rem">
            <option value="">All Technicians</option>
            @foreach (technicians as tech)
              <option value="{{ tech }}">{{ tech }}</option>
