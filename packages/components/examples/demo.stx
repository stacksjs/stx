<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@stacksjs/components - Demo</title>
</head>
<body class="min-h-screen bg-neutral-50 dark:bg-neutral-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero Section -->
    <Hero
      title="@stacksjs/components"
      description="A modern component library built with STX, headwind, and TypeScript"
      githubUrl="https://github.com/stacksjs/stx/tree/main/packages/components"
    >
      <!-- Custom demo in hero slot -->
      <div class="flex gap-2">
        <Button variant="primary" size="md">Get Started</Button>
      </div>
    </Hero>

    <!-- Main Content -->
    <main class="mt-16 space-y-16">
      <!-- Button Examples -->
      <section>
        <h2 class="text-3xl font-bold mb-6 text-neutral-900 dark:text-white">Button Component</h2>

        <div class="space-y-8">
          <!-- Variants -->
          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">Variants</h3>
            <div class="flex flex-wrap gap-4">
              <Button variant="primary">Primary</Button>

              <Button variant="secondary">Secondary</Button>

              <Button variant="outline">Outline</Button>

              <Button variant="ghost">Ghost</Button>

              <Button variant="danger">Danger</Button>
            </div>
          </div>

          <!-- Sizes -->
          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">Sizes</h3>
            <div class="flex items-center flex-wrap gap-4">
              <Button variant="primary" size="sm">Small</Button>

              <Button variant="primary" size="md">Medium</Button>

              <Button variant="primary" size="lg">Large</Button>
            </div>
          </div>

          <!-- Disabled -->
          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">Disabled State</h3>
            <div class="flex flex-wrap gap-4">
              <Button variant="primary" disabled>Disabled</Button>
            </div>
          </div>
        </div>
      </section>

      <!-- Switch Examples -->
      <section>
        <h2 class="text-3xl font-bold mb-6 text-neutral-900 dark:text-white">Switch Component</h2>

        <div class="space-y-8">
          <!-- Basic -->
          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">Basic Switch</h3>
            <div class="space-y-4">
              <Switch checked label="Enable notifications" />
              <Switch label="Email updates" />
            </div>
          </div>

          <!-- Sizes -->
          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">Sizes</h3>
            <div class="space-y-4">
              <Switch checked size="sm" label="Small" />
              <Switch checked size="md" label="Medium" />
              <Switch checked size="lg" label="Large" />
            </div>
          </div>

          <!-- Disabled -->
          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">Disabled State</h3>
            <div class="space-y-4">
              <Switch checked disabled label="Cannot toggle (enabled)" />
              <Switch disabled label="Cannot toggle (disabled)" />
            </div>
          </div>
        </div>
      </section>

      <!-- Code Block Example -->
      <section>
        <h2 class="text-3xl font-bold mb-6 text-neutral-900 dark:text-white">Code Block Component</h2>

        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">TypeScript Example</h3>
            <CodeBlock
              :code="`import { Button, Switch } from '@stacksjs/components'

function App() {
  const handleClick = () => {
    console.log('Button clicked!')
  }

  return (
    <div>
      <Button variant='primary' onClick={handleClick}>
        Click me
      </Button>
    </div>
  )
}`"
              language="typescript"
              copyable
            />
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-4 text-neutral-800 dark:text-neutral-200">Installation</h3>
            <Installation packageName="@stacksjs/components" />
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <div class="mt-24">
      <Footer
        author="@chrisbbreuer"
        authorUrl="https://github.com/chrisbbreuer"
        project="@stacksjs"
        projectUrl="https://github.com/stacksjs/stx"
      />
    </div>
  </div>
</body>
</html>
