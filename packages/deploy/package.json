{
  "name": "@stx/deploy",
  "type": "module",
  "version": "0.2.6",
  "description": "Deployment adapters for STX applications. Bun server default, static export, and community adapter interface.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/stx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stx.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stx/issues"
  },
  "keywords": [
    "deploy",
    "adapter",
    "bun-server",
    "static",
    "production",
    "stx"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE.md",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun --bun build.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun tsc --noEmit"
  }
}
