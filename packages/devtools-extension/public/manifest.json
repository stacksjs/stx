{
  "manifest_version": 3,
  "name": "Stacks DevTools",
  "version": "0.2.70",
  "description": "Inspect stx signals, scopes, the reactive graph, the :if decision trace, and the query timeline.",
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": []
}
