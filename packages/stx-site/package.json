{
  "name": "@stacksjs/stx-site",
  "type": "module",
  "version": "0.2.24",
  "description": "Build + deploy helpers for static stx marketing sites: SEO, sitemap, robots, 404, public assets, AWS deploy via Porkbun/Route53.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/stx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/stx.git",
    "directory": "packages/stx-site"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/stx/issues"
  },
  "keywords": [
    "stx",
    "static-site",
    "ssg",
    "seo",
    "sitemap",
    "deploy",
    "aws",
    "cloudfront",
    "porkbun"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE.md",
    "README.md",
    "dist"
  ],
  "dependencies": {
    "@stacksjs/stx": "workspace:*",
    "@stacksjs/ts-cloud": "^0.2.8",
    "bun-plugin-stx": "workspace:*"
  },
  "devDependencies": {
    "bun-plugin-dtsx": "^0.21.5"
  },
  "scripts": {
    "build": "bun --bun build.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit"
  }
}
